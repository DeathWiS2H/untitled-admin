function Cmd.tornado(targetPlayer, radius, speed, spinRate, velocityMagnitude)
    disconnectConnection("tornado")
    if not (targetPlayer and targetPlayer.Character and player.Character) then return end
    local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local targetHum = targetPlayer.Character:FindFirstChild("Humanoid")
    local localHum = player.Character:FindFirstChild("Humanoid")
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    if not (targetRoot and targetHum and localHum and root) then return end
    states.tornado = true
    radius = tonumber(radius) or 14
    speed = tonumber(speed) or 30
    spinRate = tonumber(spinRate) or 35
    velocityMagnitude = tonumber(velocityMagnitude) or 25
    localHum:ChangeState(Enum.HumanoidStateType.Physics)
    localHum.PlatformStand = true
    local track
    pcall(function()
        local anim = Instance.new("Animation")
        anim.AnimationId = "rbxassetid://135373056067761"
        local animator = localHum:FindFirstChildOfClass("Animator") or Instance.new("Animator", localHum)
        track = animator:LoadAnimation(anim)
        track.Priority = Enum.AnimationPriority.Action4
        track:Play(0, 1, 1)
        task.defer(function()
            if track then
                track.TimePosition = 0
                track:AdjustSpeed(0)
            end
        end)
    end)
    local ang = math.random() * math.pi * 2
    local moveDir = Vector3.new(math.cos(ang), 0, math.sin(ang))
    local offset = moveDir * (radius * 0.5)
    local spinAngle = 0
    local spinEnergy = 1
    local wobblePhase = math.random() * math.pi * 2
    local precessPhase = 0
    local burst = 0
    local function bounceOff(normal)
        moveDir = (moveDir - 2 * moveDir:Dot(normal) * normal)
        if moveDir.Magnitude < 0.01 then moveDir = -normal else moveDir = moveDir.Unit end
        local jitter = (math.random() - 0.5) * 0.7
        moveDir = (CFrame.Angles(0, jitter, 0) * CFrame.new(moveDir)).Position.Unit
        burst = 1
    end
    connections.tornado = RunService.Heartbeat:Connect(function(dt)
        if not (states.tornado and targetPlayer.Character and targetRoot and targetHum.Health > 0 and player.Character) then
            local h = player.Character and player.Character:FindFirstChild("Humanoid")
            if h then h.PlatformStand = false h:ChangeState(Enum.HumanoidStateType.GettingUp) end
            disconnectConnection("tornado")
            if track then pcall(function() track:Stop(0) end) track = nil end
            states.tornado = false
            return
        end
        root = player.Character:FindFirstChild("HumanoidRootPart")
        targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not (root and targetRoot) then return end
        spinEnergy = spinEnergy - dt * 0.06
        if spinEnergy < 0.25 then
            spinEnergy = 1
            burst = 1.5
            local a = math.random() * math.pi * 2
            moveDir = Vector3.new(math.cos(a), 0, math.sin(a))
        end
        burst = math.max(0, burst - dt * 1.8)
        local curSpeed = speed * (0.55 + 0.45 * spinEnergy) * (1 + burst * 0.9)
        offset = offset + moveDir * curSpeed * dt
        local flat = Vector3.new(offset.X, 0, offset.Z)
        if flat.Magnitude > radius then
            bounceOff(flat.Unit)
            offset = flat.Unit * (radius - 0.1)
        end
        local curSpin = spinRate * (0.3 + 0.7 * spinEnergy) * (1 + burst)
        spinAngle = spinAngle + curSpin * dt
        wobblePhase = wobblePhase + dt * (2 + (1 - spinEnergy) * 8)
        precessPhase = precessPhase + dt * (1.5 + (1 - spinEnergy) * 4)
        local wobbleAmt = math.rad(4 + (1 - spinEnergy) * 26 + burst * 6)
        local tiltX = math.sin(precessPhase) * wobbleAmt
        local tiltZ = math.cos(precessPhase) * wobbleAmt
        local grind = math.abs(math.sin(wobblePhase * 3)) * (1 - spinEnergy) * 0.8
        local pos = targetRoot.Position + Vector3.new(offset.X, grind, offset.Z)
        root.CFrame = CFrame.new(pos) * CFrame.Angles(tiltX, spinAngle, tiltZ)
        root.Velocity = (targetRoot.Position - root.Position).Unit * velocityMagnitude
        root.RotVelocity = Vector3.new(0, curSpin, 0)
    end)
end

