function registerWeldCommand(w)
    if not (w and w.name and w.name ~= "") then return end
    local nm = w.name:lower()
    if protectedWeldNames[nm] then return end
    CommandRegistry:addCommand(nm, function(pp, a)
        disablebool()
        local t = findPlayer(a[1], pp)
        if t then
            local aid = w.anim and w.anim ~= "" and weldFindAnimId(w.anim) or nil
            Cmd.weldAdv(t, w.fwd, w.side, w.up, w.rotX, w.rotY, w.rotZ, w.vel, w.dur, aid)
        end
    end, {description="Custom weld position", usage=nm.." (player)"})
end

