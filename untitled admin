            if plr ~= targetPlayer and plr ~= player and plr.Character then
                local plrRoot = plr.Character:FindFirstChild("HumanoidRootPart")
                local plrHum = plr.Character:FindFirstChild("Humanoid")
                if plrRoot and plrHum and plrHum.Health > 0 then
                    local distance = (targetRoot.Position - plrRoot.Position).Magnitude
                    if distance <= radius then
                        flingTargets[plr] = true
                        if distance < closestDistance then closestDistance = distance activeTarget = plr end
                    else
                        flingTargets[plr] = nil
                    end
                end
            end
        end
        if activeTarget and activeTarget.Character then
            local activeRoot = activeTarget.Character:FindFirstChild("HumanoidRootPart")
            local activeHum = activeTarget.Character:FindFirstChild("Humanoid")
            if activeRoot and activeHum and activeHum.Health > 0 then
                if not isFlinging then originalCFrame = localRoot.CFrame end
                if activeRoot.Velocity.Magnitude > 1000 then
                    flingTargets[activeTarget] = nil
                    isFlinging = false
                    unbindRep()
                    stripFFBodies()
                    for _, v in pairs(player.Character:GetDescendants()) do
                        if v:IsA("BasePart") then v.Velocity, v.RotVelocity = Vector3.zero, Vector3.zero end
                    end
                    if originalCFrame then localRoot.CFrame = originalCFrame end
                    return
                end
                isFlinging = true
                pcall(function() sethiddenproperty(localRoot, "PhysicsRepRootPart", activeRoot) end)
                if not localRoot:FindFirstChild("FFSpinning") then
                    local spin = Instance.new("BodyAngularVelocity")
                    spin.Name, spin.Parent, spin.MaxTorque = "FFSpinning", localRoot, Vector3.new(math.huge, math.huge, math.huge)
                    spin.AngularVelocity = Vector3.new(999999, 999999, 999999)
                end
                if not localRoot:FindFirstChild("FFUpward") then
                    local vel = Instance.new("BodyVelocity")
                    vel.Name, vel.Parent, vel.MaxForce = "FFUpward", localRoot, Vector3.new(math.huge, math.huge, math.huge)
                    vel.Velocity = Vector3.new(999999, 999999, 999999)
                end
                localRoot.CFrame = activeRoot.CFrame
            else
                flingTargets[activeTarget] = nil
                isFlinging = false
            end
        else
            if isFlinging then
                isFlinging = false
                unbindRep()
                stripFFBodies()
                for _, v in pairs(player.Character:GetDescendants()) do
                    if v:IsA("BasePart") then v.Velocity, v.RotVelocity = Vector3.zero, Vector3.zero end
                end
                if originalCFrame then localRoot.CFrame = originalCFrame end
            end
        end
    end)
end

function Cmd.stalk(targetPlayer)
