    local humanoid = player.Character:FindFirstChild("Humanoid")
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    if not (humanoid and root) then return end
    states.stalk = true
    local orgGravity = workspace.Gravity
    workspace.Gravity = 0
    pcall(function() root.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 5) end)
    pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Physics) end)
    local posVel, springVelY = Vector3.zero, 0
    local stiffX, dampX, stiffY, dampY = 1.5, 0.95, 1.5, 0.95
    connections.stalk = RunService.Heartbeat:Connect(function(dt)
        if not states.stalk then
            workspace.Gravity = orgGravity
            if humanoid then pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end) end
            disconnectConnection("stalk")
            return
        end
        if not (player.Character and targetPlayer and targetPlayer.Character) then
            states.stalk = false
            workspace.Gravity = orgGravity
            if humanoid then pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end) end
            disconnectConnection("stalk")
            return
        end
        root = player.Character:FindFirstChild("HumanoidRootPart")
        targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not (root and targetRoot) then
            states.stalk = false
            workspace.Gravity = orgGravity
            if humanoid then pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end) end
            disconnectConnection("stalk")
            return
        end
        pcall(function()
            local currentPos = root.Position
            local targetPos = targetRoot.Position - targetRoot.CFrame.LookVector * 3
            local toPlayer = (currentPos - targetRoot.Position).Unit
            local dotProduct = toPlayer:Dot(targetRoot.CFrame.LookVector)
            if dotProduct > 0.5 then
                posVel, springVelY = Vector3.zero, 0
                root.Velocity = Vector3.zero
            else
                local disp = targetPos - currentPos
                local yDisp = targetPos.Y - currentPos.Y
                local yAccel = (yDisp * stiffY) - (springVelY * dampY)
                springVelY = springVelY + yAccel * dt
                local accel = disp * stiffX - posVel * dampX
                posVel = posVel + accel * dt
                local newPos = Vector3.new(currentPos.X + posVel.X * dt, currentPos.Y + springVelY * dt, currentPos.Z + posVel.Z * dt)
                root.CFrame = CFrame.new(newPos, Vector3.new(targetRoot.Position.X, newPos.Y, targetRoot.Position.Z))
            end
        end)
    end)
end

function Cmd.loom(targetPlayer, height, distance)
