function applyButtonTransparencyTo(btn)
    if not (btn and btn:GetAttribute("UAButton")) then return end
    local t = math.clamp((state.grid and state.grid.transp) or 0, 0, 1)
    local mode = (state.grid and state.grid.transpMode) or "fill"
    local topBar = btn:FindFirstChild("TopBar")
    local textBtn = btn:FindFirstChildOfClass("TextButton")
    local stroke = btn:FindFirstChildOfClass("UIStroke")
    local accent = topBar and topBar:FindFirstChildOfClass("Frame")
    btn.BackgroundTransparency = t
    if topBar then topBar.BackgroundTransparency = t end
    if accent then accent.BackgroundTransparency = t end
    if mode == "whole" then
        if stroke then stroke.Transparency = t end
        if textBtn then textBtn.TextTransparency = t end
    else
        if stroke then stroke.Transparency = 0 end
        if textBtn then textBtn.TextTransparency = 0 end
    end
end

function applyButtonTransparency()
    for _, b in ipairs(UI.buttonGui:GetChildren()) do
        if b:IsA("Frame") and b:GetAttribute("UAButton") then
            applyButtonTransparencyTo(b)
        end
    end
end

