    workspace.Gravity = 0
    pcall(function() root.CFrame = targetRoot.CFrame end)
    pcall(function() humanoid.Sit = true end)
    local posVel, springVelY = Vector3.zero, 0
    local stiffX, dampX, stiffY, dampY = 3, 0.9, 3, 0.9
    connections.genie = RunService.Heartbeat:Connect(function(dt)
        if not states.genie then
            workspace.Gravity = orgGravity
            if humanoid then pcall(function() humanoid.Sit = false end) end
            disconnectConnection("genie")
            return
        end
        if not (player.Character and targetPlayer and targetPlayer.Character) then
