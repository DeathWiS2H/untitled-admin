    local localHum = player.Character:FindFirstChild("Humanoid")
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    if not (targetRoot and targetHum and localHum and root) then return end
    states.gun = true
    velocityMagnitude = math.abs(tonumber(velocityMagnitude) or 500)
    local returnCF = root.CFrame
    if setDeathGuard then setDeathGuard(true) end
    localHum:ChangeState(Enum.HumanoidStateType.Physics)
    localHum.PlatformStand = true
    pcall(function()
        if sethiddenproperty then
            sethiddenproperty(player, "MaximumSimulationRadius", math.huge)
            sethiddenproperty(player, "SimulationRadius", math.huge)
        end
    end)
    local function trueCF()
        local rep
        pcall(function()
            if gethiddenproperty then rep = gethiddenproperty(targetRoot, "PhysicsRepRootPart") end
        end)
        return typeof(rep) == "CFrame" and rep or targetRoot.CFrame
    end
    local gunTrack
    pcall(function()
        local anim = Instance.new("Animation")
        anim.AnimationId = "rbxassetid://73468073017890"
        local animator = localHum:FindFirstChildOfClass("Animator") or Instance.new("Animator", localHum)
        gunTrack = animator:LoadAnimation(anim)
        gunTrack.Priority = Enum.AnimationPriority.Action4
        gunTrack:Play(0, 1, 1)
    end)
    local FRONT = 4.5
    local OVERRUN = 2
    local RAISE = 1.2
    local WINDUP_DUR = 3.75
    local RECOIL_DUR = 0.75
    local RECOIL_BACK = 1
    local FIRE_DUR = 0.2
    local LINGER_DUR = 0.1
    local phase = "windup"
    local phaseT = os.clock()
    local lockPos, lockOut = nil, nil
    local function cleanup()
        disconnectConnection("gun")
        if gunTrack then pcall(function() gunTrack:Stop(0.1) end) gunTrack = nil end
        local c = player.Character
        local r = c and c:FindFirstChild("HumanoidRootPart")
        local h = c and c:FindFirstChildOfClass("Humanoid")
        if r then
            pcall(function() sethiddenproperty(r, "PhysicsRepRootPart", r) end)
            r.AssemblyLinearVelocity = Vector3.zero
            r.AssemblyAngularVelocity = Vector3.zero
            r.CFrame = returnCF
        end
        if h then h.PlatformStand = false h:ChangeState(Enum.HumanoidStateType.GettingUp) end
        if setDeathGuard then task.delay(1, function() setDeathGuard(false) end) end
        states.gun = false
    end
    connections.gun = RunService.Heartbeat:Connect(function(dt)
        dt = math.min(dt, 1/20)
        if not (states.gun and player.Character and targetPlayer and targetPlayer.Parent and targetPlayer.Character) then
            cleanup()
            return
        end
        root = player.Character:FindFirstChild("HumanoidRootPart")
        targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local hum = player.Character:FindFirstChild("Humanoid")
        if not (root and targetRoot and hum and targetHum.Health > 0) then
            cleanup()
            return
        end
        hum.PlatformStand = true
        pcall(function() sethiddenproperty(root, "PhysicsRepRootPart", targetRoot) end)
        if gunTrack and not gunTrack.IsPlaying then
            pcall(function() gunTrack:Play(0, 1, 1) end)
        end
        local tcf = trueCF()
        local tpos = tcf.Position
        local outDir = Vector3.new(tcf.LookVector.X, 0, tcf.LookVector.Z)
        outDir = outDir.Magnitude > 0.1 and outDir.Unit or Vector3.zAxis
        local now = os.clock()
        local t = now - phaseT
        local pos
        local lookPoint
        if phase == "windup" then
            pos = tpos + outDir * FRONT + Vector3.new(0, RAISE, 0)
            lookPoint = Vector3.new(tpos.X, pos.Y, tpos.Z)
            root.AssemblyLinearVelocity = Vector3.zero
            if t >= WINDUP_DUR then
                phase = "recoil"
                phaseT = now
            end
        elseif phase == "recoil" then
            local e = math.clamp(t / RECOIL_DUR, 0, 1)
            e = e * e * (3 - 2 * e)
            pos = tpos + outDir * (FRONT + RECOIL_BACK * e) + Vector3.new(0, RAISE, 0)
            lookPoint = Vector3.new(tpos.X, pos.Y, tpos.Z)
            root.AssemblyLinearVelocity = Vector3.zero
            if t >= RECOIL_DUR then
                lockPos = tpos
                lockOut = outDir
                phase = "fire"
                phaseT = now
            end
        elseif phase == "fire" then
            local s = math.clamp(t / FIRE_DUR, 0, 1)
            s = s * s * (3 - 2 * s)
            local offset = (FRONT + RECOIL_BACK) - s * (FRONT + RECOIL_BACK + OVERRUN)
            pos = lockPos + lockOut * offset + Vector3.new(0, RAISE, 0)
            lookPoint = pos - lockOut
            root.AssemblyLinearVelocity = -lockOut * velocityMagnitude
            if t >= FIRE_DUR then
                phase = "linger"
                phaseT = now
            end
        else
            pos = lockPos + lockOut * (-OVERRUN) + Vector3.new(0, RAISE, 0)
            lookPoint = pos - lockOut
            root.AssemblyLinearVelocity = Vector3.zero
            if t >= LINGER_DUR then
                cleanup()
                return
            end
        end
        if (lookPoint - pos).Magnitude < 0.1 then lookPoint = pos - outDir end
        root.CFrame = CFrame.lookAt(pos, lookPoint)
        root.AssemblyAngularVelocity = Vector3.zero
    end)
end

function Cmd.trampoline(sagDepth, velocityMagnitude)
    disconnectConnection("trampoline")
    if not player.Character then return end
    local localHum = player.Character:FindFirstChild("Humanoid")
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    if not (localHum and root) then return end
    states.trampoline = true
    sagDepth = math.clamp(tonumber(sagDepth) or 3, 0.5, 15)
    velocityMagnitude = math.abs(tonumber(velocityMagnitude) or 500)
    localHum:ChangeState(Enum.HumanoidStateType.Physics)
    localHum.PlatformStand = true
    local boardLen = math.max(4, player.Character:GetExtentsSize().Y)
    local look = root.CFrame.LookVector
    local yaw = math.atan2(-look.X, -look.Z)
    local basePos = root.Position
    local sag, sagVel = 0, 0
    local launchT = 0
    local overlapParams = OverlapParams.new()
    overlapParams.FilterType = Enum.RaycastFilterType.Exclude
    overlapParams.FilterDescendantsInstances = {player.Character}
    local function cleanup()
        disconnectConnection("trampoline")
        states.trampoline = false
        local h = player.Character and player.Character:FindFirstChild("Humanoid")
        if h then
            h.PlatformStand = false
            h:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
    end
    connections.trampoline = RunService.Heartbeat:Connect(function(dt)
        if not (states.trampoline and player.Character) then cleanup() return end
        root = player.Character:FindFirstChild("HumanoidRootPart")
        local hum = player.Character:FindFirstChild("Humanoid")
        if not (root and hum and hum.Health > 0) then cleanup() return end
        hum.PlatformStand = true
        dt = math.min(dt, 1/20)
        local mv = hum.MoveDirection
        if mv.Magnitude > 0.05 then
            local targetYaw = math.atan2(-mv.X, -mv.Z)
            local diff = math.atan2(math.sin(targetYaw - yaw), math.cos(targetYaw - yaw))
            yaw = yaw + math.clamp(diff, -3 * dt, 3 * dt)
        end
        local rotCF = CFrame.new(basePos - Vector3.new(0, sag, 0)) * CFrame.Angles(0, yaw, 0) * CFrame.Angles(math.rad(-90), 0, 0)
        local load = 0
        local boxCF = rotCF * CFrame.new(0, 0, 1.6)
        local parts = workspace:GetPartBoundsInBox(boxCF, Vector3.new(5, boardLen + 2, 3), overlapParams)
        local seen = {}
        for _, p in ipairs(parts) do
            if not p.Anchored then
                local m = p:FindFirstAncestorOfClass("Model")
                local key = m or p
                if not seen[key] then
                    seen[key] = true
                    load = load + 1
                end
            end
        end
        load = math.min(load, 3)
        local accel = load * 20 - 9 * sag - 2.5 * sagVel
        sagVel = sagVel + accel * dt
        sag = sag + sagVel * dt
        if sag < 0 then
            sag = 0
            if sagVel < 0 then sagVel = sagVel * 0.35 end
        end
        if sag >= sagDepth and launchT <= 0 then
            launchT = 0.18
            sagVel = -sagDepth * 10
        end
        rotCF = CFrame.new(basePos - Vector3.new(0, sag, 0)) * CFrame.Angles(0, yaw, 0) * CFrame.Angles(math.rad(-90), 0, 0)
        root.CFrame = rotCF
        root.AssemblyAngularVelocity = Vector3.zero
        if launchT > 0 then
            launchT = launchT - dt
            root.AssemblyLinearVelocity = Vector3.new(0, velocityMagnitude, 0)
        else
            root.AssemblyLinearVelocity = Vector3.zero
        end
    end)
end

