        if sethiddenproperty then
            sethiddenproperty(player, "MaximumSimulationRadius", math.huge)
            sethiddenproperty(player, "SimulationRadius", math.huge)
        end
    end)
    local function trueCF()
        local rep
        pcall(function()
            if gethiddenproperty then rep = gethiddenproperty(targetRoot, "PhysicsRepRootPart") end
        end)
        return typeof(rep) == "CFrame" and rep or targetRoot.CFrame
    end
    local track
    pcall(function()
        local anim = Instance.new("Animation")
        anim.AnimationId = "rbxassetid://72382226286301"
        local animator = localHum:FindFirstChildOfClass("Animator") or Instance.new("Animator", localHum)
        track = animator:LoadAnimation(anim)
        track.Priority = Enum.AnimationPriority.Action4
        track:Play(0.1, 1, 1)
        track.Looped = true
    end)
    local WINDUP = 0.55
    local OVERRUN = 10
    local LINGER = 0.5
    local offset = startDist
    local speed = 0
    local pushed = false
    local phase = "windup"
    local phaseT = os.clock()
    local approachDir
    do
        local tcf = trueCF()
        local look = Vector3.new(tcf.LookVector.X, 0, tcf.LookVector.Z)
        approachDir = look.Magnitude > 0.1 and look.Unit or Vector3.zAxis
    end
    local function cleanup()
        disconnectConnection("runover")
        if track then pcall(function() track:Stop(0.1) end) track = nil end
        local c = player.Character
        local r = c and c:FindFirstChild("HumanoidRootPart")
        local h = c and c:FindFirstChildOfClass("Humanoid")
        if r then
            pcall(function() sethiddenproperty(r, "PhysicsRepRootPart", r) end)
            r.AssemblyLinearVelocity = Vector3.zero
            r.AssemblyAngularVelocity = Vector3.zero
            r.CFrame = returnCF
        end
        if h then h.PlatformStand = false h:ChangeState(Enum.HumanoidStateType.GettingUp) end
        if setDeathGuard then task.delay(1, function() setDeathGuard(false) end) end
        states.runover = false
    end
    connections.runover = RunService.Heartbeat:Connect(function(dt)
        if not (states.runover and player.Character and targetPlayer and targetPlayer.Parent and targetPlayer.Character) then
            cleanup()
            return
        end
        root = player.Character:FindFirstChild("HumanoidRootPart")
        targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local hum = player.Character:FindFirstChild("Humanoid")
        if not (root and targetRoot and hum and targetHum.Health > 0) then
            cleanup()
            return
        end
        hum.PlatformStand = true
        pcall(function() sethiddenproperty(root, "PhysicsRepRootPart", targetRoot) end)
        if track and not track.IsPlaying then
            pcall(function() track:Play(0.1, 1, 1) end)
        end
        local tcf = trueCF()
        local tpos = tcf.Position
        if phase == "windup" then
            if os.clock() - phaseT >= WINDUP then
                phase = "charge"
                phaseT = os.clock()
            end
        elseif phase == "charge" then
            speed = math.min(topSpeed, speed + topSpeed * 1.4 * dt)
            offset = offset - speed * dt
            if not pushed and offset <= 0 then
                pushed = true
                local pw = pushPower or speed
                task.defer(function() pcall(function() Cmd.push(targetPlayer, pw) end) end)
            end
            if offset <= -OVERRUN then
                offset = -OVERRUN
                phase = "linger"
                phaseT = os.clock()
            end
            if os.clock() - phaseT > 15 then cleanup() return end
        elseif phase == "linger" then
            if os.clock() - phaseT >= LINGER then
                cleanup()
                return
            end
        end
        local pos = tpos + approachDir * offset
        local facePos
        if offset >= 0.5 then
            facePos = Vector3.new(tpos.X, pos.Y, tpos.Z)
        else
            facePos = pos - approachDir
        end
        root.CFrame = CFrame.lookAt(pos, facePos)
        root.AssemblyLinearVelocity = phase == "charge" and (-approachDir * speed) or Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
    end)
end

function Cmd.tempest(targetPlayer, tempo, range)
    disconnectConnection("tempest")
    if not (targetPlayer and targetPlayer.Character and player.Character) then return end
    local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local targetHum = targetPlayer.Character:FindFirstChild("Humanoid")
    local localHum = player.Character:FindFirstChild("Humanoid")
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    if not (targetRoot and targetHum and localHum and root) then return end
    states.tempest = true
    tempo = math.clamp(tonumber(tempo) or 1, 0.3, 3)
    local RANGE = math.clamp(tonumber(range) or 15, 6, 40)
    local returnCF = root.CFrame
    if setDeathGuard then setDeathGuard(true) end
    localHum:ChangeState(Enum.HumanoidStateType.Physics)
    localHum.PlatformStand = true
    local function trueCF()
        local rep
        pcall(function()
            if gethiddenproperty then rep = gethiddenproperty(targetRoot, "PhysicsRepRootPart") end
        end)
        return typeof(rep) == "CFrame" and rep or targetRoot.CFrame
    end
    local function springStep(x, v, goal, omega, dt)
        local d = x - goal
        local e = math.exp(-omega * dt)
        local nx = goal + (d * (1 + omega * dt) + v * dt) * e
        local nv = (v * (1 - omega * dt) - d * (omega * omega * dt)) * e
        return nx, nv
    end
    local GOLDEN = math.rad(137.5)
    local pos = root.Position
    local vel = Vector3.zero
    local phase = "rise"
    local phaseT = os.clock()
    local hopCount = 0
    local diveAng = math.random() * math.pi * 2
    local entryOff, exitOff
    local diveStage = "in"
    local pushed = false
    local function pickDive()
        diveAng = diveAng + GOLDEN + (math.random() - 0.5) * 0.5
        local flat = Vector3.new(math.cos(diveAng), 0, math.sin(diveAng))
        local h = 2.5 + math.random() * 2.5
        entryOff = flat * RANGE + Vector3.new(0, h, 0)
        exitOff = -flat * RANGE + Vector3.new(0, h * 0.7, 0)
        diveStage = "in"
        pushed = false
        hopCount = hopCount + 1
    end
    pickDive()
    local function cleanup()
        disconnectConnection("tempest")
        local c = player.Character
        local r = c and c:FindFirstChild("HumanoidRootPart")
        local h = c and c:FindFirstChildOfClass("Humanoid")
        if r then
            pcall(function() sethiddenproperty(r, "PhysicsRepRootPart", r) end)
            r.AssemblyLinearVelocity = Vector3.zero
            r.AssemblyAngularVelocity = Vector3.zero
            r.CFrame = returnCF
        end
        if h then h.PlatformStand = false h:ChangeState(Enum.HumanoidStateType.GettingUp) end
        if setDeathGuard then task.delay(1, function() setDeathGuard(false) end) end
        states.tempest = false
    end
    connections.tempest = RunService.Heartbeat:Connect(function(dt)
        dt = math.min(dt, 1/20)
        if not (states.tempest and player.Character and targetPlayer and targetPlayer.Parent and targetPlayer.Character) then
            cleanup()
            return
        end
        root = player.Character:FindFirstChild("HumanoidRootPart")
        targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local hum = player.Character:FindFirstChild("Humanoid")
        if not (root and targetRoot and hum and targetHum.Health > 0) then
            cleanup()
            return
        end
        hum.PlatformStand = true
        pcall(function()
            if sethiddenproperty then
                sethiddenproperty(player, "MaximumSimulationRadius", math.huge)
                sethiddenproperty(player, "SimulationRadius", math.huge)
            end
        end)
        pcall(function() sethiddenproperty(root, "PhysicsRepRootPart", targetRoot) end)
        local tcf = trueCF()
        local tpos = tcf.Position
        local now = os.clock()
        local goal, omega
        if phase == "rise" then
            goal = tpos + entryOff
            omega = 4.5
            if (pos - goal).Magnitude < 2.5 or now - phaseT > 2.5 then
                phase = "poise" phaseT = now
            end
        elseif phase == "poise" then
            goal = tpos + entryOff + Vector3.new(0, math.sin((now - phaseT) * 7) * 0.4, 0)
            omega = 9
            if now - phaseT >= 0.45 / tempo then
                phase = "dive" phaseT = now
            end
        elseif phase == "dive" then
            if diveStage == "in" then
                goal = tpos + Vector3.new(0, 0.3, 0)
                omega = 16 * tempo
                local toGoal = goal - pos
                local minSpeed = 55 * tempo
                if toGoal.Magnitude > 0.5 and vel.Magnitude < minSpeed then
                    vel = (vel + toGoal.Unit * (minSpeed - vel.Magnitude))
                end
                local distToT = (pos - tpos).Magnitude
                if distToT < 3.5 then
                    if not pushed then
                        pushed = true
                        local spikeDir = vel.Magnitude > 1 and vel.Unit or (tpos - pos).Unit
                        local keep = vel
                        root.AssemblyLinearVelocity = spikeDir * 10000 + Vector3.new(0, 8000, 0)
                        task.defer(function()
                            local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                            if r then r.AssemblyLinearVelocity = keep end
                        end)
                    end
                    diveStage = "out"
                    phaseT = now
                end
                if now - phaseT > 2.5 / tempo then
                    pickDive()
                    phase = "settle" phaseT = now
                end
            else
                goal = tpos + exitOff
                omega = 11 * tempo
                if (pos - goal).Magnitude < 3 or now - phaseT > 1.6 / tempo then
                    pickDive()
                    phase = "settle" phaseT = now
                end
            end
        elseif phase == "settle" then
            goal = tpos + entryOff
            omega = 8 * tempo
            if (pos - goal).Magnitude < 3 or now - phaseT > 1.3 / tempo then
                phase = "poise" phaseT = now
            end
        end
        pos, vel = springStep(pos, vel, goal, omega, dt)
        if vel.Magnitude > 500 then vel = vel.Unit * 500 end
        local repVel = vel
        if repVel.Magnitude < 4 then
            repVel = repVel + Vector3.new(0, math.sin(now * 6) * 4.5, 0)
        end
        local face
        if phase == "poise" or vel.Magnitude <= 3 then
            face = Vector3.new(tpos.X, pos.Y, tpos.Z)
        else
            face = pos + vel.Unit
        end
        if (face - pos).Magnitude < 0.1 then face = pos + tcf.LookVector end
        root.CFrame = CFrame.lookAt(pos, face)
        root.AssemblyLinearVelocity = repVel
        root.AssemblyAngularVelocity = Vector3.new(0, 0.4, 0)
    end)
end

