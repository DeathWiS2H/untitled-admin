local Grid = {cont=nil, popup=nil}
function Grid.clear()
    if Grid.cont then pcall(function() Grid.cont:Destroy() end) Grid.cont=nil end
end
function Grid.rebuild()
    Grid.clear()
    if not (state.grid.enabled and state.grid.show) then return end
    local cam = workspace.CurrentCamera
    if not cam then return end
    local vp = cam.ViewportSize
    local g = math.max(4, state.grid.size)
    local cont = create("Frame",{Name="GridOverlay",Size=UDim2.new(1,0,1,0),Position=UDim2.new(0,0,0,0),BackgroundTransparency=1,BorderSizePixel=0,ZIndex=0,Active=false,Parent=UI.buttonGui})
    local nx = math.min(220, math.floor(vp.X / g))
    local ny = math.min(220, math.floor(vp.Y / g))
    for i=1,nx do
        create("Frame",{Size=UDim2.new(0,1,1,0),Position=UDim2.new(0,i*g,0,0),BackgroundColor3=THEME.accent,BackgroundTransparency=0.86,BorderSizePixel=0,ZIndex=0,Parent=cont})
    end
    for i=1,ny do
        create("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,0,i*g),BackgroundColor3=THEME.accent,BackgroundTransparency=0.86,BorderSizePixel=0,ZIndex=0,Parent=cont})
    end
    Grid.cont = cont
end
function Grid.alignAll()
    if not state.grid.enabled then return end
    local g = math.max(4, state.grid.size)
    local cam = workspace.CurrentCamera
    local vp = cam and cam.ViewportSize or Vector2.new(1280,720)
    for id, data in pairs(buttons) do
        local b = UI.buttonGui:FindFirstChild("CmdButton_"..id)
        if b then
            local sx, sy = b.Position.X.Scale, b.Position.Y.Scale
            local baseX, baseY = sx*vp.X, sy*vp.Y
            local wc = math.max(math.ceil(50 / g), math.floor(b.AbsoluteSize.X / g + 0.5))
            local hc = math.max(math.ceil(38 / g), math.floor(b.AbsoluteSize.Y / g + 0.5))
            local w = math.min(300, wc * g)
            local h = math.min(300, hc * g)
            local absX = math.floor((baseX + b.Position.X.Offset) / g + 0.5) * g
            local absY = math.floor((baseY + b.Position.Y.Offset) / g + 0.5) * g
            absX = math.clamp(absX, 0, math.max(0, vp.X - w))
            absY = math.clamp(absY, 0, math.max(0, vp.Y - h))
            b.Size = UDim2.fromOffset(w, h)
            b.Position = UDim2.new(sx, absX - baseX, sy, absY - baseY)
            data.width = w data.height = h data.position = b.Position
        end
    end
end
