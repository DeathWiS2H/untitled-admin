    power = math.clamp(tonumber(power) or 1, 0.2, 3)
    localHum:ChangeState(Enum.HumanoidStateType.Physics)
    localHum.PlatformStand = true
    pcall(function()
        if sethiddenproperty then
            sethiddenproperty(player, "MaximumSimulationRadius", math.huge)
            sethiddenproperty(player, "SimulationRadius", math.huge)
        end
    end)
    local function trueCF()
        local rep
        pcall(function()
            if gethiddenproperty then rep = gethiddenproperty(targetRoot, "PhysicsRepRootPart") end
        end)
        return typeof(rep) == "CFrame" and rep or targetRoot.CFrame
    end
    local function bindRep()
        local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if r and targetRoot then pcall(function() sethiddenproperty(r, "PhysicsRepRootPart", targetRoot) end) end
    end
    local function unbindRep()
        local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if r then pcall(function() sethiddenproperty(r, "PhysicsRepRootPart", r) end) end
    end
    local function pivotPos(tpos)
        local head = targetPlayer.Character and targetPlayer.Character:FindFirstChild("Head")
        return (head and head.Position or (tpos + Vector3.new(0, 1.5, 0))) + Vector3.new(0, length, 0)
    end
    local g = 80 * power
    local w0sq = g / length
    local dir = math.random(0,1) == 0 and 1 or -1
    local omegaMin = 1.4 + 0.5 * power
    local E_target = 2 * w0sq + 0.5 * omegaMin * omegaMin
    local theta = 0
    local omega = 0
    local tcf0 = trueCF()
    local fwd0 = Vector3.new(tcf0.LookVector.X, 0, tcf0.LookVector.Z)
    local swingAxis = fwd0.Magnitude > 0.1 and fwd0.Unit or Vector3.zAxis
    local lastTargetPos = tcf0.Position
    local targetVel = Vector3.zero
    local pos = root.Position
    local lastPos = pos
    local breathe = math.random() * 10
    local function apply(dt, render)
        if not (states.pendulum and player.Character and targetPlayer and targetPlayer.Character) then return false end
        root = player.Character:FindFirstChild("HumanoidRootPart")
        targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local hum = player.Character:FindFirstChild("Humanoid")
        if not (root and targetRoot and hum and targetHum.Health > 0) then return false end
        hum.PlatformStand = true
        if not render then bindRep() end
        local tcf = trueCF()
        local tpos = tcf.Position
        if not render then
            local rawVel = (tpos - lastTargetPos) / math.max(dt, 0.001)
            targetVel = targetVel:Lerp(rawVel, 0.35)
            lastTargetPos = tpos
            breathe += dt * 1.8
            local fwd = Vector3.new(tcf.LookVector.X, 0, tcf.LookVector.Z)
            if fwd.Magnitude > 0.1 then
                swingAxis = swingAxis:Lerp(fwd.Unit, math.min(1, dt * 1.5))
                if swingAxis.Magnitude > 0.001 then swingAxis = swingAxis.Unit end
            end
            local pot = w0sq * (1 - math.cos(theta))
            local kTarget = math.max(E_target - pot, 0.5 * omegaMin * omegaMin)
            local omegaMag = math.sqrt(2 * kTarget)
            omega = omega + (dir * omegaMag - omega) * math.min(1, dt * 2.5)
            theta = theta + omega * dt
            if theta > math.pi * 6 then theta = theta - math.pi * 6 end
            if theta < -math.pi * 6 then theta = theta + math.pi * 6 end
        end
        local lead = targetVel * 0.3
        local pivot = pivotPos(tpos) + lead
        local arm = (-Vector3.yAxis * math.cos(theta) + swingAxis * math.sin(theta))
        arm = arm.Magnitude > 0.001 and arm.Unit or -Vector3.yAxis
        pos = pivot + arm * length
        local tang = (Vector3.yAxis * math.sin(theta) + swingAxis * math.cos(theta)) * (omega >= 0 and 1 or -1)
        if tang.Magnitude < 0.01 then tang = swingAxis end
        tang = tang.Unit
        local upv = (pivot - pos)
        upv = upv.Magnitude > 0.01 and upv.Unit or Vector3.yAxis
        local right = tang:Cross(upv)
        if right.Magnitude < 0.01 then right = Vector3.xAxis end
        right = right.Unit
        local back = right:Cross(upv).Unit
        root.CFrame = CFrame.fromMatrix(pos, right, upv, back) * CFrame.Angles(0, 0, math.sin(breathe) * 0.04)
        local frameVel = (pos - lastPos) / math.max(dt, 0.001)
        lastPos = pos
        root.AssemblyLinearVelocity = render and root.AssemblyLinearVelocity or (frameVel + targetVel * 0.5)
        root.AssemblyAngularVelocity = Vector3.zero
        return true
    end
    RunService:BindToRenderStep("UA_Pendulum", Enum.RenderPriority.Last.Value, function(dt)
        if not apply(dt, true) then
            pcall(function() RunService:UnbindFromRenderStep("UA_Pendulum") end)
        end
    end)
    connections.pendulum = RunService.Heartbeat:Connect(function(dt)
        if not apply(math.min(dt, 1/30), false) then
            pcall(function() RunService:UnbindFromRenderStep("UA_Pendulum") end)
            unbindRep()
            local h = player.Character and player.Character:FindFirstChild("Humanoid")
            if h then h.PlatformStand = false h:ChangeState(Enum.HumanoidStateType.GettingUp) end
            disconnectConnection("pendulum")
            states.pendulum = false
        end
    end)
end

function Cmd.echo(targetPlayer, delaySeconds, idleSpeed)
    disconnectConnection("echo")
    if not (targetPlayer and targetPlayer.Character and player.Character) then return end
    local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local targetHum = targetPlayer.Character:FindFirstChild("Humanoid")
    local humanoid = player.Character:FindFirstChild("Humanoid")
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    if not (targetRoot and targetHum and humanoid and root) then return end
    states.echo = true
    delaySeconds = math.clamp(tonumber(delaySeconds) or 3, 0.5, 15)
    idleSpeed = math.clamp(tonumber(idleSpeed) or 2, 0.5, 20)
    local orgGravity = workspace.Gravity
    workspace.Gravity = 0
    pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Physics) end)
    local buffer = {}
    local effectiveDelay = delaySeconds
    local lastTargetPos = targetRoot.Position
    local function pushSample(pos, look, t)
        buffer[#buffer + 1] = {t = t, pos = pos, look = look}
        local cutoff = t - delaySeconds - 2
        while buffer[1] and buffer[1].t < cutoff do table.remove(buffer, 1) end
    end
    local function sampleAt(t)
        if #buffer == 0 then return nil end
        if t <= buffer[1].t then return buffer[1].pos, buffer[1].look end
        if t >= buffer[#buffer].t then return buffer[#buffer].pos, buffer[#buffer].look end
        for i = 1, #buffer - 1 do
            local a, b = buffer[i], buffer[i + 1]
            if t >= a.t and t <= b.t then
                local span = b.t - a.t
                local alpha = span > 0.0001 and (t - a.t) / span or 0
                return a.pos:Lerp(b.pos, alpha), a.look:Lerp(b.look, alpha)
            end
        end
        return buffer[#buffer].pos, buffer[#buffer].look
    end
    local function cleanup()
        workspace.Gravity = orgGravity
        local h = player.Character and player.Character:FindFirstChild("Humanoid")
        if h then pcall(function() h:ChangeState(Enum.HumanoidStateType.GettingUp) end) end
        disconnectConnection("echo")
        states.echo = false
    end
    connections.echo = RunService.Heartbeat:Connect(function(dt)
        if not (states.echo and player.Character and targetPlayer and targetPlayer.Character) then
            cleanup()
            return
        end
        root = player.Character:FindFirstChild("HumanoidRootPart")
        targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not (root and targetRoot and targetHum.Health > 0) then
            cleanup()
            return
        end
        local now = os.clock()
        local curPos = targetRoot.Position
        local moveSpeed = (curPos - lastTargetPos).Magnitude / math.max(dt, 0.001)
        lastTargetPos = curPos
        pushSample(curPos, targetRoot.CFrame.LookVector, now)
        if moveSpeed < idleSpeed then
            effectiveDelay = math.max(0, effectiveDelay - dt * 1.2)
        else
            effectiveDelay = math.min(delaySeconds, effectiveDelay + dt * 0.6)
        end
        local goalPos, goalLook = sampleAt(now - effectiveDelay)
        if goalPos then
            local currentPos = root.Position
            local newPos = currentPos:Lerp(goalPos, math.min(1, dt * 6))
            local lookTarget = newPos + (goalLook.Magnitude > 0.01 and goalLook or Vector3.new(0,0,-1))
            root.CFrame = CFrame.new(newPos, lookTarget)
        end
    end)
end

