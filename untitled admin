local function weldMoveState(plr)
    local ch = plr and plr.Character
    local hum = ch and ch:FindFirstChildOfClass("Humanoid")
    local root = ch and ch:FindFirstChild("HumanoidRootPart")
    if not (hum and root) then return "idle" end
    if hum.Sit or hum.SeatPart then return "sit" end
    if hum.FloorMaterial == Enum.Material.Air then
        if root.AssemblyLinearVelocity.Y > 2 then return "jump" end
        return "fall"
    end
    local v = root.AssemblyLinearVelocity
    if Vector3.new(v.X, 0, v.Z).Magnitude > 1 then return "walk" end
    return "idle"
end

local function weldCondMatch(cond, ms)
    if cond == nil or cond == "any" then return true end
    if cond == "air" then return ms == "jump" or ms == "fall" end
    return cond == ms
end

function Cmd.weldCycle(targetPlayer, steps, opts)
    disconnectConnection("weldcycle")
    if not (targetPlayer and targetPlayer.Character and player.Character) then return end
    if type(steps) ~= "table" or #steps == 0 then return end
    local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local localHum = player.Character:FindFirstChild("Humanoid")
    if not (targetRoot and localHum) then return end
    states.weldcycle = true
    opts = opts or {}
    local mode = (opts.mode == "tracker" or opts.mode == "both") and opts.mode or "cycle"
    local idx, stepAt = 1, 0
    local animPlaying = nil
    local function setAnim(id)
        if id == animPlaying then return end
        if animPlaying then pcall(function() CL.stopAnimId(animPlaying) end) end
        animPlaying = nil
        if id then
            animPlaying = id
            pcall(function() CL.playAnimId(id, 1, 0) end)
        end
    end
    local function activate(i, now)
        idx = i
        stepAt = now
        setAnim(steps[i].animId)
    end
    local msNow = weldMoveState(targetPlayer)
    local first = nil
    if mode == "tracker" then
        for i, s in ipairs(steps) do
            if s.cond and s.cond ~= "any" and weldCondMatch(s.cond, msNow) then first = i break end
        end
        if not first then
            for i, s in ipairs(steps) do
                if not s.cond or s.cond == "any" then first = i break end
            end
        end
    elseif mode == "both" then
        for i, s in ipairs(steps) do
            if weldCondMatch(s.cond, msNow) then first = i break end
        end
    end
    localHum:ChangeState(Enum.HumanoidStateType.Physics)
    localHum.PlatformStand = true
    activate(first or 1, os.clock())
    local function unbindRep()
        local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if r then pcall(function() sethiddenproperty(r, "PhysicsRepRootPart", r) end) end
    end
    connections.weldcycle = RunService.Heartbeat:Connect(function()
        if not (states.weldcycle and player.Character and targetPlayer.Character and targetRoot) then
            setAnim(nil)
            unbindRep()
            removeVelocity()
            local h = player.Character and player.Character:FindFirstChild("Humanoid")
            if h then h.PlatformStand = false h:ChangeState(Enum.HumanoidStateType.GettingUp) end
            disconnectConnection("weldcycle")
            states.weldcycle = false
            return
        end
        local now = os.clock()
        local ms = weldMoveState(targetPlayer)
        if mode == "tracker" then
            local pick = nil
            for i, s in ipairs(steps) do
                if s.cond and s.cond ~= "any" and weldCondMatch(s.cond, ms) then pick = i break end
            end
            if not pick then
                for i, s in ipairs(steps) do
                    if not s.cond or s.cond == "any" then pick = i break end
                end
            end
            if pick and pick ~= idx then activate(pick, now) end
        else
            local hold = math.max(tonumber(steps[idx].hold) or 0, 0)
            if now - stepAt >= hold then
                if mode == "cycle" then
                    activate((idx % #steps) + 1, now)
                else
                    local nxt = nil
                    for o = 1, #steps do
                        local i = ((idx - 1 + o) % #steps) + 1
                        if weldCondMatch(steps[i].cond, ms) then nxt = i break end
                    end
                    if nxt then
                        if nxt == idx then stepAt = now else activate(nxt, now) end
                    else
                        stepAt = now - hold + 0.1
                    end
                end
            end
        end
        local s = steps[idx]
        targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local localRoot = player.Character:FindFirstChild("HumanoidRootPart")
        if localRoot and targetRoot then
            pcall(function() sethiddenproperty(localRoot, "PhysicsRepRootPart", targetRoot) end)
            local flatLook = Vector3.new(targetRoot.CFrame.LookVector.X, 0, targetRoot.CFrame.LookVector.Z)
            flatLook = flatLook.Magnitude > 0.01 and flatLook.Unit or Vector3.zAxis
            local flatRight = Vector3.new(targetRoot.CFrame.RightVector.X, 0, targetRoot.CFrame.RightVector.Z)
            flatRight = flatRight.Magnitude > 0.01 and flatRight.Unit or Vector3.xAxis
            local desiredPos = targetRoot.Position + flatLook * s.fwd + flatRight * s.side + Vector3.new(0, s.up, 0)
            localRoot.CFrame = CFrame.lookAt(desiredPos, desiredPos + flatLook) * CFrame.Angles(math.rad(s.rotX), math.rad(s.rotY), math.rad(s.rotZ or 0))
            localRoot.AssemblyAngularVelocity = Vector3.zero
            if math.abs(s.vel) > 0.01 then
                localRoot.AssemblyLinearVelocity = Vector3.new(s.vel, s.vel, s.vel)
            else
                removeVelocity()
            end
        end
    end)
end

function Cmd.quake(targetPlayer, radius, teleportDelay)
