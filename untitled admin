            disconnectConnection("haunt")
            return
        end
        if not (player.Character and targetPlayer and targetPlayer.Character) then
            states.haunt = false
            workspace.Gravity = orgGravity
            if humanoid then pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end) end
            disconnectConnection("haunt")
            return
        end
        root = player.Character:FindFirstChild("HumanoidRootPart")
        head = player.Character:FindFirstChild("Head")
        targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not (root and head and targetRoot) then
            states.haunt = false
            workspace.Gravity = orgGravity
            if humanoid then pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end) end
            disconnectConnection("haunt")
            return
        end
        pcall(function()
            local currentPos = root.Position
            local distToTarget = (targetRoot.Position - currentPos).Magnitude
            local newPos
            if distToTarget <= 10 then
                if distToTarget <= 2 then
                    newPos = currentPos
                    posVel, springVelY = Vector3.zero, 0
                else
                    local disp = targetRoot.Position - currentPos
                    local smoothFactor = math.min(1, (distToTarget - 2) / 8)
                    local yDisp = targetRoot.Position.Y - currentPos.Y
                    local yAccel = (yDisp * stiffY * smoothFactor) - (springVelY * dampY)
                    springVelY = springVelY + yAccel * dt
                    local accel = disp * stiffX * smoothFactor - posVel * dampX
                    posVel = posVel + accel * dt
                    newPos = Vector3.new(currentPos.X + posVel.X * dt, currentPos.Y + springVelY * dt, currentPos.Z + posVel.Z * dt)
                end
            else
                local disp = targetRoot.Position - currentPos
                local yDisp = targetRoot.Position.Y - currentPos.Y
                local yAccel = (yDisp * stiffY) - (springVelY * dampY)
                springVelY = springVelY + yAccel * dt
                local accel = disp * stiffX - posVel * dampX
                posVel = posVel + accel * dt
                newPos = Vector3.new(currentPos.X + posVel.X * dt, currentPos.Y + springVelY * dt, currentPos.Z + posVel.Z * dt)
            end
            root.CFrame = CFrame.new(newPos, targetRoot.Position)
            head.CFrame = CFrame.Lerp(head.CFrame, targetRoot.CFrame, 0.1)
        end)
    end)
end

