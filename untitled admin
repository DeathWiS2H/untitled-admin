do
    local function supportsPhysicsRep(root)
        if typeof(sethiddenproperty) ~= "function" or typeof(gethiddenproperty) ~= "function" then return false end
        if not root then return false end
        local setOk = pcall(function() sethiddenproperty(root, "PhysicsRepRootPart", root) end)
        if not setOk then return false end
        local getOk, v = pcall(function() return gethiddenproperty(root, "PhysicsRepRootPart") end)
        if not getOk then return false end
        return v == root
    end
    task.spawn(function()
        local c = player.Character or player.CharacterAdded:Wait()
        local root = c:WaitForChild("HumanoidRootPart", 10)
        if not (showWarning and root) then return end
        if not supportsPhysicsRep(root) then
            showWarning("Executor lacks Weld Support - some commands may not work well", 60)
            showWarning("Executor lacks Weld Support - weld tab will not work", 60)
        end
    end)
end

