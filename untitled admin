        if not (root and targetRoot and hum and targetHum.Health > 0) then return false end
        hum.PlatformStand = true
        local tcf = trueCF()
        local tpos = tcf.Position
        if not render then
            local rawVel = (tpos - lastTargetPos) / math.max(dt, 0.001)
            targetVel = targetVel:Lerp(rawVel, 0.35)
            lastTargetPos = tpos
            breathe1 += dt * 1.7 breathe2 += dt * 2.3 breathe3 += dt * 0.9
            phaseT += dt
            local toMe = pos - tpos
            local flatToMe = Vector3.new(toMe.X, 0, toMe.Z)
            local seen = false
            if flatToMe.Magnitude > 0.5 then
                seen = tcf.LookVector:Dot(flatToMe.Unit) > math.cos(math.rad(20))
            end
            if seen then seenT += dt unseenT = 0 else unseenT += dt seenT = 0 end
            boldness = math.clamp(boldness + (seen and -dt * 0.25 or dt * 0.08), 0, 1)
            local tSpeed = Vector3.new(targetVel.X, 0, targetVel.Z).Magnitude
            if phase == "stalk" then
                if seenT > 0.35 and boldness < 0.6 then setPhase("recoil")
                elseif boldness > 0.85 and unseenT > 1.5 then setPhase("loom")
                elseif tSpeed > 14 and phaseT > 2 then setPhase("chase") end
            elseif phase == "recoil" then
                if phaseT > 2.5 and unseenT > 1 then setPhase("stalk") end
            elseif phase == "loom" then
                if seenT > 0.5 then setPhase("recoil") boldness = 0.2
                elseif phaseT > 7 then setPhase("confront") end
            elseif phase == "confront" then
                if phaseT > 3.5 then setPhase("stalk") boldness = 0.4 end
            elseif phase == "chase" then
                if tSpeed < 6 and phaseT > 1.5 then setPhase("stalk") end
            end
            blend = math.min(1, blend + dt / 1.1)
            local ease = blend * blend * (3 - 2 * blend)
            local breath = Vector3.new(math.sin(breathe1), math.sin(breathe2) * 0.7 + math.sin(breathe3) * 0.5, math.cos(breathe1 * 0.8)) * (0.4 * intensity)
            local goal
            local stiffMul = 1
            if phase == "stalk" then
                orbitAng += dt * (0.55 * intensity) * (1 + math.sin(breathe3) * 0.25)
                local r = 9 - boldness * 4 + math.sin(breathe1 * 0.5) * 1.2
                goal = tpos + Vector3.new(math.cos(orbitAng) * r, 2 + math.sin(orbitAng * 2), math.sin(orbitAng) * r)
            elseif phase == "recoil" then
                local away = flatToMe.Magnitude > 0.5 and flatToMe.Unit or -tcf.LookVector
                goal = tpos + away * 16 + Vector3.new(0, 7 + math.sin(breathe2) * 1.5, 0)
                stiffMul = 1.6
            elseif phase == "loom" then
                goal = tpos - tcf.LookVector * 4 + Vector3.new(0, 5.5, 0)
                stiffMul = 0.7
            elseif phase == "confront" then
                weavePhase += dt * 2.4
                local side = math.sin(weavePhase) * 2.5
                goal = tpos + tcf.LookVector * 4.5 + tcf.RightVector * side + Vector3.new(0, 0.5 - math.cos(weavePhase * 2) * 0.3, 0)
                stiffMul = 2.4
            else
                local lead = targetVel * 0.45
                goal = tpos + lead - (tSpeed > 1 and Vector3.new(targetVel.X, 0, targetVel.Z).Unit or tcf.LookVector) * 3 + Vector3.new(0, 1.5, 0)
                stiffMul = 1.8
            end
            goal = goal + targetVel * 0.18 + breath * (0.5 + ease * 0.5)
            goal = goalPrev:Lerp(goal, ease)
            goalCur = goal
            local k = stiffness * stiffMul
            local c = 2 * math.sqrt(k)
            local accel = (goal - pos) * k - vel * c
            vel = vel + accel * dt
            pos = pos + vel * dt
        end
        local tilt = math.clamp(vel.Magnitude / 75, 0, 0.45)
        local leanDir = vel.Magnitude > 0.5 and vel.Unit or Vector3.zero
        local sideLean = -leanDir:Dot(tcf.RightVector) * tilt * 0.7
        local pitch = -leanDir.Y * tilt + math.sin(breathe2) * 0.05
        local head = targetPlayer.Character:FindFirstChild("Head")
        local watchPos = head and head.Position or tpos
        if phase == "recoil" then
            watchPos = watchPos:Lerp(pos + (pos - tpos), 0.35)
        end
        root.CFrame = CFrame.new(pos, watchPos) * CFrame.Angles(pitch, 0, sideLean + math.sin(breathe1) * 0.05)
        root.AssemblyLinearVelocity = vel + targetVel * 0.5
        root.AssemblyAngularVelocity = Vector3.zero
        return true
    end
    RunService:BindToRenderStep("UA_Specter", Enum.RenderPriority.Last.Value, function(dt)
        if not apply(dt, true) then
            pcall(function() RunService:UnbindFromRenderStep("UA_Specter") end)
        end
    end)
    connections.specter = RunService.Heartbeat:Connect(function(dt)
        if not apply(math.min(dt, 1/30), false) then
            pcall(function() RunService:UnbindFromRenderStep("UA_Specter") end)
            local h = player.Character and player.Character:FindFirstChild("Humanoid")
            if h then h.PlatformStand = false h:ChangeState(Enum.HumanoidStateType.GettingUp) end
