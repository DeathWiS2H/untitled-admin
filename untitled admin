        local onlineAdmins, nonAdmins = {}, {}
        for _, plr in ipairs(allPlayers) do
            if table.find(Admins, plr.Name) then table.insert(onlineAdmins, plr.Name)
            else table.insert(nonAdmins, plr.Name) end
        end
        local totalPlayers, totalAdmins, totalNonAdmins = #allPlayers, #onlineAdmins, #nonAdmins
        if totalAdmins == totalPlayers then chatMessage("Everyone is an admin.") return end
        if totalNonAdmins == totalPlayers then chatMessage("No admins currently added.") return end
        if totalNonAdmins == 1 then chatMessage("Everyone except " .. nonAdmins[1] .. " is an admin.") return end
        if totalAdmins == 1 then chatMessage("Only " .. onlineAdmins[1] .. " is an admin.") return end
        if totalAdmins > totalNonAdmins then
            chatMessage("More admins than non-admins. Here are the non-admins:")
            for _, name in ipairs(nonAdmins) do chatMessage(name) end
            return
        end
        if totalNonAdmins > totalAdmins then
            chatMessage("More non-admins than admins. Here are the admins:")
            for _, name in ipairs(onlineAdmins) do chatMessage(name) end
