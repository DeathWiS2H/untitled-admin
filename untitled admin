local function getCmdList()
    local seen, list = {}, {}
    for _, n in ipairs(commandOrder) do
        if CommandRegistry.commands[n] and not hiddenCommands[n] then table.insert(list, n) seen[n] = true end
    end
    local extras = {}
    for n in pairs(CommandRegistry.commands) do
        if not seen[n] and not hiddenCommands[n] then table.insert(extras, n) end
    end
    table.sort(extras)
    for _, n in ipairs(extras) do table.insert(list, n) end
    return list
end

local function levenshtein(a, b)
    local la, lb = #a, #b
    if la == 0 then return lb end
    if lb == 0 then return la end
    local prev = {}
    for j = 0, lb do prev[j] = j end
    for i = 1, la do
        local cur = {[0] = i}
        local ca = a:sub(i, i)
        for j = 1, lb do
            local cost = (ca == b:sub(j, j)) and 0 or 1
            cur[j] = math.min(prev[j] + 1, cur[j - 1] + 1, prev[j - 1] + cost)
        end
        prev = cur
    end
    return prev[lb]
end

local function closestCommand(name)
    local best, bestD = nil, math.huge
    for _, n in ipairs(getCmdList()) do
        local d = levenshtein(name, n)
        if d < bestD then bestD = d best = n end
    end
    if best and bestD <= 3 then return best end
    return nil
end

local function chatHandler(playerpower)
    if playerChatConnections[playerpower.UserId] then
        pcall(function() playerChatConnections[playerpower.UserId]:Disconnect() end)
    end
    local connection = playerpower.Chatted:Connect(function(message)
        if message:sub(1, #prefix) == prefix then
            local commandText = message:sub(#prefix + 1)
            local parts = {}
            for part in commandText:gmatch("%S+") do table.insert(parts, part) end
            local commandName = table.remove(parts, 1)
            if not commandName then return end
            commandName = commandName:lower()
            if state.altControlActive and playerpower.UserId == game.Players.LocalPlayer.UserId then return end
            local isAuth = playerpower.Name == owner or table.find(Admins, playerpower.Name)
            if isAuth then
                local command = CommandRegistry:getCommand(commandName, playerpower)
                if command then
                    local needsPlayer = command.usage:find("%(player%)") and not noPlayerNeeded[commandName]
                    if needsPlayer and not parts[1] and not (lastTarget and lastTarget.Parent) then
                        chatMessage("missing player " .. prefix .. commandName .. " | use a name or me, again, near, far")
                    else
                        pcall(function() command.func(playerpower, parts) end)
                    end
                else
                    local suggestion = closestCommand(commandName)
                    chatMessage("Unknown command: " .. commandName .. (suggestion and (" | Did you mean " .. prefix .. suggestion .. "?") or "") .. " | " .. prefix .. "undo | " .. prefix .. "cmds | " .. prefix .. "usage (command)")
                end
            end
        end
    end)
    playerChatConnections[playerpower.UserId] = connection
    table.insert(chatConnections, connection)
    table.insert(getgenv().UntitledAdminConnections, connection)
    return connection
end

