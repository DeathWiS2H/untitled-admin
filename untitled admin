        local matchFilter = state.histFilter=="all" or (state.histFilter=="ok" and entry.success) or (state.histFilter=="fail" and not entry.success)
        local matchSearch = q=="" or entry.command:lower():find(q,1,true)
        if matchFilter and matchSearch then
