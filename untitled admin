function updateCommands()
    for _,c in ipairs(UI.cmdScroll:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
    local q = state.commandsSearchQuery:lower()
    local filter = state.cmdFilter or "all"
    local sortMode = state.cmdSort or "az"

    local prebuiltWelds, otherWelds, anims, plainCmds = {}, {}, {}, {}

    if (filter == "all" or filter == "welds") and not state.weldHidePrebuilt and PREBUILT_WELDS then
        for i, w in ipairs(PREBUILT_WELDS) do
            local nm = w.name:lower()
            if not (state.weldPrebuiltDeleted and state.weldPrebuiltDeleted[nm]) then
                if q == "" or nm:find(q, 1, true) then
                    prebuiltWelds[#prebuiltWelds+1] = {name=w.name, order=i}
                end
            end
        end
    end
    if (filter == "all" or filter == "welds") and welds then
        for id, w in pairs(welds) do
            local nm = w.name:lower()
            if q == "" or nm:find(q, 1, true) then
                otherWelds[#otherWelds+1] = {name=w.name, id=tostring(id)}
            end
        end
    end
    if (filter == "all" or filter == "welds") and state.weldCyclesSaved then
        for id, w in pairs(state.weldCyclesSaved) do
            local nm = (w.name or ""):lower()
            if q == "" or nm:find(q, 1, true) then
                otherWelds[#otherWelds+1] = {name=w.name, id="cy_"..tostring(id), cycle=true}
            end
        end
    end
    if filter == "all" or filter == "animations" then
        if PREBUILT_ANIMS and not state.animHidePrebuilt then
            for _, d in ipairs(PREBUILT_ANIMS) do
                local nm = (d.name or ""):lower()
                if not (state.animPrebuiltDeleted and state.animPrebuiltDeleted[nm]) then
                    if q == "" or nm:find(q, 1, true) then
                        anims[#anims+1] = {data=d, id=""}
                    end
                end
            end
        end
        if animations then
            for id, d in pairs(animations) do
                local nm = (d.name or ""):lower()
                if q == "" or nm:find(q, 1, true) then
                    anims[#anims+1] = {data=d, id=tostring(id)}
                end
            end
        end
    end
    if filter == "all" or filter == "commands" then
        for _, n in ipairs(getCmdList()) do
            if CommandRegistry and CommandRegistry.commands[n] and not cmdIsWeldName(n) and not cmdIsCycleName(n) and not CommandRegistry.disabledCommands[n] then
                if q == "" or n:lower():find(q, 1, true) then
                    plainCmds[#plainCmds+1] = n
                end
            end
        end
    end

    local function byName(a,b) return a.name:lower() < b.name:lower() end
    local function byNameDesc(a,b) return a.name:lower() > b.name:lower() end
    if sortMode == "az" then
        table.sort(prebuiltWelds, byName)
        table.sort(otherWelds, byName)
        table.sort(anims, function(a,b) return (a.data.name or ""):lower() < (b.data.name or ""):lower() end)
        table.sort(plainCmds, function(a,b) return a:lower() < b:lower() end)
    elseif sortMode == "za" then
        table.sort(prebuiltWelds, byNameDesc)
        table.sort(otherWelds, byNameDesc)
        table.sort(anims, function(a,b) return (a.data.name or ""):lower() > (b.data.name or ""):lower() end)
        table.sort(plainCmds, function(a,b) return a:lower() > b:lower() end)
    else
        table.sort(prebuiltWelds, function(a,b) return (a.order or 0) > (b.order or 0) end)
        table.sort(otherWelds, function(a,b) return a.id > b.id end)
        table.sort(anims, function(a,b) return tostring(a.id) > tostring(b.id) end)
    end

    local order = 0
    local function nextOrder() order = order + 1 return order end

    for _, e in ipairs(prebuiltWelds) do
        local nm = e.name
        makeCmdRow("weld", nm, ";"..nm.." (player)", "Weld position", THEME.text, nextOrder(),
            function() return nm.." " end,
            function(btn)
                btn.MouseButton1Click:Connect(function()
                    local txt = cmdTapTarget()
                    if txt then processCmd(player, nm.." "..txt) end
                end)
            end)
    end
    for _, e in ipairs(otherWelds) do
        local nm = e.name
        makeCmdRow("weld", nm, ";"..nm.." (player)", e.cycle and "Saved weld cycle" or "Saved weld position", THEME.text, nextOrder(),
            function() return nm.." " end,
            function(btn)
                btn.MouseButton1Click:Connect(function()
                    local txt = cmdTapTarget()
                    if txt then processCmd(player, nm.." "..txt) end
                end)
            end)
    end
    for _, e in ipairs(anims) do
        local d = e.data
        local aid = tostring(d.animId)
        local isPrebuiltAnim = e.id == ""
        local animLabel = d.name or "Anim"
        local animColor = THEME.text
        makeCmdRow("anim", animLabel, "playanim "..aid, "Toggle animation on you", animColor, nextOrder(),
            function() return "playanim "..aid.." "..tostring(d.speed or 1).." "..tostring(d.setTime or 0) end,
            function(btn)
                local function refresh()
                    btn.Text = d.playing and "ON" or "Tap"
                    local col = d.playing and THEME.accent or THEME.inputLight
                    btn.BackgroundColor3 = col
                    btn:SetAttribute("BaseColor", col)
                end
                refresh()
                btn.MouseButton1Click:Connect(function()
                    d.playing = not d.playing
                    if d.playing then CL.playAnimId(d.animId, d.speed or 1, d.setTime or 0) else CL.stopAnimId(d.animId) end
                    refresh()
                    if UI.animFrame and UI.animFrame.Visible then updateAnimations() end
                end)
            end)
    end
    for _, n in ipairs(plainCmds) do
        local cmd = CommandRegistry.commands[n]
        local u, d = cmd.usage or n, cmd.description or "No description"
        local needsPlayer = u:find("%(player%)") and not noPlayerNeeded[n]
        makeCmdRow("cmd", n, u, d, THEME.text, nextOrder(),
            function() return n.." " end,
            function(btn)
                if needsPlayer then
                    btn.Text = "Tap"
                    btn.MouseButton1Click:Connect(function()
                        local txt = cmdTapTarget()
                        if txt then processCmd(player, n.." "..txt) end
                    end)
                else
                    btn.Text = "Run"
                    btn.MouseButton1Click:Connect(function() processCmd(player, n) end)
                end
            end)
    end
end

function processCmd(plr,msg)
    if not msg or msg=="" then return end
    local parts = {} for w in msg:gmatch("%S+") do table.insert(parts,w) end
    local cmdName = table.remove(parts,1)
    if not cmdName then return end
    cmdName = cmdName:lower()
    if CommandRegistry and CommandRegistry.getCommand then
        local cmd = CommandRegistry:getCommand(cmdName,plr)
        if not cmd then
            local suggestion = closestCommand(cmdName)
            displayLog(plr.Name,cmdName.." "..table.concat(parts," "),false,suggestion and ("Unknown - did you mean "..suggestion.."?") or "Unknown command")
            return
        end
        local needsPlayer = cmd.usage:find("%(player%)") and not noPlayerNeeded[cmdName]
        if needsPlayer and not parts[1] and not (lastTarget and lastTarget.Parent) then
            displayLog(plr.Name,cmdName,false,"Missing player - use a name or me, again, near, far, again")
            return
        end
        local success = pcall(function() cmd.func(plr,parts) end)
        displayLog(plr.Name,cmdName.." "..table.concat(parts," "),success,success and nil or "Execution error")
    end
end

