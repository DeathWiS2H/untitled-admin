function updateAnimations()
    for _, child in ipairs(UI.animScroll:GetChildren()) do
        if child:IsA("Frame") and child ~= UI.animCard and child ~= UI.animCtrl then child:Destroy() end
    end
    local order = 3
    local isNarrow = UI.content.AbsoluteSize.X < 300
    local q = (state.animSearch or ""):lower()
    if PREBUILT_ANIMS and not state.animHidePrebuilt then
        for _, data in ipairs(PREBUILT_ANIMS) do
            if not state.animPrebuiltDeleted[(data.name or ""):lower()] then
                if q == "" or (data.name or ""):lower():find(q, 1, true) then
                    makeAnimCard(nil, data, true, order, isNarrow)
                    order = order + 1
                end
            end
        end
    end
    local list = {}
    for id, data in pairs(animations) do
        if q == "" or (data.name or ""):lower():find(q, 1, true) then
            list[#list+1] = {id=id, data=data}
        end
    end
    local mode = state.animSort or "az"
    if mode == "za" then
        table.sort(list, function(a,b) return (a.data.name or ""):lower() > (b.data.name or ""):lower() end)
    elseif mode == "recent" then
        table.sort(list, function(a,b) return tostring(a.id) > tostring(b.id) end)
    else
        table.sort(list, function(a,b) return (a.data.name or ""):lower() < (b.data.name or ""):lower() end)
    end
    for _, e in ipairs(list) do
        makeAnimCard(e.id, e.data, false, order, isNarrow)
        order = order + 1
    end
end

