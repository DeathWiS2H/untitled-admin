function updatePlayers()
    for _,c in ipairs(UI.plyScroll:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
    if not Admins then return end
    local all,filtered,q = game.Players:GetPlayers(),{},state.searchQuery:lower()
    for _,p in ipairs(all) do
        local isAdmin = table.find(Admins,p.Name)~=nil
        if state.playerFilterMode=="all" or (state.playerFilterMode=="admin" and isAdmin) or (state.playerFilterMode=="nonadmin" and not isAdmin) then
            local sName = state.playerSortMode=="display" and p.DisplayName or p.Name
            if q=="" or sName:lower():find(q) then table.insert(filtered,p) end
        end
    end
    table.sort(filtered,function(a,b)
        local nA,nB = state.playerSortMode=="display" and a.DisplayName or a.Name, state.playerSortMode=="display" and b.DisplayName or b.Name
        return nA:lower()<nB:lower()
    end)
    for _,p in ipairs(filtered) do
        local isAdmin = table.find(Admins,p.Name)~=nil
        local dName,aName = state.playerSortMode=="display" and p.DisplayName or p.Name, state.playerSortMode=="display" and p.Name or p.DisplayName
