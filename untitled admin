function Cmd.mine(radius, armDelay)
    disconnectConnection("mine")
    disconnectConnection("explode")
    states.explode = false
    if not player.Character then return end
    local localHum = player.Character:FindFirstChild("Humanoid")
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    if not (localHum and root) then return end
    states.mine = true
    radius = math.max(0.5, tonumber(radius) or 1)
    armDelay = math.max(0, tonumber(armDelay) or 1)
    localHum:ChangeState(Enum.HumanoidStateType.Physics)
    localHum.PlatformStand = true
    local plantCF = root.CFrame
    local plantT = os.clock()
    local mineTrack
    pcall(function()
        local anim = Instance.new("Animation")
        anim.AnimationId = "rbxassetid://108148206637150"
        local animator = localHum:FindFirstChildOfClass("Animator") or Instance.new("Animator", localHum)
        mineTrack = animator:LoadAnimation(anim)
        mineTrack.Priority = Enum.AnimationPriority.Action4
        mineTrack:Play(0, 1, 1)
        task.defer(function()
            if mineTrack then
                mineTrack.TimePosition = 0
                mineTrack:AdjustSpeed(0)
            end
        end)
    end)
    local function unbindRep()
        local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if r then pcall(function() sethiddenproperty(r, "PhysicsRepRootPart", r) end) end
    end
    local function stopMine()
        if mineTrack then pcall(function() mineTrack:Stop(0) end) mineTrack = nil end
        disconnectConnection("mine")
        states.mine = false
    end
    local detonated = false
    local function detonate(targetPlayer)
        if detonated then return end
        detonated = true
        stopMine()
        local c = player.Character
        local r = c and c:FindFirstChild("HumanoidRootPart")
        local h = c and c:FindFirstChildOfClass("Humanoid")
        local tr = targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        if r then
            for _, v in pairs(r:GetChildren()) do
                if v:IsA("BodyVelocity") or v:IsA("BodyAngularVelocity") or v:IsA("BodyGyro") then v:Destroy() end
            end
            pcall(function() r.Anchored = false end)
            r.AssemblyLinearVelocity = Vector3.zero
        end
        if h then h.PlatformStand = true end
        if r and tr then
            local weldCF = CFrame.new(0, 0, -0.1)
            local function stick()
                local rr = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                local trr = targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart")
                if rr and trr then
                    pcall(function() sethiddenproperty(rr, "PhysicsRepRootPart", trr) end)
                    rr.CFrame = trr.CFrame * weldCF
                    rr.AssemblyLinearVelocity = Vector3.zero
                end
            end
            stick()
            local weldConn
            weldConn = RunService.Heartbeat:Connect(stick)
            task.delay(0.12, function()
                if weldConn then weldConn:Disconnect() weldConn = nil end
                unbindRep()
                local hh = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
                if hh then hh.PlatformStand = false end
                task.defer(function() pcall(function() Cmd.explode(targetPlayer, 120) end) end)
            end)
        else
            unbindRep()
            if h then h.PlatformStand = false end
            task.defer(function() pcall(function() Cmd.explode(targetPlayer, 120) end) end)
        end
    end
    connections.mine = RunService.Heartbeat:Connect(function()
        if not (states.mine and player.Character) then
            local h = player.Character and player.Character:FindFirstChild("Humanoid")
            if h then h.PlatformStand = false h:ChangeState(Enum.HumanoidStateType.GettingUp) end
            stopMine()
            return
        end
        root = player.Character:FindFirstChild("HumanoidRootPart")
        local hum = player.Character:FindFirstChild("Humanoid")
        if not (root and hum) then
            stopMine()
            return
        end
        hum.PlatformStand = true
        if mineTrack and not mineTrack.IsPlaying then
            pcall(function()
                mineTrack:Play(0, 1, 1)
                mineTrack.TimePosition = 0
                mineTrack:AdjustSpeed(0)
            end)
        end
        root.CFrame = plantCF
        root.AssemblyLinearVelocity = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
        if os.clock() - plantT < armDelay then return end
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= player and plr.Character then
                local pr = plr.Character:FindFirstChild("HumanoidRootPart")
                local ph = plr.Character:FindFirstChild("Humanoid")
                if pr and ph and ph.Health > 0 then
                    local rel = pr.Position - plantCF.Position
                    local relFlat = Vector3.new(rel.X, 0, rel.Z)
                    local triggered = rel.Magnitude <= (radius + 2)
                        or (relFlat.Magnitude <= 2 and rel.Y > 0 and rel.Y <= 7)
                    if triggered then
                        detonate(plr)
                        return
                    end
                end
            end
        end
    end)
end

function Cmd.runover(targetPlayer, startDist, topSpeed, pushPower)
