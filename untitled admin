function CL.fullCleanup()
    pcall(function() CL.setFlyState(false) end)
    pcall(function() CL.setNoclipState(false) end)
    pcall(function() CL.setInvisState(false) end)
    pcall(function() CL.setViewState(false) end)
    pcall(function() CL.setWalkFlingState(false) end)
    pcall(function() CL.setTranspState(false) end)
    pcall(function() CL.stopAllAnims() end)
    pcall(function() CL.nofly() end)
    pcall(function() CL.stopNoclip() end)
    for k, conn in pairs(CL.conns) do
        if conn and conn.Connected then pcall(function() conn:Disconnect() end) end
        CL.conns[k] = nil
    end
    local h = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
    if h then
        pcall(function() h.WalkSpeed = 16 end)
        pcall(function() if h.UseJumpPower then h.JumpPower = 50 else h.JumpHeight = 7.2 end end)
        pcall(function() h.PlatformStand = false end)
        pcall(function() h:ChangeState(Enum.HumanoidStateType.GettingUp) end)
    end
    pcall(function() Transp.stop() end)
end

