    local localHum = player.Character:FindFirstChild("Humanoid")
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    if not (targetRoot and targetHum and localHum and root) then return end
    states.hammer = true
    velocityMagnitude = math.abs(tonumber(velocityMagnitude) or 600)
    local originalCFrame = root.CFrame
    localHum:ChangeState(Enum.HumanoidStateType.Physics)
    localHum.PlatformStand = true
    pcall(function()
        if sethiddenproperty then
            sethiddenproperty(player, "MaximumSimulationRadius", math.huge)
            sethiddenproperty(player, "SimulationRadius", math.huge)
        end
    end)
    local function trueCF()
        local rep
        pcall(function()
            if gethiddenproperty then rep = gethiddenproperty(targetRoot, "PhysicsRepRootPart") end
        end)
        return typeof(rep) == "CFrame" and rep or targetRoot.CFrame
    end
    local hammerTrack
    pcall(function()
        local anim = Instance.new("Animation")
        anim.AnimationId = "rbxassetid://116732690818367"
        local animator = localHum:FindFirstChildOfClass("Animator") or Instance.new("Animator", localHum)
        hammerTrack = animator:LoadAnimation(anim)
        hammerTrack.Priority = Enum.AnimationPriority.Action4
        hammerTrack:Play(0, 1, 1)
        task.defer(function()
            if hammerTrack then hammerTrack.TimePosition = 0.1 hammerTrack:AdjustSpeed(0) end
        end)
    end)
    local FRONT = 4
    local HEIGHT = 9
    local ARM = 9
    local RAISE_START = math.rad(75)
    local WINDUP = math.rad(150)
    local SLAM_END = math.rad(-55)
    local RAISE_DUR = 1.4
    local CHARGE_DUR = 1.1
    local SLAM_DUR = 0.38
    local IMPACT_DUR = 0.3
    local downVec = -Vector3.yAxis
    local phase = "raise"
    local raiseT, chargeT, slamT, impactT = 0, 0, 0, 0
    local angle = RAISE_START
    local goalAngle = RAISE_START
    local angleVel = 0
    local collapse = 0
    local breathe1, breathe2 = math.random()*10, math.random()*10
    local lastPos = root.Position
    local smoothVel = Vector3.zero
    local function frontDir(tcf)
        local f = tcf.LookVector
        f = Vector3.new(f.X, 0, f.Z)
        if f.Magnitude < 0.05 then
            local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            local d = (r and r.Position or tcf.Position) - tcf.Position
            f = Vector3.new(d.X, 0, d.Z)
        end
        return f.Magnitude > 0.001 and f.Unit or Vector3.zAxis
    end
    local function armDir(a, fd)
        local v = downVec * math.cos(a) + fd * math.sin(a)
        return v.Magnitude > 0.001 and v.Unit or downVec
    end
    local function unbindRep()
        local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if r then pcall(function() sethiddenproperty(r, "PhysicsRepRootPart", r) end) end
    end
    local function apply(dt, render)
        if not (states.hammer and player.Character and targetPlayer and targetPlayer.Character) then return false end
        root = player.Character:FindFirstChild("HumanoidRootPart")
        targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local hum = player.Character:FindFirstChild("Humanoid")
        if not (root and targetRoot and hum and targetHum.Health > 0) then return false end
        hum.PlatformStand = true
        if hammerTrack and not hammerTrack.IsPlaying then
            pcall(function() hammerTrack:Play(0,1,1) hammerTrack.TimePosition = 0.1 hammerTrack:AdjustSpeed(0) end)
        end
        if not render then
            pcall(function() sethiddenproperty(root, "PhysicsRepRootPart", targetRoot) end)
        end
        local tcf = trueCF()
        local tpos = tcf.Position
        local fd = frontDir(tcf)
        local slamming = false
        local goalCollapse = 0
        if not render then
            breathe1 += dt * 1.9 breathe2 += dt * 2.7
            if phase == "raise" then
                raiseT = raiseT + dt
                local a = math.clamp(raiseT / RAISE_DUR, 0, 1)
                local ease = a*a*a*(a*(a*6-15)+10)
                goalAngle = RAISE_START + (WINDUP - RAISE_START) * ease
                if a >= 1 then phase = "charge" chargeT = 0 end
            elseif phase == "charge" then
                chargeT = chargeT + dt
                goalAngle = WINDUP + math.sin(breathe1) * math.rad(4)
                if chargeT >= CHARGE_DUR then phase = "slam" slamT = 0 end
            elseif phase == "slam" then
                slamming = true
                slamT = slamT + dt
                local a = math.clamp(slamT / SLAM_DUR, 0, 1)
                local ease = a*a
                goalAngle = WINDUP + (SLAM_END - WINDUP) * ease
                goalCollapse = ease
                if a >= 1 then phase = "impact" impactT = 0 end
            elseif phase == "impact" then
                slamming = true
                impactT = impactT + dt
                goalAngle = SLAM_END
                goalCollapse = 1
                if impactT >= IMPACT_DUR then return false end
            end
            local k = slamming and 480 or 90
            local c = 2 * math.sqrt(k) * (slamming and 1 or 0.9)
            local accel = (goalAngle - angle) * k - angleVel * c
            angleVel = angleVel + accel * dt
            angle = angle + angleVel * dt
            collapse = collapse + (goalCollapse - collapse) * math.min(1, dt * 14)
        end
        local frontAmt = FRONT * (1 - collapse)
        local heightAmt = HEIGHT * (1 - collapse * 0.85)
        local armAmt = ARM * (1 - collapse * 0.7)
        local anchor = tpos + fd * frontAmt + Vector3.new(0, heightAmt, 0)
        local breathY = (phase == "charge") and math.sin(breathe2) * 0.4 or 0
        local dir = armDir(angle, fd)
        local pos = anchor + dir * armAmt + Vector3.new(0, breathY, 0)
        local up = dir
        local fwd = Vector3.new(tpos.X - pos.X, 0, tpos.Z - pos.Z)
        if fwd.Magnitude < 0.05 then fwd = -fd end
        fwd = fwd.Unit
        local right = up:Cross(fwd)
        if right.Magnitude < 0.05 then right = up:Cross(Vector3.yAxis) end
        right = right.Unit
        local back = right:Cross(up).Unit
        root.CFrame = CFrame.fromMatrix(pos, right, up, back)
        if not render then
            local rawVel = (pos - lastPos) / math.max(dt, 0.001)
            smoothVel = smoothVel:Lerp(rawVel, 0.25)
            lastPos = pos
            if phase == "impact" or phase == "slam" then
                local toT = tpos - pos
                local d = toT.Magnitude > 0.1 and toT.Unit or -Vector3.yAxis
                root.AssemblyLinearVelocity = d * velocityMagnitude
            else
                root.AssemblyLinearVelocity = smoothVel
            end
        end
        root.AssemblyAngularVelocity = Vector3.zero
        return true
    end
    RunService:BindToRenderStep("UA_Hammer", Enum.RenderPriority.Last.Value, function(dt)
        if not apply(dt, true) then
            pcall(function() RunService:UnbindFromRenderStep("UA_Hammer") end)
        end
    end)
    connections.hammer = RunService.Heartbeat:Connect(function(dt)
        if not apply(math.min(dt, 1/30), false) then
            pcall(function() RunService:UnbindFromRenderStep("UA_Hammer") end)
            unbindRep()
            local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if r then
                removeVelocity()
                pcall(function() r.CFrame = originalCFrame end)
            end
            local h = player.Character and player.Character:FindFirstChild("Humanoid")
            if h then h.PlatformStand = false h:ChangeState(Enum.HumanoidStateType.GettingUp) end
            if hammerTrack then pcall(function() hammerTrack:Stop(0) end) hammerTrack = nil end
            disconnectConnection("hammer")
            states.hammer = false
        end
    end)
end

