    local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local targetHum = targetPlayer.Character:FindFirstChild("Humanoid")
    local localHum = player.Character:FindFirstChild("Humanoid")
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    if not (targetRoot and targetHum and localHum and root) then return end
    states.yeet = true
    local distance = -3.2
    velocity = tonumber(velocity) or -20
    velocity = velocity > 0 and -velocity or velocity
    local returnCF = root.CFrame
    if setDeathGuard then setDeathGuard(true) end
    localHum:ChangeState(Enum.HumanoidStateType.Physics)
    localHum.PlatformStand = true
    local function trueCF()
        local rep
        pcall(function()
            if gethiddenproperty then rep = gethiddenproperty(targetRoot, "PhysicsRepRootPart") end
        end)
        return typeof(rep) == "CFrame" and rep or targetRoot.CFrame
    end
    local function targetAirborne()
        local air = false
        pcall(function() air = targetHum.FloorMaterial == Enum.Material.Air end)
        if not air then
            pcall(function()
                local s = targetHum:GetState()
                air = s == Enum.HumanoidStateType.Freefall or s == Enum.HumanoidStateType.Jumping
            end)
        end
        return air
    end
    local phase = "wait"
    local lockY = 0
    local beltTop = 0
    local landedAt = nil
    local phaseT = os.clock()
    local function snapBelt()
        local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        local tr = targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not (r and tr) then return end
        local flat = Vector3.new(tr.CFrame.LookVector.X, 0, tr.CFrame.LookVector.Z)
        flat = flat.Magnitude > 0.01 and flat.Unit or Vector3.zAxis
        local p = Vector3.new(tr.Position.X, lockY, tr.Position.Z)
        r.CFrame = CFrame.lookAt(p, p + flat) * CFrame.Angles(math.rad(90), 0, 0)
        r.AssemblyAngularVelocity = Vector3.zero
        return r, tr, flat
    end
    local function cleanup()
        disconnectConnection("yeet")
        disconnectConnection("yeet2")
        local c = player.Character
        local r = c and c:FindFirstChild("HumanoidRootPart")
        local h = c and c:FindFirstChildOfClass("Humanoid")
        if r then
            pcall(function() sethiddenproperty(r, "PhysicsRepRootPart", r) end)
            r.AssemblyLinearVelocity = Vector3.zero
            r.AssemblyAngularVelocity = Vector3.zero
            r.CFrame = returnCF
        end
        if h then h.PlatformStand = false h:ChangeState(Enum.HumanoidStateType.GettingUp) end
        if setDeathGuard then task.delay(1, function() setDeathGuard(false) end) end
        states.yeet = false
    end
    connections.yeet2 = RunService.Stepped:Connect(function()
        if not (states.yeet and phase == "treadmill") then return end
        pcall(snapBelt)
    end)
    connections.yeet = RunService.Heartbeat:Connect(function(dt)
        dt = math.min(dt, 1/20)
        if not (states.yeet and player.Character and targetPlayer and targetPlayer.Parent and targetPlayer.Character) then
            cleanup()
            return
        end
        root = player.Character:FindFirstChild("HumanoidRootPart")
        targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local hum = player.Character:FindFirstChild("Humanoid")
        if not (root and targetRoot and hum and targetHum.Health > 0) then
            cleanup()
            return
        end
        hum.PlatformStand = true
        pcall(function()
            if sethiddenproperty then
                sethiddenproperty(player, "MaximumSimulationRadius", math.huge)
                sethiddenproperty(player, "SimulationRadius", math.huge)
            end
        end)
        local tcf = trueCF()
        local tpos = tcf.Position
        local tvel = targetRoot.AssemblyLinearVelocity
        local now = os.clock()
        local airborne = targetAirborne()
        if phase == "wait" then
            root.CFrame = returnCF
            root.AssemblyLinearVelocity = Vector3.new(0, math.sin(now * 6) * 3, 0)
            root.AssemblyAngularVelocity = Vector3.new(0, 0.4, 0)
            if not airborne and math.abs(tvel.Y) < 3 then
                landedAt = landedAt or now
                if now - landedAt >= 0.35 then
                    lockY = tpos.Y + distance
                    beltTop = lockY - distance
                    phase = "treadmill"
                    phaseT = now
                end
            else
                landedAt = nil
            end
        elseif phase == "treadmill" then
            local ok, r, tr, flat = pcall(snapBelt)
            if ok and r and tr and flat then
                pcall(function() sethiddenproperty(r, "PhysicsRepRootPart", tr) end)
                local heightAbove = tr.Position.Y - beltTop
                local downPull = heightAbove > 0.5 and -math.clamp(heightAbove * 8, 6, 70) or -3
                r.Velocity = flat * velocity + Vector3.new(0, downPull, 0)
                if now - phaseT >= 1 or math.abs(tpos.Y - beltTop) > 10 then
                    cleanup()
                end
            else
                cleanup()
            end
        end
    end)
end

