function CL.viewSorted()
    local list = {}
    for _, plr in ipairs(Players:GetPlayers()) do table.insert(list, plr) end
    table.sort(list, function(a, b) return a.Name:lower() < b.Name:lower() end)
    return list
end

function CL.viewUpdateLabel()
    if CL.viewLabel then CL.viewLabel.Text = (CL.viewing and CL.viewing.Parent and CL.viewing.Name) or "-" end
end

function CL.viewRefresh()
    if not CL.viewActive then return end
    local target = CL.viewing
    if not (target and target.Parent) then return end
    local cam = workspace.CurrentCamera
    if not cam then return end
    local char = target.Character
    local want = char and (char:FindFirstChildOfClass("Humanoid") or char:FindFirstChild("HumanoidRootPart") or char)
    if want and cam.CameraSubject ~= want then
        pcall(function() cam.CameraSubject = want end)
    end
end

function CL.viewBindCamera()
    if CL.viewConns.subj then CL.viewConns.subj:Disconnect() CL.viewConns.subj = nil end
    local cam = workspace.CurrentCamera
    if cam then
        CL.viewConns.subj = cam:GetPropertyChangedSignal("CameraSubject"):Connect(function()
            if CL.viewActive then CL.viewRefresh() end
        end)
    end
    if not CL.viewConns.cam then
        CL.viewConns.cam = workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
            if CL.viewActive then CL.viewBindCamera() CL.viewRefresh() end
        end)
    end
end

function CL.viewApply(target)
    if not (target and target.Parent) then return end
    CL.viewing = target
    CL.viewUpdateLabel()
    if CL.viewConns.charAdded then CL.viewConns.charAdded:Disconnect() CL.viewConns.charAdded = nil end
    CL.viewConns.charAdded = target.CharacterAdded:Connect(function(char)
        char:WaitForChild("HumanoidRootPart", 10)
        task.wait(0.2)
        if CL.viewActive and CL.viewing == target then CL.viewRefresh() end
    end)
    CL.viewBindCamera()
    CL.viewRefresh()
end

function CL.viewCycle(dir)
    local list = CL.viewSorted()
    if #list == 0 then return end
    local idx
    for i, plr in ipairs(list) do if plr == CL.viewing then idx = i break end end
    if not idx then CL.viewApply(list[1]) return end
    idx = ((idx - 1 + dir) % #list) + 1
    CL.viewApply(list[idx])
end

function CL.viewBuildGui()
    if CL.viewGui and CL.viewGui.Parent then return CL.viewGui end
