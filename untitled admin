function CL.playAnimId(rawId, speed, setTime)
    local idStr = tostring(rawId)
    local fullId = idStr:find("rbxassetid://") and idStr or ("rbxassetid://"..idStr)
    speed = tonumber(speed) or 1
    setTime = math.max(0, tonumber(setTime) or 0)
    CL.stopAnimId(idStr)
    CL.animSettings[idStr] = {speed = speed, setTime = setTime}
    local function load()
        local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        local cfg = CL.animSettings[idStr] or {speed = 1, setTime = 0}
        local anim = Instance.new("Animation")
        anim.AnimationId = fullId
        local animator = hum:FindFirstChildOfClass("Animator") or Instance.new("Animator", hum)
        local track = animator:LoadAnimation(anim)
        track.Priority = Enum.AnimationPriority.Action4
        track.Looped = true
        track:Play(0.1, 1, cfg.speed)
        CL.animTracks[idStr] = track
        if cfg.setTime > 0 then
            task.defer(function()
                if CL.animTracks[idStr] == track then
                    pcall(function()
                        track.TimePosition = cfg.setTime
                        track:AdjustSpeed(0)
                    end)
                end
            end)
        end
    end
    pcall(load)
    if CL.animConns[idStr] then CL.animConns[idStr]:Disconnect() end
    CL.animConns[idStr] = player.CharacterAdded:Connect(function()
        task.wait(0.3)
        pcall(load)
    end)
end

function CL.updateAnimId(rawId, speed, setTime)
    local idStr = tostring(rawId)
    speed = tonumber(speed) or 1
    setTime = math.max(0, tonumber(setTime) or 0)
    CL.animSettings[idStr] = {speed = speed, setTime = setTime}
    local track = CL.animTracks[idStr]
    if track then
        pcall(function()
            if setTime > 0 then
                track.TimePosition = setTime
                track:AdjustSpeed(0)
            else
                track:AdjustSpeed(speed)
            end
        end)
    end
end

function CL.stopAnimId(rawId)
    local idStr = tostring(rawId)
    if CL.animConns[idStr] then CL.animConns[idStr]:Disconnect() CL.animConns[idStr] = nil end
    local t = CL.animTracks[idStr]
    if t then pcall(function() t:Stop(0) end) CL.animTracks[idStr] = nil end
end

function CL.stopAllAnims()
    for id in pairs(CL.animTracks) do
        local t = CL.animTracks[id]
        if t then pcall(function() t:Stop(0) end) end
        CL.animTracks[id] = nil
    end
    for id, c in pairs(CL.animConns) do
        pcall(function() c:Disconnect() end)
        CL.animConns[id] = nil
    end
end

CL.invisRunning = false

function CL.startInvisible()
    if CL.invisRunning then return end
    CL.invisRunning = true
    local Lighting = game:GetService("Lighting")
    local Player = player
    repeat task.wait(0.1) until Player.Character
    local Character = Player.Character
    Character.Archivable = true
    local IsInvis = false
    local InvisibleCharacter = Character:Clone()
    InvisibleCharacter.Parent = Lighting
    local Void = workspace.FallenPartsDestroyHeight
    InvisibleCharacter.Name = ""
    local invisFix, invisDied
    local Respawn, TurnVisible
    function TurnVisible()
        if IsInvis == false then return end
        if invisFix then invisFix:Disconnect() end
        if invisDied then invisDied:Disconnect() end
        local CF_1 = Player.Character.Humanoid.RootPart.CFrame
        Character.Humanoid.RootPart.CFrame = CF_1
        InvisibleCharacter:Destroy()
        Player.Character = Character
        Character.Parent = workspace
        IsInvis = false
        pcall(function() workspace.CurrentCamera.CameraSubject = Character:FindFirstChildOfClass("Humanoid") end)
        pcall(function() Character.Animate.Disabled = true Character.Animate.Disabled = false end)
        invisDied = Character:FindFirstChildOfClass("Humanoid").Died:Connect(function() Respawn() end)
        CL.invisRunning = false
    end
    function Respawn()
        if IsInvis == true then
            pcall(function()
                Player.Character = Character
                task.wait()
                Character.Parent = workspace
                Character:FindFirstChildWhichIsA("Humanoid"):Destroy()
                IsInvis = false
                InvisibleCharacter.Parent = nil
                CL.invisRunning = false
            end)
        else
            pcall(function()
                Player.Character = Character
                task.wait()
                Character.Parent = workspace
                Character:FindFirstChildWhichIsA("Humanoid"):Destroy()
                TurnVisible()
            end)
        end
    end
    invisFix = RunService.Stepped:Connect(function()
        pcall(function()
            local IsInteger = tostring(Void):find("-") and true or false
            local Y = Player.Character.Humanoid.RootPart.Position.Y
            if IsInteger then
                if Y <= Void then Respawn() end
            else
                if Y >= Void then Respawn() end
            end
        end)
    end)
    for _, v in pairs(InvisibleCharacter:GetDescendants()) do
        if v:IsA("BasePart") then
            v.Transparency = (v.Name == "HumanoidRootPart") and 1 or 0.5
        end
    end
