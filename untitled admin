    local orbitDirSmooth = orbitDir
    local reverseTimer = 2.5 + math.random() * 3
    local radiusPhase = math.random() * math.pi * 2
    local weave = math.random() * math.pi * 2
    local phase = "circle"
    local phaseT = 0
    local seenT, unseenT = 0, 0
    local boldness = 0.4
    local blend = 1
    local goalPrev, goalCur = pos, pos
    local swoopSign = 1
    local dodgeSign = 1
    local bank, roll = 0, 0
    local stiffness = 95 * intensity
    local function setPhase(p)
        if p == phase then return end
        phase = p
        phaseT = 0
        blend = 0
