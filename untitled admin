local function beginKeyCapture(statusBtn, onBound)
    if capturing then return end
    capturing = true
    local orig = statusBtn.Text
    statusBtn.Text = "Press a key... (Esc)"
    statusBtn.BackgroundColor3 = THEME.accent
    local conn
    conn = UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
        local kc = input.KeyCode
        if conn then conn:Disconnect() conn = nil end
        task.defer(function() capturing = false end)
        statusBtn.BackgroundColor3 = THEME.inputLight
        if kc == Enum.KeyCode.Escape then
            statusBtn.Text = orig
        else
            onBound(kc)
            statusBtn.Text = "Bound "..kc.Name
            task.delay(1.2, function() if statusBtn and statusBtn.Parent then statusBtn.Text = orig end end)
        end
    end)
    table.insert(getgenv().UntitledAdminConnections, conn)
end

