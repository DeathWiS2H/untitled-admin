local Transp = {Transparency = 0.7, Radius = 8, TweenDuration = 0.2, UpdateInterval = 0.1, original = {}, active = {}, tweens = {}, timer = 0, conn = nil}
Transp.tweenInfo = TweenInfo.new(Transp.TweenDuration, Enum.EasingStyle.Quad)
Transp.overlap = OverlapParams.new()
Transp.overlap.FilterDescendantsInstances = { player.Character or Instance.new("Folder") }
Transp.overlap.FilterType = Enum.RaycastFilterType.Exclude
Transp.overlap.MaxParts = 200

player.CharacterAdded:Connect(function(newChar)
    Transp.overlap.FilterDescendantsInstances = { newChar }
end)

function Transp.cancelTween(part)
    local t = Transp.tweens[part]
    if t then t:Cancel() Transp.tweens[part] = nil end
end

function Transp.restorePart(part)
    local orig = Transp.original[part]
    if orig == nil or not part or not part.Parent then Transp.original[part] = nil return end
    Transp.cancelTween(part)
    local t = TweenService:Create(part, Transp.tweenInfo, { Transparency = orig })
    Transp.tweens[part] = t
    t:Play()
    t.Completed:Connect(function(s) if s == Enum.PlaybackState.Completed then Transp.tweens[part] = nil end end)
    Transp.original[part] = nil
end

function Transp.applyPart(part)
    if Transp.original[part] == nil then Transp.original[part] = part.Transparency end
    if part.Transparency == Transp.Transparency then return end
    Transp.cancelTween(part)
    local t = TweenService:Create(part, Transp.tweenInfo, { Transparency = Transp.Transparency })
    Transp.tweens[part] = t
    t:Play()
    t.Completed:Connect(function(s) if s == Enum.PlaybackState.Completed then Transp.tweens[part] = nil end end)
end

function Transp.restoreAll()
    for part in pairs(Transp.active) do
        Transp.restorePart(part)
    end
    Transp.active = {}
end

function Transp.start()
    if Transp.conn then return end
    Transp.conn = RunService.Heartbeat:Connect(function(dt)
        Transp.timer += dt
        if Transp.timer < Transp.UpdateInterval then return end
        Transp.timer = 0
        local char = player.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local nearby = workspace:GetPartBoundsInRadius(root.Position, Transp.Radius, Transp.overlap)
        local newActive = {}
        for _, part in ipairs(nearby) do
            newActive[part] = true
            Transp.applyPart(part)
        end
        for part in pairs(Transp.active) do
            if not newActive[part] then Transp.restorePart(part) end
        end
        Transp.active = newActive
    end)
end

function Transp.stop()
    if Transp.conn then Transp.conn:Disconnect() Transp.conn = nil end
    Transp.restoreAll()
end

