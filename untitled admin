                torpedoTrack:AdjustSpeed(0)
            end)
        end
        dt = math.min(dt, 1/30)
        phaseT += dt
        roll = roll + dt * 12

        if phase == "pullback" then
            local tp = trueTargetCF().Position
            local goal = tp + approachDir * runwayDist + Vector3.new(0, height, 0)
            local accel = (goal - pos) * 18 - vel * 8.5
            vel += accel * dt
            pos += vel * dt
            if phaseT > 1.0 and (pos - goal).Magnitude < 6 then phase = "lock" phaseT = 0
            elseif phaseT > 1.8 then phase = "lock" phaseT = 0 end

        elseif phase == "lock" then
            local tp = trueTargetCF().Position
            local hold = tp + approachDir * runwayDist + Vector3.new(0, height, 0)
            local shake = Vector3.new(math.sin(phaseT * 40) * 0.6, math.cos(phaseT * 33) * 0.4, math.sin(phaseT * 47) * 0.6)
            local accel = (hold + shake - pos) * 40 - vel * 12
            vel += accel * dt
            pos += vel * dt
            if phaseT > 0.5 then phase = "strike" phaseT = 0 strikeT = 0 end

        elseif phase == "strike" then
            strikeT += dt
            local tp = trueTargetCF().Position
            local ramp = math.clamp(strikeT / 0.8, 0, 1)
            local harmonic = (1 - math.cos(ramp * math.pi)) * 0.5
            local speed = 25 + (strikeSpeed - 25) * harmonic
            local predicted = tp + targetRoot.AssemblyLinearVelocity * 0.06
            local aimPoint = predicted + Vector3.new(0, 0.5, 0)
            local toTarget = aimPoint - pos
            local dist = toTarget.Magnitude
            if strikeT > 0.15 and dist <= 5 then
                pcall(function() sethiddenproperty(root, "PhysicsRepRootPart", targetRoot) end)
            end
            if strikeT > 0.15 and dist <= 1 then
                pos = aimPoint
                root.CFrame = CFrame.new(pos)
                root.AssemblyLinearVelocity = Vector3.zero
                detonate()
                return
            end
            local dir = toTarget.Magnitude > 0.01 and toTarget.Unit or approachDir
            local desiredVel = dir * speed
            local accel = (desiredVel - vel) * (12 + harmonic * 28)
            vel += accel * dt
            pos += vel * dt
            if strikeT > 6 then detonate() return end
        end

        local lookDir
        if phase == "strike" and vel.Magnitude > 1 then
            lookDir = vel.Unit
        else
            local tp = trueTargetCF().Position
            local d = tp - pos
            lookDir = d.Magnitude > 0.1 and d.Unit or Vector3.new(0, 0, -1)
        end
        local lookTarget = pos + lookDir
        if (lookTarget - pos).Magnitude < 0.05 then lookTarget = pos + Vector3.new(0, 0, -1) end
        root.CFrame = CFrame.new(pos, lookTarget) * CFrame.Angles(math.rad(90), roll, 0)
        root.AssemblyLinearVelocity = vel
        root.AssemblyAngularVelocity = Vector3.zero
    end)
end

function Cmd.hammer(targetPlayer, velocityMagnitude)
    disconnectConnection("hammer")
