    end
    rebuildWeldCycle()
end

function saveWeld()
    local nm = (UI.weldName.Text or ""):gsub("^%s+",""):gsub("%s+$","")
    if nm == "" then return end
    if protectedWeldNames[nm:lower()] then
        if showWarning then showWarning("'"..nm.."' is a reserved command name", 6) end
        return
    end
    local id
    for k, w in pairs(welds) do if w.name:lower() == nm:lower() then id = k break end end
    if not id then id = tostring(os.time())..math.random(1000,9999) end
    welds[id] = {name=nm, fwd=state.weld.fwd, side=state.weld.side, up=state.weld.up, rotX=state.weld.rotX, rotY=state.weld.rotY, rotZ=state.weld.rotZ, vel=state.weld.vel, dur=state.weld.dur, anim=state.weld.anim or ""}
    registerWeldCommand(welds[id])
    UI.weldName.Text = ""
    updateWelds()
    if UI.weldSaveBtn then
        UI.weldSaveBtn.Text = "Saved!"
        task.delay(1, function() if UI.weldSaveBtn then UI.weldSaveBtn.Text = "Save Position" end end)
    end
end

