function Cmd.valkyrie(targetPlayer, intensity)
    disconnectConnection("valkyrie")
    pcall(function() RunService:UnbindFromRenderStep("UA_Valkyrie") end)
    if not (targetPlayer and targetPlayer.Character and player.Character) then return end
    local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local targetHum = targetPlayer.Character:FindFirstChild("Humanoid")
    local localHum = player.Character:FindFirstChild("Humanoid")
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    if not (targetRoot and targetHum and localHum and root) then return end
    states.valkyrie = true
    intensity = math.clamp(tonumber(intensity) or 1, 0.2, 3)
    localHum:ChangeState(Enum.HumanoidStateType.Physics)
    localHum.PlatformStand = true
    pcall(function()
        if sethiddenproperty then
            sethiddenproperty(player, "MaximumSimulationRadius", math.huge)
            sethiddenproperty(player, "SimulationRadius", math.huge)
        end
    end)
    local function trueCF()
        local rep
        pcall(function()
            if gethiddenproperty then rep = gethiddenproperty(targetRoot, "PhysicsRepRootPart") end
        end)
        return typeof(rep) == "CFrame" and rep or targetRoot.CFrame
    end
    local function bindRep()
        local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if r and targetRoot then pcall(function() sethiddenproperty(r, "PhysicsRepRootPart", targetRoot) end) end
    end
    local function unbindRep()
        local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if r then pcall(function() sethiddenproperty(r, "PhysicsRepRootPart", r) end) end
    end
    local pos = root.Position
    local vel = Vector3.zero
    local lastTargetPos = trueCF().Position
    local targetVel = Vector3.zero
    local breathe1, breathe2, breathe3 = math.random()*10, math.random()*10, math.random()*10
    local orbitAng = math.random() * math.pi * 2
    local orbitDir = math.random(0,1) == 0 and 1 or -1
    local orbitDirSmooth = orbitDir
    local petalPhase = math.random() * math.pi * 2
    local phase = "weave"
    local phaseT = 0
    local blend = 1
    local goalPrev, goalCur = pos, pos
    local diveEntry, diveApex, diveExit = pos, pos, pos
    local flip = 0
    local flipTurns = 1
    local bank, pitch = 0, 0
    local strafeArm = false
    local strafeTimer = 0
    local WINDUP_DUR = 0.42 / intensity
    local DIVE_DUR = 0.66
    local CLIMB_DUR = 0.85
    local stiffness = 95 * intensity
    local function setPhase(p)
        if p == phase then return end
        phase = p
        phaseT = 0
        blend = 0
        goalPrev = goalCur
    end
    local function apply(dt, render)
        if not (states.valkyrie and player.Character and targetPlayer and targetPlayer.Character) then return false end
        root = player.Character:FindFirstChild("HumanoidRootPart")
        targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local hum = player.Character:FindFirstChild("Humanoid")
        if not (root and targetRoot and hum and targetHum.Health > 0) then return false end
        hum.PlatformStand = true
        if not render then bindRep() end
        local tcf = trueCF()
        local tpos = tcf.Position
        if not render then
            local rawVel = (tpos - lastTargetPos) / math.max(dt, 0.001)
            targetVel = targetVel:Lerp(rawVel, 0.35)
            lastTargetPos = tpos
            breathe1 += dt*1.7 breathe2 += dt*2.3 breathe3 += dt*0.9
            phaseT += dt
            orbitDirSmooth = orbitDirSmooth + (orbitDir - orbitDirSmooth) * math.min(1, dt * 2.5)
            local lead = targetVel * 0.35
            if phase == "weave" then
                strafeTimer = strafeTimer + dt
                if strafeTimer > (2 + math.random() * 1.5) then strafeArm = true strafeTimer = 0 end
                if strafeArm then
                    local toMe = pos - tpos
                    local flat = Vector3.new(toMe.X, 0, toMe.Z)
                    local fwd = Vector3.new(tcf.LookVector.X, 0, tcf.LookVector.Z)
                    if flat.Magnitude > 1 and fwd.Magnitude > 0.1 then
                        local align = flat.Unit:Dot(fwd.Unit)
                        if align > 0.992 then
                            strafeArm = false
                            local dir = flat.Unit
                            flipTurns = (math.random(0,1)==0) and 1 or 2
                            diveEntry = tpos + dir * (15 + 4*intensity) + Vector3.new(0, 19, 0)
                            diveApex = tpos + dir * (7 + 2*intensity) + Vector3.new(0, 8, 0)
                            diveExit = tpos + Vector3.new(0, -1, 0)
                            setPhase("windup")
                        end
                    end
                end
            elseif phase == "windup" then
                if phaseT > WINDUP_DUR then setPhase("dive") end
            elseif phase == "dive" then
                if phaseT > DIVE_DUR then setPhase("climb") end
            elseif phase == "climb" then
                if phaseT > CLIMB_DUR then
                    orbitDir = -orbitDir
                    setPhase("weave")
                end
            end
            blend = math.min(1, blend + dt / 0.5)
            local ease = blend*blend*(3-2*blend)
            local breath = Vector3.new(math.sin(breathe1), math.sin(breathe2)*0.6 + math.sin(breathe3)*0.4, math.cos(breathe1*0.8)) * (0.4 * intensity)
            local goal
            local stiffMul = 1
            if phase == "weave" then
                orbitAng += dt * orbitDirSmooth * (1.1 + 0.35*intensity)
                petalPhase += dt * 0.7
                local r = 12 + math.cos(orbitAng * 2 + petalPhase) * 3.5 + math.sin(breathe1*0.5)*1
                local h = 4.5 + math.sin(orbitAng*2 + breathe2) * 2.5 + math.sin(breathe3)*1
                goal = tpos + Vector3.new(math.cos(orbitAng)*r, h, math.sin(orbitAng)*r) + lead
            elseif phase == "windup" then
                local shake = Vector3.new(math.sin(breathe1*22), math.sin(breathe2*26), math.cos(breathe1*20)) * 0.6
                goal = diveEntry + shake + lead
                stiffMul = 3.6
            elseif phase == "dive" then
                local a = math.clamp(phaseT / DIVE_DUR, 0, 1)
                local inv = 1 - a
                local hp = trueCF().Position + Vector3.new(0, -1, 0)
                local exit = diveExit:Lerp(hp, 0.6)
                goal = diveEntry*(inv*inv) + diveApex*(2*inv*a) + exit*(a*a) + targetVel * (0.4 + a*0.3)
                stiffMul = 7.0
            else
                local a = math.clamp(phaseT / CLIMB_DUR, 0, 1)
                local up = Vector3.new(0, 11 + 5*intensity, 0) * math.sin(a * math.pi * 0.5)
                local outDir = pos - tpos
                outDir = Vector3.new(outDir.X, 0, outDir.Z)
                outDir = outDir.Magnitude > 0.1 and outDir.Unit or tcf.LookVector
                goal = tpos + outDir * (9 + a * 6) + up + lead
                stiffMul = 2.0
            end
            goal = goal + breath * (0.5 + ease*0.5)
            goal = goalPrev:Lerp(goal, ease)
            goalCur = goal
            local k = stiffness * stiffMul
            local c = 2 * math.sqrt(k)
            local accel = (goal - pos) * k - vel * c
            vel = vel + accel * dt
            pos = pos + vel * dt
            local goalFlip
            if phase == "dive" then
                local a = math.clamp(phaseT / DIVE_DUR, 0, 1)
                local eased = a*a*a*(a*(a*6-15)+10)
                goalFlip = eased * math.pi * 2 * flipTurns
            elseif phase == "climb" then
                goalFlip = math.pi * 2 * flipTurns
            else
                goalFlip = 0
                flip = 0
            end
            if phase == "dive" or phase == "climb" then
                flip = flip + (goalFlip - flip) * math.min(1, dt * 20)
            end
        end
        local watchPos
        if phase == "dive" then
            watchPos = pos + (vel.Magnitude > 1 and vel.Unit or -tcf.LookVector) * 4
        else
            watchPos = trueCF().Position + Vector3.new(0, 1.5, 0)
        end
        local tilt = math.clamp(vel.Magnitude / 70, 0, 0.55)
        local leanDir = vel.Magnitude > 0.5 and vel.Unit or Vector3.zero
        local targetBank = -leanDir:Dot(tcf.RightVector) * tilt
        bank = bank + (targetBank - bank) * math.min(1, dt * 6)
        local targetPitch = -leanDir.Y * tilt + math.sin(breathe2)*0.04
        pitch = pitch + (targetPitch - pitch) * math.min(1, dt * 6)
        root.CFrame = CFrame.new(pos, watchPos) * CFrame.Angles(pitch + flip, 0, bank + math.sin(breathe1)*0.04)
        root.AssemblyLinearVelocity = vel + targetVel * 0.5
        root.AssemblyAngularVelocity = Vector3.zero
        return true
    end
    RunService:BindToRenderStep("UA_Valkyrie", Enum.RenderPriority.Last.Value, function(dt)
        if not apply(dt, true) then
            pcall(function() RunService:UnbindFromRenderStep("UA_Valkyrie") end)
        end
    end)
    connections.valkyrie = RunService.Heartbeat:Connect(function(dt)
        if not apply(math.min(dt, 1/30), false) then
            pcall(function() RunService:UnbindFromRenderStep("UA_Valkyrie") end)
            unbindRep()
            local h = player.Character and player.Character:FindFirstChild("Humanoid")
            if h then h.PlatformStand = false h:ChangeState(Enum.HumanoidStateType.GettingUp) end
            disconnectConnection("valkyrie")
            states.valkyrie = false
        end
    end)
end

function Cmd.pendulum(targetPlayer, length, power)
    disconnectConnection("pendulum")
