local lastTarget = nil

local function resolveTarget(partialName, sender)
    sender = sender or player
    local pn = partialName:lower()
    if pn == "me" then return sender end
    if pn == "random" then
        local validPlayers = {}
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= sender then table.insert(validPlayers, plr) end
        end
        return #validPlayers > 0 and validPlayers[math.random(#validPlayers)] or nil
    end
    local senderChar = sender.Character
    local senderRoot = senderChar and senderChar:FindFirstChild("HumanoidRootPart")
    if (pn == "nearest" or pn == "near") and senderRoot then
        local closest, closestDist = nil, math.huge
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= sender and plr.Character then
                local plrRoot = plr.Character:FindFirstChild("HumanoidRootPart")
                if plrRoot then
                    local dist = (senderRoot.Position - plrRoot.Position).Magnitude
                    if dist < closestDist then closestDist, closest = dist, plr end
                end
            end
        end
        return closest
    end
    if (pn == "furthest" or pn == "far") and senderRoot then
        local furthest, furthestDist = nil, 0
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= sender and plr.Character then
                local plrRoot = plr.Character:FindFirstChild("HumanoidRootPart")
                if plrRoot then
                    local dist = (senderRoot.Position - plrRoot.Position).Magnitude
                    if dist > furthestDist then furthestDist, furthest = dist, plr end
                end
            end
        end
        return furthest
    end
    local bestMatch, bestScore = nil, 0
    for _, plr in pairs(Players:GetPlayers()) do
        local nameMatch = plr.Name:lower():find(pn)
        local displayMatch = plr.DisplayName:lower():find(pn)
        if nameMatch or displayMatch then
            local score = (nameMatch and #plr.Name or 0) + (displayMatch and #plr.DisplayName or 0)
            if score > bestScore then bestScore, bestMatch = score, plr end
        end
    end
    return bestMatch
end

local function findPlayer(partialName, sender)
    if partialName == nil or partialName == "" or partialName:lower() == "again" or partialName:lower() == "last" then
        return (lastTarget and lastTarget.Parent) and lastTarget or nil
    end
    local result = resolveTarget(partialName, sender)
    if result then lastTarget = result end
    return result
end

