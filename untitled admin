                    local fwdAmt = md:Dot(flatLook)
                    local sideAmt = md:Dot(flatRight)
                    vel = cam.CFrame.LookVector * (fwdAmt * speed) + cam.CFrame.RightVector * (sideAmt * speed)
                end
            end
            if hum.Jump then
                vel = vel + Vector3.new(0, speed, 0)
            end
            VH.Velocity = vel
        end)
