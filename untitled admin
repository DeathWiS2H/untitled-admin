            orbitDirSmooth = orbitDirSmooth + (orbitDir - orbitDirSmooth) * math.min(1, dt * 2.2)
            local toMe = pos - tpos
            local flat = Vector3.new(toMe.X, 0, toMe.Z)
            local seen = false
            if flat.Magnitude > 0.5 then
