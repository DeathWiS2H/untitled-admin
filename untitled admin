function updateSettings()
    for _,c in ipairs(UI.setScroll:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
    if not CommandRegistry then return end
    local q = state.settingsSearchQuery:lower()
    for _,n in ipairs(getCmdList()) do
        local cmd = CommandRegistry.commands[n]
        if cmd then
            local isDisabled = CommandRegistry.disabledCommands[n]~=nil
            local tf = state.settingsTypeFilter or "all"
            local kind = (settingsCmdKind and settingsCmdKind(n)) or "commands"
            if ((state.settingsFilterMode=="all") or (state.settingsFilterMode=="enabled" and not isDisabled) or (state.settingsFilterMode=="disabled" and isDisabled)) and (tf=="all" or tf==kind) then
                if q=="" or n:lower():find(q) then
                    local defs = CMD_DEFAULTS[n]
                    local cardH = 38 + (defs and (#defs * 30 + 4) or 0)
                    local card = create("Frame",{Size=UDim2.new(1,0,0,cardH),BackgroundColor3=THEME.panel,BorderSizePixel=0,Parent=UI.setScroll})
                    corner(card,5)
                    create("TextLabel",{Size=UDim2.new(1,-80,0,38),Position=UDim2.new(0,8,0,0),Text=isDisabled and (n.."  (hidden)") or n,Font=Enum.Font.Code,TextSize=13,TextColor3=isDisabled and THEME.textMuted or THEME.text,BackgroundTransparency=1,TextXAlignment=Enum.TextXAlignment.Left,TextYAlignment=Enum.TextYAlignment.Center,TextTruncate=Enum.TextTruncate.AtEnd,Parent=card})
                    local togBtn = create("TextButton",{Size=UDim2.new(0,54,0,24),Position=UDim2.new(1,-62,0,7),Text=isDisabled and "Show" or "Hide",BackgroundColor3=isDisabled and THEME.green or THEME.red,TextColor3=THEME.text,Font=Enum.Font.Code,TextSize=12,BorderSizePixel=0,Parent=card})
                    corner(togBtn,4)
                    togBtn.MouseButton1Click:Connect(function() if isDisabled then CommandRegistry:enableCommand(n) else CommandRegistry:disableCommand(n) end updateSettings() end)
                    if defs then
                        for di, def in ipairs(defs) do
                            local row = create("Frame",{Size=UDim2.new(1,-16,0,26),Position=UDim2.new(0,8,0,38+(di-1)*30),BackgroundTransparency=1,Parent=card})
                            create("TextLabel",{Size=UDim2.new(1,-70,1,0),Position=UDim2.new(0,0,0,0),Text=def.label,Font=Enum.Font.Code,TextSize=11,TextColor3=THEME.textGray,BackgroundTransparency=1,TextXAlignment=Enum.TextXAlignment.Left,TextYAlignment=Enum.TextYAlignment.Center,TextTruncate=Enum.TextTruncate.AtEnd,Parent=row})
                            local ov = state.cmdDefaults[n]
                            local cur = ov and (ov[tostring(def.i)] or ov[def.i]) or nil
                            local box = create("TextBox",{Size=UDim2.new(0,60,0,24),Position=UDim2.new(1,-62,0,1),Text=tostring(cur ~= nil and cur or def.def),BackgroundColor3=THEME.input,TextColor3=cur ~= nil and THEME.textBlue or THEME.text,Font=Enum.Font.Code,TextSize=11,BorderSizePixel=0,ClearTextOnFocus=false,Parent=row})
                            corner(box,4)
                            box.FocusLost:Connect(function()
                                local nv = tonumber(box.Text)
                                if nv == nil then
                                    local o = state.cmdDefaults[n]
                                    local c = o and (o[tostring(def.i)] or o[def.i]) or nil
                                    box.Text = tostring(c ~= nil and c or def.def)
                                    return
                                end
                                if nv == def.def then
                                    local o = state.cmdDefaults[n]
                                    if o then
                                        o[tostring(def.i)] = nil
                                        o[def.i] = nil
                                        if not next(o) then state.cmdDefaults[n] = nil end
                                    end
                                    box.TextColor3 = THEME.text
                                else
                                    state.cmdDefaults[n] = state.cmdDefaults[n] or {}
                                    state.cmdDefaults[n][tostring(def.i)] = nv
                                    box.TextColor3 = THEME.textBlue
                                end
                                box.Text = tostring(nv)
                            end)
                        end
                    end
                end
            end
        end
    end
end

