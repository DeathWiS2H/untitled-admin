function Cmd.nuke(targetPlayer, height, velocity)
    disconnectConnection("nuke")
    if not (targetPlayer and targetPlayer.Character and player.Character) then return end
    local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    local humanoid = player.Character:FindFirstChild("Humanoid")
    if not (targetRoot and root and humanoid) then return end
    states.nuke = true
    local spawnPos = targetRoot.Position + Vector3.new(0, height, 0)
    humanoid.Sit = true
    workspace.Gravity = 0
    root.CFrame = CFrame.new(spawnPos) * CFrame.Angles(math.pi, 0, 0)
    local spinAngle = 0
    local phase = "descend"
    local function unbindRep()
        local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if r then pcall(function() sethiddenproperty(r, "PhysicsRepRootPart", r) end) end
    end
    local function cleanup()
        unbindRep()
        workspace.Gravity = OriginalGravity
        disconnectConnection("nuke")
        states.nuke = false
    end
    connections.nuke = RunService.Heartbeat:Connect(function()
        if not (states.nuke and player.Character and targetPlayer.Character) then cleanup() return end
        root = player.Character:FindFirstChild("HumanoidRootPart")
        targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        humanoid = player.Character:FindFirstChild("Humanoid")
        if not (root and targetRoot and humanoid) then cleanup() return end
        humanoid.Sit = true
        if phase == "descend" then
            spinAngle = spinAngle + math.rad(20)
            local currentPos = root.Position
            root.CFrame = CFrame.new(targetRoot.Position.X, currentPos.Y - 2.5, targetRoot.Position.Z) * CFrame.Angles(0, spinAngle, 0)
            if (root.Position - Vector3.new(root.Position.X, targetRoot.Position.Y, root.Position.Z)).Magnitude <= 10 then
                phase = "lock"
            end
        else
            pcall(function() sethiddenproperty(root, "PhysicsRepRootPart", targetRoot) end)
            root.CFrame = targetRoot.CFrame * CFrame.Angles(math.pi, 0, 0)
            if not root:FindFirstChild("NukeSpin") then
                local spin = Instance.new("BodyAngularVelocity")
                spin.Name = "NukeSpin"
