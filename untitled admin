do
    local function clampToScreen()
        local cam = workspace.CurrentCamera
        if not cam then return end
        local vp = cam.ViewportSize
        if UI.main then
            local s = UI.main.AbsoluteSize
            local px, py = UI.main.Position.X, UI.main.Position.Y
            local baseX, baseY = px.Scale * vp.X, py.Scale * vp.Y
            local nx = math.clamp(baseX + px.Offset, 0, math.max(0, vp.X - s.X)) - baseX
            local ny = math.clamp(baseY + py.Offset, 0, math.max(0, vp.Y - s.Y)) - baseY
            UI.main.Position = UDim2.new(px.Scale, nx, py.Scale, ny)
        end
        for _, b in ipairs(UI.buttonGui:GetChildren()) do
            if b:IsA("Frame") and b.Name:sub(1,10) == "CmdButton_" then
                local s = b.AbsoluteSize
                local bx, by = b.Position.X, b.Position.Y
                local baseX, baseY = bx.Scale * vp.X, by.Scale * vp.Y
                local nx = math.clamp(baseX + bx.Offset, 0, math.max(0, vp.X - s.X)) - baseX
                local ny = math.clamp(baseY + by.Offset, 0, math.max(0, vp.Y - s.Y)) - baseY
                b.Position = UDim2.new(bx.Scale, nx, by.Scale, ny)
            end
        end
        pcall(function() Grid.rebuild() end)
    end
    local vpConn
    local function hook()
        if vpConn then vpConn:Disconnect() end
        local cam = workspace.CurrentCamera
        if cam then
            vpConn = cam:GetPropertyChangedSignal("ViewportSize"):Connect(clampToScreen)
            table.insert(getgenv().UntitledAdminConnections, vpConn)
        end
    end
    hook()
    local camConn = workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(hook)
    table.insert(getgenv().UntitledAdminConnections, camConn)
end

