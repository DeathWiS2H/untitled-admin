function applyAntilag(on)
    state.antilag = on and true or false
    pcall(function()
        local rq = UserSettings():GetService("UserGameSettings")
        if on then rq.SavedQualityLevel = Enum.SavedQualitySetting.QualityLevel1 end
    end)
    pcall(function()
        settings().Rendering.QualityLevel = on and Enum.QualityLevel.Level01 or Enum.QualityLevel.Automatic
    end)
    local Lighting = game:GetService("Lighting")
    if on then
        for _, e in ipairs(Lighting:GetChildren()) do
            if e:IsA("PostEffect") or e:IsA("Atmosphere") then
                savedLighting[e] = e.Enabled
                e.Enabled = false
            end
        end
    else
        for e, was in pairs(savedLighting) do
            if e and e.Parent then e.Enabled = was end
        end
        savedLighting = {}
    end
    disconnectConnection("antilag")
    if on then
