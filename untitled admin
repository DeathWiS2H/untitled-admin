function Cmd.bang(targetPlayer, speed, startThrust, endThrust)
    disconnectConnection("bang")
    pcall(function() RunService:UnbindFromRenderStep("UA_Bang") end)
    if not (targetPlayer and targetPlayer.Character and player.Character) then return end
    local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local targetHum = targetPlayer.Character:FindFirstChild("Humanoid")
    local localHum = player.Character:FindFirstChild("Humanoid")
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    if not (targetRoot and targetHum and localHum and root) then return end
    states.bang = true
    speed = tonumber(speed) or 6
    startThrust = -math.abs(tonumber(startThrust) or 0)
    endThrust = -math.abs(tonumber(endThrust) or 2)
    localHum:ChangeState(Enum.HumanoidStateType.Physics)
    localHum.PlatformStand = true
    pcall(function()
        if sethiddenproperty then
            sethiddenproperty(player, "MaximumSimulationRadius", math.huge)
            sethiddenproperty(player, "SimulationRadius", math.huge)
        end
    end)
    local function trueCF()
        local rep
        pcall(function()
            if gethiddenproperty then rep = gethiddenproperty(targetRoot, "PhysicsRepRootPart") end
        end)
        return typeof(rep) == "CFrame" and rep or targetRoot.CFrame
    end
    local bangTrack
    pcall(function()
        local anim = Instance.new("Animation")
        anim.AnimationId = "rbxassetid://116732690818367"
        local animator = localHum:FindFirstChildOfClass("Animator") or Instance.new("Animator", localHum)
        bangTrack = animator:LoadAnimation(anim)
        bangTrack.Priority = Enum.AnimationPriority.Action4
        bangTrack:Play(0, 1, 1)
        task.defer(function()
            if bangTrack then
                bangTrack.TimePosition = 0.1
                bangTrack:AdjustSpeed(0)
            end
        end)
    end)
    local k = 90
    local zeta = 0.7
    local c = 2 * math.sqrt(k) * zeta
    local SWING_INERTIA = 0.05
    local REST_PITCH = math.rad(8)
    local pitch, pitchVel = REST_PITCH, 0
    local yaw, yawVel = 0, 0
    local thrust, thrustVel = startThrust, 0
    local oscPhase = 0
    local lastPos = root.Position
    local lastAnchor = trueCF().Position
    local anchorVel = Vector3.zero
    local lastTargetYaw = math.atan2(trueCF().LookVector.X, trueCF().LookVector.Z)
    local PITCH_MIN, PITCH_MAX = -1.0, 1.0
    local YAW_LIM = 0.6
    local ANCHOR_DROP = -1
    local function apply(dt, render)
        if not (states.bang and player.Character and targetPlayer and targetPlayer.Character) then return false end
        root = player.Character:FindFirstChild("HumanoidRootPart")
        targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local hum = player.Character:FindFirstChild("Humanoid")
        if not (root and targetRoot and hum and targetHum.Health > 0) then return false end
        hum.PlatformStand = true
        if not render then
            pcall(function() sethiddenproperty(root, "PhysicsRepRootPart", targetRoot) end)
        end
        if bangTrack and not bangTrack.IsPlaying then
            pcall(function()
                bangTrack:Play(0, 1, 1)
                bangTrack.TimePosition = 0.1
                bangTrack:AdjustSpeed(0)
            end)
        end
        local tcf = trueCF()
        local outDir = tcf.LookVector
        outDir = Vector3.new(outDir.X, 0, outDir.Z)
        outDir = outDir.Magnitude > 0.1 and outDir.Unit or Vector3.zAxis
        local faceDir = -outDir
        if not render then
            oscPhase += dt * speed
            local osc = (math.sin(oscPhase) * 0.5 + 0.5)
            local eased = osc * osc * (3 - 2 * osc)
            local goalThrust = startThrust + (endThrust - startThrust) * eased
            local thrustAcc = (goalThrust - thrust) * k - thrustVel * c
            thrustVel = thrustVel + thrustAcc * dt
            thrust = thrust + thrustVel * dt
        end
        local anchor = tcf.Position + faceDir * thrust + Vector3.new(0, -ANCHOR_DROP, 0)
        if not render then
            local newAnchorVel = (anchor - lastAnchor) / math.max(dt, 0.001)
            local accelKick = (newAnchorVel - anchorVel)
            anchorVel = anchorVel:Lerp(newAnchorVel, 0.5)
            lastAnchor = anchor
            local pitchAcc = -(pitch - REST_PITCH) * k - pitchVel * c
            local yawAcc = -yaw * k - yawVel * c
            local targetYaw = math.atan2(-faceDir.X, -faceDir.Z)
            local dYaw = targetYaw - lastTargetYaw
            while dYaw > math.pi do dYaw -= 2 * math.pi end
            while dYaw < -math.pi do dYaw += 2 * math.pi end
            lastTargetYaw = targetYaw
            local turnRate = dYaw / math.max(dt, 0.001)
            yawVel = yawVel - turnRate * SWING_INERTIA
            pitchVel = pitchVel - accelKick.Y * 0.02
            pitchVel = pitchVel + pitchAcc * dt
            pitch = pitch + pitchVel * dt
            yawVel = yawVel + yawAcc * dt
            yaw = yaw + yawVel * dt
            if pitch < PITCH_MIN then pitch = PITCH_MIN pitchVel = -pitchVel * 0.3 end
            if pitch > PITCH_MAX then pitch = PITCH_MAX pitchVel = -pitchVel * 0.3 end
            if yaw < -YAW_LIM then yaw = -YAW_LIM yawVel = -yawVel * 0.3 end
            if yaw > YAW_LIM then yaw = YAW_LIM yawVel = -yawVel * 0.3 end
        end
        local yawCF = CFrame.fromAxisAngle(Vector3.yAxis, yaw)
        local swungOut = yawCF * faceDir
        local bodyDir = (swungOut * math.cos(pitch) + Vector3.yAxis * math.sin(pitch)).Unit
        local pos = anchor + bodyDir * 1.5
        local up = -bodyDir
        local refRight = up:Cross(Vector3.yAxis)
        if refRight.Magnitude < 0.05 then refRight = up:Cross(tcf.LookVector) end
        refRight = refRight.Unit
        local back = refRight:Cross(up).Unit
        root.CFrame = CFrame.fromMatrix(pos, refRight, up, back)
        local frameVel = (pos - lastPos) / math.max(dt, 0.001)
        lastPos = pos
        root.AssemblyLinearVelocity = render and root.AssemblyLinearVelocity or (frameVel:Lerp(anchorVel, 0.3))
        root.AssemblyAngularVelocity = Vector3.zero
        return true
    end
    RunService:BindToRenderStep("UA_Bang", Enum.RenderPriority.Last.Value, function(dt)
        if not apply(dt, true) then
            pcall(function() RunService:UnbindFromRenderStep("UA_Bang") end)
        end
    end)
    connections.bang = RunService.Heartbeat:Connect(function(dt)
        if not apply(math.min(dt, 1/30), false) then
            pcall(function() RunService:UnbindFromRenderStep("UA_Bang") end)
            local h = player.Character and player.Character:FindFirstChild("Humanoid")
            if h then h.PlatformStand = false h:ChangeState(Enum.HumanoidStateType.GettingUp) end
            disconnectConnection("bang")
            local rr = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if rr then pcall(function() sethiddenproperty(rr, "PhysicsRepRootPart", rr) end) end
            if bangTrack then pcall(function() bangTrack:Stop(0) end) bangTrack = nil end
            states.bang = false
        end
    end)
end

