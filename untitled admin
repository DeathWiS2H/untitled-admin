    local function findSavedWeld(name)
        name = (name or ""):gsub("^%s+",""):gsub("%s+$",""):lower()
        if name == "" then return nil end
        if welds then
            for _, w in pairs(welds) do
                if w.name:lower() == name then return w end
            end
        end
        if PREBUILT_WELDS then
            for _, w in ipairs(PREBUILT_WELDS) do
                if w.name:lower() == name and not (state.weldPrebuiltDeleted and state.weldPrebuiltDeleted[name]) then return w end
            end
        end
        return nil
    end

    local function resolveWeldTarget(preferLast)
        local txt = (UI.weldTargetBox and UI.weldTargetBox.Text or ""):gsub("^%s+",""):gsub("%s+$","")
