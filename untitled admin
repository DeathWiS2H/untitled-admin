            if p then return end
            if i.KeyCode==Enum.KeyCode.W then CONTROL.F=0
            elseif i.KeyCode==Enum.KeyCode.S then CONTROL.B=0
            elseif i.KeyCode==Enum.KeyCode.A then CONTROL.L=0
            elseif i.KeyCode==Enum.KeyCode.D then CONTROL.R=0
            elseif i.KeyCode==Enum.KeyCode.E then CONTROL.Q=0
            elseif i.KeyCode==Enum.KeyCode.Q then CONTROL.E=0 end
        end)

        task.spawn(function()
            repeat task.wait()
                if not CL.flying then break end
                local c = player.Character
                local cam = workspace.CurrentCamera
                local root = c and c:FindFirstChild("HumanoidRootPart")
                local hum = c and c:FindFirstChildOfClass("Humanoid")
                if root and hum and cam then
                    local VH, GH = attach(root)
                    if VH and GH then
                        if not CL.vflying then hum.PlatformStand = true end
                        VH.MaxForce = Vector3.new(9e9,9e9,9e9)
                        GH.MaxTorque = Vector3.new(9e9,9e9,9e9)
                        GH.CFrame = cam.CFrame
                        local anyInput = (CONTROL.L+CONTROL.R)~=0 or (CONTROL.F+CONTROL.B)~=0 or (CONTROL.Q+CONTROL.E)~=0
                        local speed = CL.flyspeed * 50
                        if anyInput then
                            VH.Velocity = ((cam.CFrame.LookVector*(CONTROL.F+CONTROL.B)) + ((cam.CFrame*CFrame.new(CONTROL.L+CONTROL.R,(CONTROL.F+CONTROL.B+CONTROL.Q+CONTROL.E)*0.2,0).p)-cam.CFrame.p)) * speed
                        else
                            VH.Velocity = Vector3.zero
                        end
                    end
                end
            until not CL.flying
        end)
    end
