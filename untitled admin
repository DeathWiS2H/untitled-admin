function Cmd.wreckingball(targetPlayer, length, velocityMagnitude)
    disconnectConnection("wreckingball")
    disconnectConnection("wreckingballJump")
    if not (targetPlayer and targetPlayer.Character and player.Character) then return end
    local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local targetHum = targetPlayer.Character:FindFirstChild("Humanoid")
    local localHum = player.Character:FindFirstChild("Humanoid")
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    local head = player.Character:FindFirstChild("Head")
    if not (targetRoot and targetHum and localHum and root and head) then return end
    states.wreckingball = true
    length = math.clamp(tonumber(length) or 18, 6, 80)
    velocityMagnitude = tonumber(velocityMagnitude) or -150
    local gravMag = math.abs(velocityMagnitude)
    localHum:ChangeState(Enum.HumanoidStateType.Physics)
    localHum.PlatformStand = true
    pcall(function()
        if sethiddenproperty then
            sethiddenproperty(player, "MaximumSimulationRadius", math.huge)
            sethiddenproperty(player, "SimulationRadius", math.huge)
        end
    end)
    local function bindRep()
        local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if r and targetRoot then pcall(function() sethiddenproperty(r, "PhysicsRepRootPart", targetRoot) end) end
    end
    local function unbindRep()
        local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if r then pcall(function() sethiddenproperty(r, "PhysicsRepRootPart", r) end) end
    end
    local function pivotFromTarget()
        local th = targetPlayer.Character and targetPlayer.Character:FindFirstChild("Head")
        local base = (th and th.Position) or (targetRoot.Position + Vector3.new(0, 1.5, 0))
        return base + Vector3.new(0, length, 0)
    end
    local pivot = pivotFromTarget()
    local arm = (root.Position - pivot)
    arm = arm.Magnitude > 0.1 and arm.Unit or -Vector3.yAxis
    local vel = Vector3.zero
    local jumpPulse = 0
    connections.wreckingballJump = UserInputService.JumpRequest:Connect(function()
        if states.wreckingball then jumpPulse = 0.28 end
    end)
    local function cleanup()
        disconnectConnection("wreckingball")
        disconnectConnection("wreckingballJump")
        states.wreckingball = false
        unbindRep()
        local h = player.Character and player.Character:FindFirstChild("Humanoid")
        if h then h.PlatformStand = false h:ChangeState(Enum.HumanoidStateType.GettingUp) end
    end
    connections.wreckingball = RunService.Heartbeat:Connect(function(dt)
        if not (states.wreckingball and player.Character and targetPlayer.Character) then cleanup() return end
        root = player.Character:FindFirstChild("HumanoidRootPart")
        head = player.Character:FindFirstChild("Head")
        targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local hum = player.Character:FindFirstChild("Humanoid")
        if not (root and head and targetRoot and hum and targetHum.Health > 0) then cleanup() return end
        hum.PlatformStand = true
        dt = math.min(dt, 1/20)
        bindRep()
        pivot = pivotFromTarget()
        local ballPos = pivot + arm * length
        local accel = Vector3.new(0, -gravMag, 0)
        local mv = hum.MoveDirection
        if mv.Magnitude > 0.05 then
            accel = accel + mv.Unit * gravMag * 1.4
        end
        if jumpPulse > 0 then
            jumpPulse = jumpPulse - dt
            local swingDir = vel.Magnitude > 0.5 and vel.Unit or (arm:Cross(Vector3.yAxis))
            if swingDir.Magnitude > 0.01 then accel = accel + swingDir.Unit * gravMag * 2.2 end
        end
        local tangAccel = accel - arm * accel:Dot(arm)
        vel = vel + tangAccel * dt
        vel = vel * math.max(0, 1 - 0.4 * dt)
        local newBall = ballPos + vel * dt
        local newArm = newBall - pivot
        if newArm.Magnitude < 0.1 then newArm = -Vector3.yAxis end
        arm = newArm.Unit
        vel = vel - arm * vel:Dot(arm)
        ballPos = pivot + arm * length
        local up = (pivot - ballPos)
        up = up.Magnitude > 0.01 and up.Unit or Vector3.yAxis
        local fwd = vel.Magnitude > 0.5 and vel.Unit or arm:Cross(Vector3.yAxis)
        if fwd.Magnitude < 0.01 then fwd = Vector3.zAxis end
        fwd = fwd.Unit
        local right = fwd:Cross(up)
        if right.Magnitude < 0.01 then right = Vector3.xAxis end
        right = right.Unit
        local back = right:Cross(up).Unit
        root.CFrame = CFrame.fromMatrix(ballPos, right, up, back)
        root.AssemblyLinearVelocity = vel
        root.AssemblyAngularVelocity = Vector3.zero
    end)
end

local CommandRegistry = {commands = {}, disabledCommands = {}}
local hiddenCommands = {}

function CommandRegistry:addCommand(name, func, options)
    options = options or {}
    if type(name) ~= "string" or type(func) ~= "function" then return false end
    self.commands[name:lower()] = {
        func = func,
        description = options.description or "No description provided",
        usage = options.usage or "No usage information",
        enabled = true
    }
    return true
end

function CommandRegistry:getCommand(name, playerpower)
    name = name:lower()
    local command = self.commands[name]
    if not command then return nil end
    if playerpower and playerpower.Name == owner then return command end
    if self.disabledCommands[name] then return nil end
    return command
end

function CommandRegistry:enableCommand(name)
    name = name:lower()
    if not self.commands[name] then return false end
    self.disabledCommands[name] = nil
    return name, {}
end

function CommandRegistry:disableCommand(name)
    name = name:lower()
    if self.commands[name] then
        self.disabledCommands[name] = true
        return name, {}
    end
    return false
end

