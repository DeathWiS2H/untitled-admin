    pcall(function() RunService:UnbindFromRenderStep("UA_Loom") end)
    if not (targetPlayer and targetPlayer.Character and player.Character) then return end
    local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local targetHum = targetPlayer.Character:FindFirstChild("Humanoid")
    local localHum = player.Character:FindFirstChild("Humanoid")
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    if not (targetRoot and targetHum and localHum and root) then return end
    states.loom = true
    height = tonumber(height) or 5.5
    distance = tonumber(distance) or 4.5
    localHum:ChangeState(Enum.HumanoidStateType.Physics)
    localHum.PlatformStand = true
    pcall(function()
        if sethiddenproperty then
            sethiddenproperty(player, "MaximumSimulationRadius", math.huge)
            sethiddenproperty(player, "SimulationRadius", math.huge)
        end
    end)
    local function trueCF()
        local rep
        pcall(function()
            if gethiddenproperty then rep = gethiddenproperty(targetRoot, "PhysicsRepRootPart") end
        end)
        return typeof(rep) == "CFrame" and rep or targetRoot.CFrame
    end
    local pos = root.Position
    local vel = Vector3.zero
    local lastTargetPos = trueCF().Position
    local targetVel = Vector3.zero
    local breathe1, breathe2, breathe3 = math.random()*10, math.random()*10, math.random()*10
    local stiffness = 70
    local function apply(dt, render)
        if not (states.loom and player.Character and targetPlayer and targetPlayer.Character) then return false end
        root = player.Character:FindFirstChild("HumanoidRootPart")
        targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local hum = player.Character:FindFirstChild("Humanoid")
        if not (root and targetRoot and hum and targetHum.Health > 0) then return false end
        hum.PlatformStand = true
        local tcf = trueCF()
        local tpos = tcf.Position
        if not render then
            local rawVel = (tpos - lastTargetPos) / math.max(dt, 0.001)
            targetVel = targetVel:Lerp(rawVel, 0.35)
            lastTargetPos = tpos
            breathe1 += dt * 1.7 breathe2 += dt * 2.3 breathe3 += dt * 0.9
            local breath = Vector3.new(math.sin(breathe1), math.sin(breathe2) * 0.7 + math.sin(breathe3) * 0.5, math.cos(breathe1 * 0.8)) * 0.4
            local goal = tpos - tcf.LookVector * distance + Vector3.new(0, height, 0) + targetVel * 0.18 + breath
            local k = stiffness
            local c = 2 * math.sqrt(k)
            local accel = (goal - pos) * k - vel * c
            vel = vel + accel * dt
            pos = pos + vel * dt
        end
        local tilt = math.clamp(vel.Magnitude / 80, 0, 0.35)
        local leanDir = vel.Magnitude > 0.5 and vel.Unit or Vector3.zero
        local pitch = -leanDir.Y * tilt + math.sin(breathe2) * 0.05
        local head = targetPlayer.Character:FindFirstChild("Head")
        local watchPos = head and head.Position or tpos
        root.CFrame = CFrame.new(pos, watchPos) * CFrame.Angles(pitch, 0, math.sin(breathe1) * 0.06)
        root.AssemblyLinearVelocity = vel + targetVel * 0.5
        root.AssemblyAngularVelocity = Vector3.zero
        return true
    end
    RunService:BindToRenderStep("UA_Loom", Enum.RenderPriority.Last.Value, function(dt)
        if not apply(dt, true) then
            pcall(function() RunService:UnbindFromRenderStep("UA_Loom") end)
        end
    end)
    connections.loom = RunService.Heartbeat:Connect(function(dt)
        if not apply(math.min(dt, 1/30), false) then
            pcall(function() RunService:UnbindFromRenderStep("UA_Loom") end)
            local h = player.Character and player.Character:FindFirstChild("Humanoid")
            if h then h.PlatformStand = false h:ChangeState(Enum.HumanoidStateType.GettingUp) end
            disconnectConnection("loom")
            states.loom = false
        end
    end)
end

function Cmd.drag(targetPlayer, ropeLength, friction, elasticity)
    disconnectConnection("drag")
    if not (targetPlayer and targetPlayer.Character and player.Character) then return end
    local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local targetHum = targetPlayer.Character:FindFirstChild("Humanoid")
    local localHum = player.Character:FindFirstChild("Humanoid")
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    if not (targetRoot and targetHum and localHum and root) then return end
    states.drag = true
    ropeLength = tonumber(ropeLength) or 8
    friction = tonumber(friction) or 0.55
    elasticity = tonumber(elasticity) or 0.1
    localHum:ChangeState(Enum.HumanoidStateType.Physics)
    localHum.PlatformStand = true
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {player.Character, targetPlayer.Character}
    local pos = targetRoot.Position - targetRoot.CFrame.LookVector * math.min(ropeLength, 5)
    local vel = Vector3.zero
    local lastAnchor = targetRoot.Position
    local anchorVel = Vector3.zero
    local grounded = false
    local restHeight = (root.Size.Z * 0.5) + 0.05
    local stuck = true
    local STATIC_MULT = 1.3
    connections.drag = RunService.Heartbeat:Connect(function(dt)
        if not (states.drag and targetPlayer.Character and targetRoot and targetHum.Health > 0 and player.Character) then
            local h = player.Character and player.Character:FindFirstChild("Humanoid")
            if h then h.PlatformStand = false h:ChangeState(Enum.HumanoidStateType.GettingUp) end
            disconnectConnection("drag")
            states.drag = false
            return
        end
        root = player.Character:FindFirstChild("HumanoidRootPart")
        targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not (root and targetRoot) then return end
        dt = math.min(dt, 1/30)
        if player.Character then rayParams.FilterDescendantsInstances = {player.Character, targetPlayer.Character} end
        local anchor = targetRoot.Position
        anchorVel = (anchor - lastAnchor) / dt
        lastAnchor = anchor
        vel = vel + Vector3.new(0, -workspace.Gravity, 0) * dt
        local ray = workspace:Raycast(pos + Vector3.new(0, 2, 0), Vector3.new(0, -(2 + restHeight + 0.6), 0), rayParams)
        grounded = false
        local groundNormal = Vector3.yAxis
        if ray then
            groundNormal = ray.Normal
            local floorY = ray.Position.Y + restHeight
            if pos.Y <= floorY + 0.05 then
                grounded = true
                pos = Vector3.new(pos.X, floorY, pos.Z)
                if vel.Y < 0 then
                    vel = Vector3.new(vel.X, -vel.Y * 0.15, vel.Z)
                    if math.abs(vel.Y) < 2 then vel = Vector3.new(vel.X, 0, vel.Z) end
                end
                local slopeDir = (Vector3.yAxis - groundNormal * groundNormal.Y)
                if slopeDir.Magnitude > 0.02 then
                    vel = vel - slopeDir * workspace.Gravity * dt
                end
            end
        end
        local toMe = pos - anchor
        local dist = toMe.Magnitude
        if grounded then
            local hVel = Vector3.new(vel.X, 0, vel.Z)
            local hSpeed = hVel.Magnitude
            if stuck then
                if dist > ropeLength then
                    local stretch = dist - ropeLength
                    if stretch * 12 > friction * STATIC_MULT * workspace.Gravity * 0.1 then
                        stuck = false
                    end
                end
                if hSpeed > 0.5 then stuck = false end
                if stuck then vel = Vector3.new(0, vel.Y, 0) end
            else
                if hSpeed > 0.01 then
                    local fricDecel = friction * workspace.Gravity * dt
                    local newSpeed = math.max(0, hSpeed - fricDecel)
                    vel = hVel.Unit * newSpeed + Vector3.new(0, vel.Y, 0)
                    if newSpeed < 0.3 and dist <= ropeLength then
                        vel = Vector3.new(0, vel.Y, 0)
                        stuck = true
                    end
                end
            end
        end
        pos = pos + vel * dt
        toMe = pos - anchor
        dist = toMe.Magnitude
        if dist > ropeLength then
            local dir = toMe.Unit
            local stretch = dist - ropeLength
            pos = anchor + dir * (ropeLength + stretch * elasticity)
            local relVel = vel - anchorVel
            local radialSpeed = relVel:Dot(dir)
            if radialSpeed > 0 then
                vel = vel - dir * radialSpeed * (1 - elasticity * 0.5)
            end
            if grounded then
                stuck = false
                vel = vel + Vector3.new(-dir.X, 0, -dir.Z) * stretch * 4
                local ropePitch = (anchor.Y - pos.Y) / math.max(dist, 0.01)
                if ropePitch > 0.3 then
                    local relSpeed = (anchorVel - Vector3.new(vel.X, 0, vel.Z)).Magnitude
                    vel = vel + Vector3.new(0, (ropePitch - 0.3) * relSpeed * 1.5, 0)
                end
            end
        end
        local headDir = (anchor - pos)
        local headDirFlat = Vector3.new(headDir.X, 0, headDir.Z)
        if grounded and headDirFlat.Magnitude > 0.5 then
            local fwd = headDirFlat.Unit
            local up = groundNormal
            local right = fwd:Cross(up)
            if right.Magnitude > 0.01 then
                right = right.Unit
                fwd = up:Cross(right).Unit
                root.CFrame = CFrame.fromMatrix(pos, right, up, -fwd) * CFrame.Angles(math.rad(-90), 0, 0)
            end
        elseif headDir.Magnitude > 0.5 then
            root.CFrame = CFrame.new(pos, anchor) * CFrame.Angles(math.rad(-90), 0, 0)
        else
            root.CFrame = CFrame.new(pos) * root.CFrame.Rotation
        end
        root.Velocity = vel
        root.RotVelocity = Vector3.zero
    end)
end

function Cmd.stick(targetPlayer, distance, springiness)
    disconnectConnection("stick")
    pcall(function() RunService:UnbindFromRenderStep("UA_Stick") end)
    if not (targetPlayer and targetPlayer.Character and player.Character) then return end
    local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
