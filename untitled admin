function updateWelds()
    for _, c in ipairs(UI.weldFrame:GetChildren()) do
        if c:IsA("Frame") and c:GetAttribute("WeldItem") then
            c:Destroy()
        end
    end

    local isNarrow = UI.content.AbsoluteSize.X < 300
    local order = 10
    local q = (state.weldSearch or ""):lower()

    local function makeCard(w, prebuilt, id)
        local card = create("Frame", {Size=UDim2.new(1,-8,0,72),BackgroundColor3=THEME.panel,BorderSizePixel=0,LayoutOrder=order,Parent=UI.weldFrame})
        card:SetAttribute("WeldItem", true)
        corner(card, 5)
        order += 1

        create("TextLabel", {Size=UDim2.new(1,-16,0,16),Position=UDim2.new(0,8,0,5),Text=w.name,Font=Enum.Font.GothamBold,TextSize=13,TextColor3=THEME.text,BackgroundTransparency=1,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,Parent=card})
        create("TextLabel", {Size=UDim2.new(1,-16,0,14),Position=UDim2.new(0,8,0,22),Text=";"..w.name.." (player)",Font=Enum.Font.Code,TextSize=isNarrow and 9 or 10,TextColor3=THEME.textBlue,BackgroundTransparency=1,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,Parent=card})

        local brow = create("Frame", {Size=UDim2.new(1,-16,0,24),Position=UDim2.new(0,8,1,-28),BackgroundTransparency=1,Parent=card})
        local applyB = create("TextButton", {Size=UDim2.new(0.25,-3,1,0),Position=UDim2.new(0,0,0,0),Text="Apply",BackgroundColor3=THEME.green,TextColor3=THEME.text,Font=Enum.Font.Code,TextSize=11,BorderSizePixel=0,Parent=brow})
        corner(applyB,4)
        local loadB = create("TextButton", {Size=UDim2.new(0.25,-3,1,0),Position=UDim2.new(0.25,2,0,0),Text="Load",BackgroundColor3=THEME.accent,TextColor3=THEME.text,Font=Enum.Font.Code,TextSize=11,BorderSizePixel=0,Parent=brow})
        corner(loadB,4)
        local btnB = create("TextButton", {Size=UDim2.new(0.25,-3,1,0),Position=UDim2.new(0.5,2,0,0),Text="Button",BackgroundColor3=THEME.inputLight,TextColor3=THEME.text,Font=Enum.Font.Code,TextSize=11,BorderSizePixel=0,Parent=brow})
        corner(btnB,4)
        local delB = create("TextButton", {Size=UDim2.new(0.25,-2,1,0),Position=UDim2.new(0.75,2,0,0),Text="Delete",BackgroundColor3=THEME.red,TextColor3=THEME.text,Font=Enum.Font.Code,TextSize=11,BorderSizePixel=0,Parent=brow})
        corner(delB,4)

        applyB.MouseButton1Click:Connect(function()
            local t = weldPickTarget()
            if not t then
                if showWarning then showWarning("No other players to weld to", 5) end
                return
            end
            state.weld.fwd = w.fwd
            state.weld.side = w.side
            state.weld.up = w.up
            state.weld.rotX = w.rotX
            state.weld.rotY = w.rotY
            state.weld.rotZ = w.rotZ or 0
            state.weld.vel = w.vel or 0
            state.weld.dur = w.dur or 0
            state.weld.anim = w.anim or ""
            if UI.weldDurBox then UI.weldDurBox.Text = tostring(state.weld.dur) end
            if UI.weldAnimBox then UI.weldAnimBox.Text = state.weld.anim end
            if UI.weldBoxes then
                for key, box in pairs(UI.weldBoxes) do
                    if not box:IsFocused() then box.Text = tostring(state.weld[key]) end
                end
            end
            disablebool()
            lastTarget = t
            state.weld.target = t
            local aid = state.weld.anim ~= "" and weldFindAnimId(state.weld.anim) or nil
            Cmd.weldAdv(t, state.weld.fwd, state.weld.side, state.weld.up, state.weld.rotX, state.weld.rotY, state.weld.rotZ, state.weld.vel, state.weld.dur, aid)
        end)

        loadB.MouseButton1Click:Connect(function()
            state.weld.fwd = w.fwd
            state.weld.side = w.side
            state.weld.up = w.up
            state.weld.rotX = w.rotX
            state.weld.rotY = w.rotY
            state.weld.rotZ = w.rotZ or 0
            state.weld.vel = w.vel or 0
            state.weld.dur = w.dur or 0
            state.weld.anim = w.anim or ""
            if UI.weldDurBox then UI.weldDurBox.Text = tostring(state.weld.dur) end
            weldRedraw()
        end)

        btnB.MouseButton1Click:Connect(function()
            local bid = tostring(os.time())..math.random(1000,9999)
            buttons[bid] = {name=w.name, cmd=w.name.." near", toggle=false, offCmd=nil, width=90, height=48, position=UDim2.new(0.5,-45,0.5,-24), locked=false}
            createDraggableButton(buttons[bid], bid)
            if UI.btnFrame and UI.btnFrame.Visible then updateButtons() end
            btnB.Text = "Added!"
            task.delay(1, function() if btnB.Parent then btnB.Text = "Button" end end)
        end)

        delB.MouseButton1Click:Connect(function()
            local nm = w.name:lower()
            if prebuilt then
                state.weldPrebuiltDeleted[nm] = true
            else
                welds[id] = nil
            end
            if not protectedWeldNames[nm] and CommandRegistry.commands[nm] then
                CommandRegistry.commands[nm] = nil
            end
            updateWelds()
        end)
    end

    local shownPrebuilt = 0
    if not state.weldHidePrebuilt then
        for _, w in ipairs(PREBUILT_WELDS) do
            if not state.weldPrebuiltDeleted[w.name:lower()] then
                if q == "" or w.name:lower():find(q, 1, true) then
                    makeCard(w, true, nil)
                    shownPrebuilt += 1
                end
            end
        end
    end

    if shownPrebuilt > 0 then
        local div = create("Frame", {Size=UDim2.new(1,-16,0,2),BackgroundColor3=THEME.stroke,BorderSizePixel=0,LayoutOrder=order,Parent=UI.weldFrame})
        div:SetAttribute("WeldItem", true)
        order += 1
    end

    local list = {}
    for id, w in pairs(welds) do
        if q == "" or w.name:lower():find(q, 1, true) then
            list[#list+1] = {id=id, w=w}
        end
    end
    local mode = state.weldSort or "az"
    if mode == "za" then
        table.sort(list, function(a,b) return a.w.name:lower() > b.w.name:lower() end)
    elseif mode == "recent" then
        table.sort(list, function(a,b) return tostring(a.id) > tostring(b.id) end)
    else
        table.sort(list, function(a,b) return a.w.name:lower() < b.w.name:lower() end)
    end
    for _, e in ipairs(list) do
        makeCard(e.w, false, e.id)
    end

    if not next(welds) then
        local empty = create("Frame", {Size=UDim2.new(1,-8,0,40),BackgroundColor3=THEME.panel,BorderSizePixel=0,LayoutOrder=order,Parent=UI.weldFrame})
        empty:SetAttribute("WeldItem", true)
        corner(empty,5)
        create("TextLabel", {Size=UDim2.new(1,-16,1,0),Position=UDim2.new(0,8,0,0),Text="None saved — save a position above to create a command",Font=Enum.Font.Code,TextSize=11,TextColor3=THEME.textMuted,BackgroundTransparency=1,TextXAlignment=Enum.TextXAlignment.Left,TextYAlignment=Enum.TextYAlignment.Center,TextTruncate=Enum.TextTruncate.AtEnd,Parent=empty})
    end
end

function updateShareExport()
    if not UI.shareExportBox then return end
    local ok, enc = pcall(function() return HttpService:JSONEncode(Persist.collect()) end)
    UI.shareExportBox.Text = (ok and enc) or "{}"
end

do
    UI.shareFrame = makeScroll(false)
    local sortLabels = {az="A-Z ▼", za="Z-A ▼", recent="Recent ▼"}

    local exportCard = create("Frame",{Size=UDim2.new(1,-8,0,212),BackgroundColor3=THEME.panel,BorderSizePixel=0,LayoutOrder=1,Parent=UI.shareFrame})
    corner(exportCard,6)
    create("TextLabel",{Size=UDim2.new(1,-16,0,18),Position=UDim2.new(0,8,0,6),Text="Export Save",Font=Enum.Font.GothamBold,TextSize=13,TextColor3=THEME.text,BackgroundTransparency=1,TextXAlignment=Enum.TextXAlignment.Left,Parent=exportCard})
    create("TextLabel",{Size=UDim2.new(1,-16,0,14),Position=UDim2.new(0,8,0,24),Text="Your full config as a share code. Copy and send it.",Font=Enum.Font.Code,TextSize=10,TextColor3=THEME.textMuted,BackgroundTransparency=1,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,Parent=exportCard})
    UI.shareExportBox = create("TextBox",{Size=UDim2.new(1,-16,0,120),Position=UDim2.new(0,8,0,42),Text="{}",BackgroundColor3=THEME.input,TextColor3=THEME.textBlue,Font=Enum.Font.Code,TextSize=10,BorderSizePixel=0,TextXAlignment=Enum.TextXAlignment.Left,TextYAlignment=Enum.TextYAlignment.Top,TextWrapped=true,ClearTextOnFocus=false,MultiLine=true,ClipsDescendants=true,Parent=exportCard})
    corner(UI.shareExportBox,4)
    create("UIPadding",{PaddingLeft=UDim.new(0,6),PaddingRight=UDim.new(0,6),PaddingTop=UDim.new(0,5),PaddingBottom=UDim.new(0,5),Parent=UI.shareExportBox})
    local exRow = create("Frame",{Size=UDim2.new(1,-16,0,26),Position=UDim2.new(0,8,0,170),BackgroundTransparency=1,Parent=exportCard})
    local copyBtn = create("TextButton",{Size=UDim2.new(0.5,-3,1,0),Position=UDim2.new(0,0,0,0),Text="Copy",BackgroundColor3=THEME.accent,TextColor3=THEME.text,Font=Enum.Font.Code,TextSize=12,BorderSizePixel=0,Parent=exRow})
    corner(copyBtn,4)
    local refreshBtn = create("TextButton",{Size=UDim2.new(0.5,-3,1,0),Position=UDim2.new(0.5,3,0,0),Text="Refresh",BackgroundColor3=THEME.inputLight,TextColor3=THEME.text,Font=Enum.Font.Code,TextSize=12,BorderSizePixel=0,Parent=exRow})
    corner(refreshBtn,4)

    copyBtn.MouseButton1Click:Connect(function()
        updateShareExport()
        local text = UI.shareExportBox.Text
        local ok = false
        pcall(function()
            if setclipboard then setclipboard(text) ok = true
            elseif toclipboard then toclipboard(text) ok = true
            elseif type(syn)=="table" and syn.write_clipboard then syn.write_clipboard(text) ok = true end
        end)
        copyBtn.Text = ok and "Copied!" or "Copy manually"
        copyBtn.BackgroundColor3 = ok and THEME.green or THEME.orange
        if showWarning then showWarning(ok and "Save copied to clipboard" or "Copy unsupported - select the box and copy manually", ok and 4 or 8) end
        task.delay(1.2, function() if copyBtn.Parent then copyBtn.Text = "Copy" copyBtn.BackgroundColor3 = THEME.accent end end)
    end)
    refreshBtn.MouseButton1Click:Connect(function()
        updateShareExport()
        refreshBtn.Text = "Refreshed!"
        task.delay(1, function() if refreshBtn.Parent then refreshBtn.Text = "Refresh" end end)
    end)

    local importCard = create("Frame",{Size=UDim2.new(1,-8,0,206),BackgroundColor3=THEME.panel,BorderSizePixel=0,LayoutOrder=2,Parent=UI.shareFrame})
    corner(importCard,6)
    create("TextLabel",{Size=UDim2.new(1,-16,0,18),Position=UDim2.new(0,8,0,6),Text="Import Save",Font=Enum.Font.GothamBold,TextSize=13,TextColor3=THEME.text,BackgroundTransparency=1,TextXAlignment=Enum.TextXAlignment.Left,Parent=importCard})
    create("TextLabel",{Size=UDim2.new(1,-16,0,14),Position=UDim2.new(0,8,0,24),Text="Paste a share code to load it. Replaces your current config.",Font=Enum.Font.Code,TextSize=10,TextColor3=THEME.textMuted,BackgroundTransparency=1,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,Parent=importCard})
    local importBox = create("TextBox",{Size=UDim2.new(1,-16,0,110),Position=UDim2.new(0,8,0,42),PlaceholderText="Paste save code here...",Text="",BackgroundColor3=THEME.input,TextColor3=THEME.text,Font=Enum.Font.Code,TextSize=10,BorderSizePixel=0,TextXAlignment=Enum.TextXAlignment.Left,TextYAlignment=Enum.TextYAlignment.Top,TextWrapped=true,ClearTextOnFocus=false,MultiLine=true,ClipsDescendants=true,Parent=importCard})
    corner(importBox,4)
    create("UIPadding",{PaddingLeft=UDim.new(0,6),PaddingRight=UDim.new(0,6),PaddingTop=UDim.new(0,5),PaddingBottom=UDim.new(0,5),Parent=importBox})
    local importBtn = create("TextButton",{Size=UDim2.new(1,-16,0,28),Position=UDim2.new(0,8,0,160),Text="Import",BackgroundColor3=THEME.green,TextColor3=THEME.text,Font=Enum.Font.Code,TextSize=12,BorderSizePixel=0,Parent=importCard})
    corner(importBtn,4)

    local function applyImported(data)
        if type(data.prefix) == "string" and data.prefix ~= "" then prefix = data.prefix getgenv().Settings.prefix = prefix end
        if data.chatEnabled ~= nil then chatEnabled = data.chatEnabled and true or false end
        if tonumber(data.flyspeed) then pcall(function() CL.setFlySpeed(tonumber(data.flyspeed)) end) end
        if tonumber(data.transp) then Transp.Transparency = math.clamp(tonumber(data.transp), 0, 1) end
        if tonumber(data.transpRadius) then Transp.Radius = math.max(1, tonumber(data.transpRadius)) Transp.overlap.MaxParts = math.max(200, math.ceil(Transp.Radius * 25)) end
        if type(data.kbSort) == "string" then state.kbSort = data.kbSort if UI.kbSortBtn then UI.kbSortBtn.Text = sortLabels[state.kbSort] or "A-Z ▼" end end
        if type(data.animSort) == "string" then state.animSort = data.animSort if UI.animSortBtn then UI.animSortBtn.Text = sortLabels[state.animSort] or "A-Z ▼" end end
        if data.animHidePrebuilt ~= nil then state.animHidePrebuilt = data.animHidePrebuilt and true or false if UI.animHideBtn then UI.animHideBtn.Text = state.animHidePrebuilt and "Prebuilt: Hidden" or "Prebuilt: Shown" UI.animHideBtn.BackgroundColor3 = state.animHidePrebuilt and THEME.red or THEME.green end end
        if type(data.weldSort) == "string" then state.weldSort = data.weldSort if UI.weldSortBtn then UI.weldSortBtn.Text = sortLabels[state.weldSort] or "A-Z ▼" end end
        if data.weldHidePrebuilt ~= nil then state.weldHidePrebuilt = data.weldHidePrebuilt and true or false if UI.weldHideBtn then UI.weldHideBtn.Text = state.weldHidePrebuilt and "Prebuilt: Hidden" or "Prebuilt: Shown" UI.weldHideBtn.BackgroundColor3 = state.weldHidePrebuilt and THEME.red or THEME.green end end

        if CommandRegistry then
            CommandRegistry.disabledCommands = {}
            if type(data.disabled) == "table" then for _, n in ipairs(data.disabled) do CommandRegistry.disabledCommands[tostring(n)] = true end end
        end
        if type(data.cmdDefaults) == "table" then
            state.cmdDefaults = {}
            for cmdName, args in pairs(data.cmdDefaults) do
                if type(args) == "table" then
                    local clean = {}
                    for k, v in pairs(args) do
                        local nv = tonumber(v)
                        if nv ~= nil then clean[tostring(k)] = nv end
                    end
                    if next(clean) then state.cmdDefaults[tostring(cmdName)] = clean end
                end
            end
        end

        if type(data.keybinds) == "table" then
            for k in pairs(state.keybinds) do state.keybinds[k] = nil end
            state.kbToggleState = {}
            state.kbCounter = 0
            for k, v in pairs(data.keybinds) do
                local entry
                if type(v) == "table" then
                    entry = {cmd=tostring(v.cmd or ""), toggle=v.toggle and true or false, offCmd=(type(v.offCmd)=="string" and v.offCmd ~= "" and v.offCmd or nil), added=tonumber(v.added) or 0}
                elseif type(v) == "string" then
                    entry = {cmd=v, toggle=false, offCmd=nil, added=0}
                end
                if entry then
                    state.keybinds[tostring(k)] = entry
                    if entry.added > state.kbCounter then state.kbCounter = entry.added end
                end
            end
        end

        if type(data.animations) == "table" then
            for id in pairs(animations) do
                local d = animations[id]
                if d and d.playing then pcall(function() CL.stopAnimId(d.animId) end) end
                animations[id] = nil
            end
            for id, d in pairs(data.animations) do
                if type(d) == "table" then animations[id] = {name=d.name, animId=d.animId, playing=false, speed=tonumber(d.speed) or 1, setTime=tonumber(d.setTime) or 0} end
            end
        end

        if type(data.buttons) == "table" then
            for id in pairs(buttons) do
                local ex = UI.buttonGui:FindFirstChild("CmdButton_"..id)
                if ex then pcall(function() ex:Destroy() end) end
                buttons[id] = nil
            end
            for id, d in pairs(data.buttons) do
                if type(d) == "table" then
                    buttons[id] = {name=d.name, cmd=d.cmd, toggle=d.toggle and true or false, offCmd=d.offCmd, width=d.width or 90, height=d.height or 48, locked=d.locked and true or false, shown=d.shown and true or false, position=UDim2.new(d.pxs or 0.5, d.pxo or -45, d.pys or 0.5, d.pyo or -24)}
                    if buttons[id].shown then pcall(function() createDraggableButton(buttons[id], id) end) end
                end
            end
        end

        if type(data.welds) == "table" then
            for id, w in pairs(welds) do
                local nm = w.name and w.name:lower()
                if nm and not protectedWeldNames[nm] and CommandRegistry.commands[nm] then CommandRegistry.commands[nm] = nil end
                welds[id] = nil
            end
            for id, w in pairs(data.welds) do
                if type(w) == "table" and w.name then
                    welds[id] = {name=tostring(w.name), fwd=tonumber(w.fwd) or 0, side=tonumber(w.side) or 0, up=tonumber(w.up) or 0, rotX=tonumber(w.rotX) or 0, rotY=tonumber(w.rotY) or 0, rotZ=tonumber(w.rotZ) or 0, vel=tonumber(w.vel) or 0, dur=tonumber(w.dur) or 0, anim=type(w.anim)=="string" and w.anim or ""}
                    pcall(function() registerWeldCommand(welds[id]) end)
                end
            end
        end

        if type(data.weldCycle) == "table" then
            local wc = data.weldCycle
            local steps = {}
            if type(wc.steps) == "table" then
                for _, s in ipairs(wc.steps) do
                    if type(s) == "table" then
                        steps[#steps+1] = {name=tostring(s.name or "?"), fwd=tonumber(s.fwd) or 0, side=tonumber(s.side) or 0, up=tonumber(s.up) or 0, rotX=tonumber(s.rotX) or 0, rotY=tonumber(s.rotY) or 0, rotZ=tonumber(s.rotZ) or 0, vel=tonumber(s.vel) or 0, anim=type(s.anim)=="string" and s.anim or "", cond=type(s.cond)=="string" and s.cond or "any", hold=math.max(0, tonumber(s.hold) or 1)}
                    end
                end
            end
            local m = wc.mode
            if m == "timer" then m = "both" elseif m == "state" then m = "tracker" end
            if m ~= "tracker" and m ~= "both" then m = "cycle" end
            state.weldCycle = {steps=steps, mode=m}
        end

        if type(data.weldCyclesSaved) == "table" then
            for _, w in pairs(state.weldCyclesSaved) do
                local nm = w.name and w.name:lower()
                if nm and not protectedWeldNames[nm] and CommandRegistry.commands[nm] then CommandRegistry.commands[nm] = nil end
            end
            state.weldCyclesSaved = {}
            for id, w in pairs(data.weldCyclesSaved) do
                if type(w) == "table" and w.name and type(w.steps) == "table" then
                    local steps = {}
                    for _, s in ipairs(w.steps) do
                        if type(s) == "table" then
                            steps[#steps+1] = {name=tostring(s.name or "?"), fwd=tonumber(s.fwd) or 0, side=tonumber(s.side) or 0, up=tonumber(s.up) or 0, rotX=tonumber(s.rotX) or 0, rotY=tonumber(s.rotY) or 0, rotZ=tonumber(s.rotZ) or 0, vel=tonumber(s.vel) or 0, anim=type(s.anim)=="string" and s.anim or "", cond=type(s.cond)=="string" and s.cond or "any", hold=math.max(0, tonumber(s.hold) or 1)}
                        end
                    end
                    local m = w.mode
                    if m ~= "tracker" and m ~= "both" then m = "cycle" end
                    state.weldCyclesSaved[tostring(id)] = {name=tostring(w.name), mode=m, steps=steps}
                    pcall(function() registerWeldCycleCommand(state.weldCyclesSaved[tostring(id)]) end)
                end
            end
        end

        if type(data.tpPositions) == "table" then
            state.tpPositions = {}
            for id, p in pairs(data.tpPositions) do
                if type(p) == "table" and p.name then
                    state.tpPositions[tostring(id)] = {name=tostring(p.name), x=tonumber(p.x) or 0, y=tonumber(p.y) or 0, z=tonumber(p.z) or 0, rx=tonumber(p.rx) or 0, ry=tonumber(p.ry) or 0, rz=tonumber(p.rz) or 0, place=tonumber(p.place) or 0}
                end
            end
        end

        if type(data.grid) == "table" and state.grid then
            if data.grid.enabled ~= nil then state.grid.enabled = data.grid.enabled and true or false end
            if tonumber(data.grid.size) then state.grid.size = math.clamp(math.floor(tonumber(data.grid.size)), 4, 400) end
            if data.grid.show ~= nil then state.grid.show = data.grid.show and true or false end
            pcall(function() Grid.rebuild() end)
        end

        pcall(function() updateKeybinds() end)
        pcall(function() updateButtons() end)
        pcall(function() updateAnimations() end)
        pcall(function() updateWelds() end)
        pcall(function() rebuildWeldCycle() end)
        pcall(function() updatePositions() end)
        pcall(function() updateSettings() end)
        pcall(function() updateCommands() end)
        pcall(function() updateShareExport() end)
        pcall(function() Persist.save() end)
    end

    importBtn.MouseButton1Click:Connect(function()
        local raw = (importBox.Text or ""):gsub("^%s+",""):gsub("%s+$","")
        if raw == "" then
            if showWarning then showWarning("Paste a save code first", 5) end
            return
        end
        local ok, data = pcall(function() return HttpService:JSONDecode(raw) end)
        if not ok or type(data) ~= "table" then
            if showWarning then showWarning("Invalid save code - check you copied all of it", 7) end
            importBtn.Text = "Invalid"
            importBtn.BackgroundColor3 = THEME.red
            task.delay(1.2, function() if importBtn.Parent then importBtn.Text = "Import" importBtn.BackgroundColor3 = THEME.green end end)
            return
        end
        local applied = pcall(applyImported, data)
        if applied then
            if Persist.canIO() then pcall(function() writefile(Persist.file, HttpService:JSONEncode(data)) end) end
            Persist.last = nil
            importBox.Text = ""
            importBtn.Text = "Imported!"
            if showWarning then showWarning("Save imported and applied", 4) end
        else
            importBtn.Text = "Error"
            importBtn.BackgroundColor3 = THEME.red
            if showWarning then showWarning("Something went wrong applying that save", 7) end
        end
        task.delay(1.2, function() if importBtn.Parent then importBtn.Text = "Import" importBtn.BackgroundColor3 = THEME.green end end)
    end)
end

do
    UI.codesFrame = makeScroll(false)
    local redeemCard = create("Frame",{Size=UDim2.new(1,-8,0,178),BackgroundColor3=THEME.panel,BorderSizePixel=0,LayoutOrder=1,Parent=UI.codesFrame})
    corner(redeemCard,6)
