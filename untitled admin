    stroke.Parent = f
    local bar = create("Frame", {Name="Bar",Size=UDim2.new(1,0,0,22),BackgroundColor3=THEME.titleBar,BorderSizePixel=0,Parent=f})
    corner(bar, 8)
    create("Frame", {Size=UDim2.new(1,0,0,11),Position=UDim2.new(0,0,1,-11),BackgroundColor3=THEME.titleBar,BorderSizePixel=0,Parent=bar})
    create("TextLabel", {Size=UDim2.new(1,-30,1,0),Position=UDim2.new(0,8,0,0),Text="spectating",TextColor3=THEME.textDim,Font=Enum.Font.Code,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,BackgroundTransparency=1,ZIndex=2,Parent=bar})
    local closeBtn = create("TextButton", {Size=UDim2.fromOffset(18,18),Position=UDim2.new(1,-22,0,2),Text="✕",TextColor3=THEME.textDim,Font=Enum.Font.GothamBold,TextSize=11,BackgroundColor3=THEME.input,BorderSizePixel=0,ZIndex=3,Parent=bar})
    corner(closeBtn, 4)
    local prevBtn = create("TextButton", {Size=UDim2.fromOffset(38,30),Position=UDim2.new(0,8,0,30),Text="‹",TextColor3=THEME.text,Font=Enum.Font.GothamBold,TextSize=22,BackgroundColor3=THEME.input,BorderSizePixel=0,Parent=f})
    corner(prevBtn, 4)
    local nextBtn = create("TextButton", {Size=UDim2.fromOffset(38,30),Position=UDim2.new(1,-46,0,30),Text="›",TextColor3=THEME.text,Font=Enum.Font.GothamBold,TextSize=22,BackgroundColor3=THEME.input,BorderSizePixel=0,Parent=f})
    corner(nextBtn, 4)
    CL.viewLabel = create("TextLabel", {Size=UDim2.new(1,-100,0,30),Position=UDim2.new(0,50,0,30),Text="-",TextColor3=THEME.text,Font=Enum.Font.GothamBold,TextSize=13,TextXAlignment=Enum.TextXAlignment.Center,TextTruncate=Enum.TextTruncate.AtEnd,BackgroundTransparency=1,Parent=f})
    prevBtn.MouseButton1Click:Connect(function() CL.viewCycle(-1) end)
    nextBtn.MouseButton1Click:Connect(function() CL.viewCycle(1) end)
    closeBtn.MouseButton1Click:Connect(function() CL.setViewState(false) end)
    local function hov(b, base, hover)
        b.MouseEnter:Connect(function() TweenService:Create(b,TweenInfo.new(.12),{BackgroundColor3=hover}):Play() end)
        b.MouseLeave:Connect(function() TweenService:Create(b,TweenInfo.new(.12),{BackgroundColor3=base}):Play() end)
    end
    hov(prevBtn, THEME.input, THEME.inputLight)
    hov(nextBtn, THEME.input, THEME.inputLight)
    hov(closeBtn, THEME.input, THEME.hoverDark)
    local dragging, dragStart, startPos = false, nil, nil
    bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true dragStart = input.Position startPos = f.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    local dconn = UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            local vp = workspace.CurrentCamera.ViewportSize
            local baseX = startPos.X.Scale * vp.X + startPos.X.Offset
            local baseY = startPos.Y.Scale * vp.Y + startPos.Y.Offset
            local nx = math.clamp(baseX + delta.X, 0, math.max(0, vp.X - f.AbsoluteSize.X))
            local ny = math.clamp(baseY + delta.Y, 0, math.max(0, vp.Y - f.AbsoluteSize.Y))
            f.Position = UDim2.fromOffset(nx, ny)
        end
    end)
    table.insert(getgenv().UntitledAdminConnections, dconn)
    f.Destroying:Connect(function() if dconn then dconn:Disconnect() dconn = nil end end)
    CL.viewGui = f
    return f
end

function CL.startView()
    CL.viewActive = true
    if not (CL.viewing and CL.viewing.Parent) then
        local default
        for _, plr in ipairs(CL.viewSorted()) do if plr ~= player then default = plr break end end
        CL.viewing = default or player
    end
    CL.viewBuildGui()
    CL.viewGui.Visible = true
    if not CL.viewConns.leave then
        CL.viewConns.leave = Players.PlayerRemoving:Connect(function(plr)
            if CL.viewActive and plr == CL.viewing then
                task.wait(0.1)
                CL.viewCycle(1)
            end
        end)
    end
    CL.viewApply(CL.viewing)
end

function CL.stopView()
    CL.viewActive = false
    for k, c in pairs(CL.viewConns) do
        if c then pcall(function() c:Disconnect() end) end
        CL.viewConns[k] = nil
    end
    CL.viewing = nil
    if CL.viewGui then CL.viewGui.Visible = false end
    if CL.viewLabel then CL.viewLabel.Text = "-" end
    pcall(function()
        local char = player.Character
        local cam = workspace.CurrentCamera
        if cam and char then cam.CameraSubject = char:FindFirstChildOfClass("Humanoid") or char end
    end)
end

