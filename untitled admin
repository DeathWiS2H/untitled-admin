function updateKeybinds()
    for _, child in ipairs(UI.kbScroll:GetChildren()) do
        if child:IsA("Frame") and child ~= UI.kbCard and child ~= UI.kbCtrl then child:Destroy() end
    end
    local order = 3
    local isNarrow = UI.content.AbsoluteSize.X < 300
    local q = (state.kbSearch or ""):lower()
    local list = {}
    for keyName, v in pairs(state.keybinds) do
        local entry = kbEntry(v)
        state.keybinds[keyName] = entry
        if q == "" or keyName:lower():find(q, 1, true) or (entry.cmd or ""):lower():find(q, 1, true) then
            list[#list+1] = {key=keyName, entry=entry}
        end
    end
    local mode = state.kbSort or "az"
    if mode == "za" then
        table.sort(list, function(a,b) return a.key:lower() > b.key:lower() end)
    elseif mode == "recent" then
        table.sort(list, function(a,b) return (a.entry.added or 0) > (b.entry.added or 0) end)
    else
        table.sort(list, function(a,b) return a.key:lower() < b.key:lower() end)
    end
    for _, e in ipairs(list) do
        makeKbCard(e.key, e.entry, order, isNarrow)
        order = order + 1
    end
end

