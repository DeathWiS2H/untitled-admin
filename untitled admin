    local accentBar = create("Frame", {Size=UDim2.new(0,0,0,2),Position=UDim2.new(0,0,1,-2),BackgroundColor3=THEME.accent,BorderSizePixel=0,ZIndex=3,Parent=topBar})
    TweenService:Create(accentBar,TweenInfo.new(0.3,Enum.EasingStyle.Quad),{Size=UDim2.new(1,0,0,2)}):Play()
    local textBtn = create("TextButton", {Size=UDim2.new(1,0,1,-14),Position=UDim2.new(0,0,0,14),BackgroundTransparency=1,TextColor3=THEME.textBright,Font=Enum.Font.GothamBold,TextSize=12,Text=data.name or "Button",BorderSizePixel=0,TextScaled=true,ZIndex=2,Parent=btn})
    create("UIPadding", {PaddingLeft=UDim.new(0,6),PaddingRight=UDim.new(0,6),PaddingTop=UDim.new(0,4),PaddingBottom=UDim.new(0,5),Parent=textBtn})
    local textConstraint = Instance.new("UITextSizeConstraint")
    textConstraint.MaxTextSize = 14
    textConstraint.MinTextSize = 8
    textConstraint.Parent = textBtn
    local resizeHandle = create("Frame", {Name="ResizeHandle",Size=UDim2.fromOffset(8,8),Position=UDim2.new(1,-4,1,-4),AnchorPoint=Vector2.new(0.5,0.5),BackgroundColor3=THEME.accent,BackgroundTransparency=0.4,BorderSizePixel=0,ZIndex=5,Active=true,Parent=btn})
    local cornerHandle = Instance.new("UICorner") cornerHandle.CornerRadius = UDim.new(0.5,0) cornerHandle.Parent = resizeHandle
    local function updateColors()
        if data.toggle and btnState then
            TweenService:Create(btn,TweenInfo.new(0.15),{BackgroundColor3=THEME.onBg}):Play()
            TweenService:Create(topBar,TweenInfo.new(0.15),{BackgroundColor3=THEME.onTop}):Play()
            TweenService:Create(accentBar,TweenInfo.new(0.15),{BackgroundColor3=THEME.green}):Play()
            TweenService:Create(stroke,TweenInfo.new(0.15),{Color=THEME.onStroke}):Play()
            if not data.locked then resizeHandle.BackgroundColor3=THEME.green end
        else
            TweenService:Create(btn,TweenInfo.new(0.15),{BackgroundColor3=THEME.panel2}):Play()
            TweenService:Create(topBar,TweenInfo.new(0.15),{BackgroundColor3=THEME.btnTop}):Play()
            TweenService:Create(accentBar,TweenInfo.new(0.15),{BackgroundColor3=THEME.accent}):Play()
            TweenService:Create(stroke,TweenInfo.new(0.15),{Color=THEME.stroke}):Play()
            if not data.locked then resizeHandle.BackgroundColor3=THEME.accent end
        end
    end
    updateColors()
    local function updateLockVisual()
        resizeHandle.Visible = not data.locked
        topBar.Visible = not data.locked
        if data.locked then
            textBtn.Size = UDim2.new(1,0,1,0)
            textBtn.Position = UDim2.new(0,0,0,0)
        else
            textBtn.Size = UDim2.new(1,0,1,-14)
            textBtn.Position = UDim2.new(0,0,0,14)
        end
    end
    updateLockVisual()
    btn:SetAttribute("UpdateLock", true)
    btn.AttributeChanged:Connect(function(attr)
        if attr == "UpdateLock" then updateLockVisual() updateColors() end
    end)
    textBtn.MouseButton1Click:Connect(function()
        local origSize = btn.Size
        TweenService:Create(btn,TweenInfo.new(0.06,Enum.EasingStyle.Quad),{Size=UDim2.fromOffset(origSize.X.Offset-4,origSize.Y.Offset-3)}):Play()
        task.delay(0.07,function()
            TweenService:Create(btn,TweenInfo.new(0.1,Enum.EasingStyle.Back),{Size=origSize}):Play()
        end)
        if data.toggle then
            btnState = not btnState updateColors()
            processCmd(player, btnState and data.cmd or (data.offCmd or data.cmd))
        else processCmd(player, data.cmd) end
    end)
    textBtn.MouseEnter:Connect(function()
        if not (data.toggle and btnState) then
            TweenService:Create(btn,TweenInfo.new(0.12),{BackgroundColor3=THEME.hoverBtn}):Play()
        end
    end)
    textBtn.MouseLeave:Connect(function() updateColors() end)
    local draggingBtn,dragStart,startPosBtn=false,nil,nil
    topBar.InputBegan:Connect(function(input)
        if data.locked then return end
        if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
            draggingBtn=true dragStart=input.Position startPosBtn=btn.Position
            input.Changed:Connect(function() if input.UserInputState==Enum.UserInputState.End then draggingBtn=false data.position=btn.Position end end)
        end
    end)
    local dragMoveConn = UserInputService.InputChanged:Connect(function(input)
        if draggingBtn and (input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch) then
            local delta=input.Position-dragStart
            local screenSize = workspace.CurrentCamera.ViewportSize
            local absSize = btn.AbsoluteSize
            local baseX = startPosBtn.X.Scale*screenSize.X
            local baseY = startPosBtn.Y.Scale*screenSize.Y
            local absX = baseX + startPosBtn.X.Offset + delta.X
            local absY = baseY + startPosBtn.Y.Offset + delta.Y
            if state.grid and state.grid.enabled then
                local g = math.max(4, state.grid.size)
                absX = math.floor(absX / g + 0.5) * g
                absY = math.floor(absY / g + 0.5) * g
            end
            absX = math.clamp(absX, 0, math.max(0,screenSize.X-absSize.X))
            absY = math.clamp(absY, 0, math.max(0,screenSize.Y-absSize.Y))
            btn.Position=UDim2.new(startPosBtn.X.Scale, absX - baseX, startPosBtn.Y.Scale, absY - baseY)
        end
    end)
    local resizingBtn,resizeStart,startSizeBtn=false,nil,nil
    local MIN_WIDTH,MIN_HEIGHT,MAX_WIDTH,MAX_HEIGHT=50,38,300,300
    resizeHandle.InputBegan:Connect(function(input)
        if data.locked then return end
        if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
            resizingBtn=true resizeStart=Vector2.new(input.Position.X,input.Position.Y) startSizeBtn=btn.AbsoluteSize
            input.Changed:Connect(function() if input.UserInputState==Enum.UserInputState.End then resizingBtn=false data.width=btn.AbsoluteSize.X data.height=btn.AbsoluteSize.Y end end)
        end
    end)
    local resizeMoveConn = UserInputService.InputChanged:Connect(function(input)
        if resizingBtn and (input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch) then
            local delta=Vector2.new(input.Position.X,input.Position.Y)-resizeStart
            local w = startSizeBtn.X+delta.X
            local h = startSizeBtn.Y+delta.Y
            if state.grid and state.grid.enabled then
                local g = math.max(4, state.grid.size)
                local wc = math.max(math.ceil(MIN_WIDTH / g), math.floor(w / g + 0.5))
                local hc = math.max(math.ceil(MIN_HEIGHT / g), math.floor(h / g + 0.5))
                w = math.min(MAX_WIDTH, wc * g)
                h = math.min(MAX_HEIGHT, hc * g)
            else
                w = math.clamp(w, MIN_WIDTH, MAX_WIDTH)
                h = math.clamp(h, MIN_HEIGHT, MAX_HEIGHT)
            end
            btn.Size=UDim2.fromOffset(w, h)
        end
    end)
    btn.Destroying:Connect(function()
        if dragMoveConn then dragMoveConn:Disconnect() dragMoveConn=nil end
        if resizeMoveConn then resizeMoveConn:Disconnect() resizeMoveConn=nil end
    end)
    if applyButtonTransparencyTo then applyButtonTransparencyTo(btn) end
    return btn
end

function updateButtons()
    for _, child in ipairs(UI.btnScroll:GetChildren()) do
        if child:IsA("Frame") and child ~= UI.btnCard and child ~= UI.btnCtrl then child:Destroy() end
    end
    local isNarrow = UI.content.AbsoluteSize.X < 300
    local fontSize = isNarrow and 9 or 10
    local q = (state.btnSearch or ""):lower()

    local list = {}
    for id, data in pairs(buttons) do
        local nm = (data.name or ""):lower()
        local cm = (data.cmd or ""):lower()
        if q == "" or nm:find(q, 1, true) or cm:find(q, 1, true) then
            list[#list+1] = {id=id, data=data}
        end
    end
    local mode = state.btnSort or "recent"
    if mode == "za" then
        table.sort(list, function(a,b) return (a.data.name or ""):lower() > (b.data.name or ""):lower() end)
    elseif mode == "recent" then
        table.sort(list, function(a,b) return tostring(a.id) > tostring(b.id) end)
    else
        table.sort(list, function(a,b) return (a.data.name or ""):lower() < (b.data.name or ""):lower() end)
    end

    local layoutOrder = 3
    for _, e in ipairs(list) do
        local id, data = e.id, e.data
        local card = create("Frame", {Size=UDim2.new(1,-8,0,74),BackgroundColor3=THEME.panel,BorderSizePixel=0,LayoutOrder=layoutOrder,Parent=UI.btnScroll})
        corner(card, 5)
        layoutOrder = layoutOrder + 1
        create("TextLabel", {Size=UDim2.new(1,-16,0,16),Position=UDim2.new(0,8,0,6),Text=data.name or "Unnamed",Font=Enum.Font.GothamBold,TextSize=isNarrow and 11 or 12,TextColor3=THEME.text,BackgroundTransparency=1,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,Parent=card})
        create("TextLabel", {Size=UDim2.new(1,-16,0,16),Position=UDim2.new(0,8,0,24),Text=data.toggle and (data.cmd.." | "..(data.offCmd or "off")) or data.cmd,Font=Enum.Font.Code,TextSize=fontSize,TextColor3=THEME.textGray,BackgroundTransparency=1,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,Parent=card})
        local row = create("Frame", {Size=UDim2.new(1,-16,0,24),Position=UDim2.new(0,8,1,-30),BackgroundTransparency=1,Parent=card})
        local show = create("TextButton", {Size=UDim2.new(1/3,-3,1,0),Position=UDim2.new(0,0,0,0),Text="Show",BackgroundColor3=THEME.accent,TextColor3=THEME.text,Font=Enum.Font.Code,TextSize=fontSize,BorderSizePixel=0,Parent=row})
        corner(show, 4)
        local editB = create("TextButton", {Size=UDim2.new(1/3,-3,1,0),Position=UDim2.new(1/3,2,0,0),Text="Edit",BackgroundColor3=THEME.inputLight,TextColor3=THEME.text,Font=Enum.Font.Code,TextSize=fontSize,BorderSizePixel=0,Parent=row})
        corner(editB, 4)
        local del = create("TextButton", {Size=UDim2.new(1/3,-3,1,0),Position=UDim2.new(2/3,3,0,0),Text="Delete",BackgroundColor3=THEME.red,TextColor3=THEME.text,Font=Enum.Font.Code,TextSize=fontSize,BorderSizePixel=0,Parent=row})
        corner(del, 4)
        local function updateShowBtn()
            if UI.buttonGui:FindFirstChild("CmdButton_"..id) then
                if data.locked then
                    show.Text = "Unlock"
                    show.BackgroundColor3 = THEME.orange
                else
                    show.Text = "Lock"
                    show.BackgroundColor3 = THEME.green
                end
            else
                show.Text = "Show"
                show.BackgroundColor3 = THEME.accent
            end
        end
        show.MouseButton1Click:Connect(function()
            local existing = UI.buttonGui:FindFirstChild("CmdButton_"..id)
            if existing then
                data.locked = not data.locked
                existing:SetAttribute("UpdateLock", not existing:GetAttribute("UpdateLock"))
            else
                createDraggableButton(data, id)
            end
            updateShowBtn()
        end)
        updateShowBtn()
        editB.MouseButton1Click:Connect(function()
            state.btnEditing = id
            UI.btnName.Text = data.name or ""
            UI.btnCmd.Text = data.cmd or ""
            setBtnTogMode(data.toggle and true or false)
            UI.btnOff.Text = data.offCmd or ""
            if state.btnMinimized then
                state.btnMinimized = false
                UI.btnMinimizeBtn.Text = "-"
                UI.btnName.Visible = true UI.btnCmd.Visible = true UI.btnTogFrame.Visible = true UI.btnOff.Visible = state.btnTogMode UI.btnAdd.Visible = true
                updateBtnCardSize()
            end
            UI.btnAdd.Text = "Save Changes"
            UI.btnAdd.BackgroundColor3 = THEME.orange
        end)
        del.MouseButton1Click:Connect(function()
            if UI.buttonGui:FindFirstChild("CmdButton_"..id) then UI.buttonGui:FindFirstChild("CmdButton_"..id):Destroy() end
            if state.btnEditing == id then
                state.btnEditing = nil
                UI.btnName.Text = "" UI.btnCmd.Text = "" UI.btnOff.Text = ""
                UI.btnAdd.Text = "Add Button" UI.btnAdd.BackgroundColor3 = THEME.green
            end
            buttons[id]=nil updateButtons()
        end)
    end
end

