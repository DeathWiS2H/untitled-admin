            end
            if seen then seenT += dt unseenT = 0 else unseenT += dt seenT = 0 end
            boldness = math.clamp(boldness + (seen and -dt * 0.5 or dt * 0.12), 0, 1)
            local tSpeed = Vector3.new(targetVel.X,0,targetVel.Z).Magnitude
            if phase == "circle" then
                reverseTimer = reverseTimer - dt
                if reverseTimer <= 0 then
                    orbitDir = -orbitDir
                    reverseTimer = 3 + math.random() * 4
                end
                if seenT > 0.25 then
                    dodgeSign = (tcf.RightVector:Dot(flat.Magnitude>0.1 and flat.Unit or tcf.RightVector) >= 0) and -1 or 1
                    setPhase("dodge")
                elseif boldness > 0.8 and unseenT > 1.2 and phaseT > 1.5 then
                    swoopSign = orbitDirSmooth >= 0 and 1 or -1
                    setPhase("swoop")
                elseif phaseT > 5 + math.random()*3 then
                    setPhase("lurk")
                end
            elseif phase == "dodge" then
                if unseenT > 0.6 and phaseT > 0.8 then
                    orbitDir = (dodgeSign >= 0) and 1 or -1
                    setPhase("circle")
                end
            elseif phase == "swoop" then
                if phaseT > 1.3 then setPhase("circle") boldness = boldness*0.6 end
            elseif phase == "lurk" then
                if tSpeed > 12 and phaseT > 0.8 then setPhase("circle")
                elseif boldness > 0.9 and phaseT > 2 then setPhase("mirror")
                elseif phaseT > 4 then setPhase("circle") end
            elseif phase == "mirror" then
                if seenT > 0.3 then
                    dodgeSign = math.random(0,1)==0 and -1 or 1
                    setPhase("dodge")
                elseif phaseT > 3 then setPhase("lurk") end
            end
            blend = math.min(1, blend + dt / 0.9)
            local ease = blend*blend*(3-2*blend)
            local breath = Vector3.new(math.sin(breathe1), math.sin(breathe2)*0.7 + math.sin(breathe3)*0.5, math.cos(breathe1*0.8)) * (0.45 * intensity)
            local lead = targetVel * (0.25 + boldness * 0.35)
            local goal
            local stiffMul = 1
            if phase == "circle" then
                orbitAng += dt * orbitDirSmooth * (1.1 + boldness * 0.9) * (1 + math.sin(breathe3)*0.2)
                weave += dt * 1.6
                radiusPhase += dt * 0.6
                local r = 11 - boldness * 5 + math.sin(radiusPhase) * 2.5 + math.sin(breathe1*0.5) * 1
                local h = 2.5 + math.sin(weave) * 2.5 + boldness * 1.5
                goal = tpos + Vector3.new(math.cos(orbitAng)*r, h, math.sin(orbitAng)*r) + lead
                stiffMul = 1.1
            elseif phase == "dodge" then
                local side = tcf.RightVector * (dodgeSign * 13)
                goal = tpos + side - tcf.LookVector * 2 + Vector3.new(0, 6 + math.sin(breathe2)*1.5, 0) + lead
                stiffMul = 1.9
            elseif phase == "swoop" then
                local dive = math.sin(math.clamp(phaseT/1.3,0,1) * math.pi)
                local axis = flat.Magnitude>0.1 and flat.Unit or -tcf.LookVector
                local head = targetPlayer.Character:FindFirstChild("Head")
                local hp = head and head.Position or (tpos + Vector3.new(0,2,0))
                local lateral = tcf.RightVector * (swoopSign * dive * 4)
                goal = hp + axis * (7 - dive * 6.5) + lateral + Vector3.new(0, 3 - dive * 3.2, 0) + lead * 0.5
                stiffMul = 2.6
            elseif phase == "lurk" then
                local back = tSpeed > 1 and -Vector3.new(targetVel.X,0,targetVel.Z).Unit or -tcf.LookVector
                goal = tpos + back * 9 + Vector3.new(0, 4 + math.sin(breathe3)*1.5, 0) + lead
                stiffMul = 0.8
            else
                weave += dt * 2.2
                goal = tpos + tcf.LookVector * 5 + tcf.RightVector * math.sin(weave) * 2 + Vector3.new(0, 0.5, 0)
                stiffMul = 2.2
            end
            goal = goal + breath * (0.5 + ease * 0.5)
            goal = goalPrev:Lerp(goal, ease)
            goalCur = goal
            local k = stiffness * stiffMul
            local c = 2 * math.sqrt(k)
            local accel = (goal - pos) * k - vel * c
            vel = vel + accel * dt
            pos = pos + vel * dt
        end
        local tilt = math.clamp(vel.Magnitude / 70, 0, 0.5)
        local leanDir = vel.Magnitude > 0.5 and vel.Unit or Vector3.zero
        local targetBank = -leanDir:Dot(tcf.RightVector) * tilt
        bank = bank + (targetBank - bank) * math.min(1, dt * 6)
        local targetRoll = (phase == "swoop") and math.sin(phaseT * 6) * 0.4 or 0
        roll = roll + (targetRoll - roll) * math.min(1, dt * 5)
        local pitch = -leanDir.Y * tilt + math.sin(breathe2) * 0.05
        local head = targetPlayer.Character:FindFirstChild("Head")
        local watchPos = head and head.Position or tpos
        root.CFrame = CFrame.new(pos, watchPos) * CFrame.Angles(pitch, 0, bank + roll + math.sin(breathe1)*0.05)
        root.AssemblyLinearVelocity = vel + targetVel * 0.5
        root.AssemblyAngularVelocity = Vector3.zero
        return true
    end
    RunService:BindToRenderStep("UA_Wraith", Enum.RenderPriority.Last.Value, function(dt)
        if not apply(dt, true) then
