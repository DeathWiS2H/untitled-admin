function CL.startWalkFling()
    if CL.walkflinging then return end
    CL.walkflinging = true
    local movel = 0.1
    CL.conns.wflingNoclip = RunService.Stepped:Connect(function()
        if not CL.walkflinging then return end
        local char = player.Character
        if not char then return end
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") and p.CanCollide then
                p.CanCollide = false
            end
        end
    end)
    task.spawn(function()
        while CL.walkflinging do
            RunService.Heartbeat:Wait()
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if root and hum and hum.Health > 0 and not (states and (states.missile or states.torpedo or states.meteor or states.stick or states.stick2 or states.stick3 or states.stick4 or states.stick5 or states.stick6 or CL.flying)) then
                local vel = root.AssemblyLinearVelocity
                root.AssemblyLinearVelocity = vel * 10000 + Vector3.new(0, 10000, 0)
                RunService.RenderStepped:Wait()
                if CL.walkflinging and root.Parent then
                    root.AssemblyLinearVelocity = vel
                end
                RunService.Stepped:Wait()
                if CL.walkflinging and root.Parent then
                    root.AssemblyLinearVelocity = vel + Vector3.new(0, movel, 0)
                    movel = movel * -1
                end
            end
        end
    end)
    if CL.conns.wflingDied then CL.conns.wflingDied:Disconnect() end
    local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
    if hum then
        CL.conns.wflingDied = hum.Died:Connect(function()
            if CL.setWalkFlingState then CL.setWalkFlingState(false) end
        end)
    end
    if CL.conns.wflingCA then CL.conns.wflingCA:Disconnect() end
    CL.conns.wflingCA = player.CharacterAdded:Connect(function(char)
        if not CL.walkflinging then return end
        local h = char:WaitForChild("Humanoid", 10)
        if h and CL.walkflinging then
            if CL.conns.wflingDied then CL.conns.wflingDied:Disconnect() end
            CL.conns.wflingDied = h.Died:Connect(function()
                if CL.setWalkFlingState then CL.setWalkFlingState(false) end
            end)
        end
    end)
end

function CL.stopWalkFling()
    CL.walkflinging = false
    for _, k in ipairs({"wflingNoclip","wflingDied","wflingCA"}) do
        if CL.conns[k] then pcall(function() CL.conns[k]:Disconnect() end) CL.conns[k] = nil end
    end
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if root then root.AssemblyLinearVelocity = Vector3.zero end
    if hum then hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
    if char then
        task.defer(function()
            for _, p in ipairs(char:GetDescendants()) do
                if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then p.CanCollide = true end
            end
        end)
    end
end

