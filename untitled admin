local function weldPickTarget()
    local me = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    local best, bestD = nil, math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local r = plr.Character.HumanoidRootPart
            if me then
                local d = (me.Position - r.Position).Magnitude
                if d < bestD then bestD = d best = plr end
            else
                best = best or plr
            end
        end
    end
    return best
end

function weldFindAnimId(name)
    name = (name or ""):gsub("^%s+",""):gsub("%s+$",""):lower()
    if name == "" then return nil end
    if animations then
        for _, d in pairs(animations) do
            if d.name and d.name:lower() == name then return d.animId end
        end
    end
    if PREBUILT_ANIMS then
        for _, d in ipairs(PREBUILT_ANIMS) do
            if d.name and d.name:lower() == name and not (state.animPrebuiltDeleted and state.animPrebuiltDeleted[name]) then return d.animId end
        end
    end
    return nil
end

