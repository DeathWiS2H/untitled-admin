    if not (humanoid and root) then return end
    velocity = math.floor(math.abs(velocity))
    if velocity < 1 then velocity = 1 end
    humanoid:ChangeState(Enum.HumanoidStateType.Physics)
    local vel = Instance.new("BodyVelocity")
    vel.Name, vel.Parent, vel.MaxForce = "Upward", root, Vector3.new(0, math.huge, 0)
    vel.Velocity = Vector3.new(0, upwardVelocity, 0)
    local spin = Instance.new("BodyAngularVelocity")
    spin.Name, spin.Parent, spin.MaxTorque = "InitialSpinning", root, Vector3.new(0, math.huge, 0)
    spin.AngularVelocity = Vector3.new(0, 25, 0)
    task.delay(1.75, function()
        if spin then spin:Destroy() end
        local newSpin = Instance.new("BodyAngularVelocity")
        newSpin.Name, newSpin.Parent, newSpin.MaxTorque = "Spinning", root, Vector3.new(math.huge, math.huge, math.huge)
        newSpin.AngularVelocity = Vector3.new(
            math.clamp(math.random(-velocity, velocity), -velocity/2, velocity/2),
            math.clamp(math.random(-velocity, velocity), -velocity/2, velocity/2),
            math.clamp(math.random(-velocity, velocity), -velocity/2, velocity/2)
        )
        task.delay(0.25, function()
            if newSpin then newSpin:Destroy() end
            if vel then vel:Destroy() end
            Cmd.kill()
        end)
    end)
    if targetPlayer and targetPlayer.Character then
        local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        if targetRoot then root.CFrame = CFrame.new(targetRoot.Position + Vector3.new(0, 5, 0)) end
    end
