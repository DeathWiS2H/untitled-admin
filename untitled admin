    if not (targetRoot and targetHum and localHum and localRoot) then return end
    states.quake = true
    radius = math.max(1, math.floor(radius))
    localHum:ChangeState(Enum.HumanoidStateType.Physics)
    local lastTeleport = 0
    local function getRandomPosition()
        local randomAngle = math.random() * 2 * math.pi
        local randomRadius = math.random(math.floor(radius * 0.5), radius)
        return targetRoot.Position + Vector3.new(math.cos(randomAngle) * randomRadius, 0, math.sin(randomAngle) * randomRadius)
    end
    connections.quake = RunService.Heartbeat:Connect(function()
        if not (states.quake and targetPlayer.Character and targetRoot and targetHum.Health > 0 and player.Character) then
            if localHum then localHum:ChangeState(Enum.HumanoidStateType.GettingUp) end
            disconnectConnection("quake")
            states.quake = false
            return
        end
        localRoot = player.Character:FindFirstChild("HumanoidRootPart")
        targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        if localRoot and targetRoot then
            local currentTime = tick()
            if currentTime - lastTeleport >= teleportDelay then
                localRoot.CFrame = CFrame.new(getRandomPosition(), targetRoot.Position)
                lastTeleport = currentTime
            else
                local currentPos = localRoot.Position
                localRoot.CFrame = CFrame.lookAt(currentPos, Vector3.new(targetRoot.Position.X, currentPos.Y, targetRoot.Position.Z))
            end
            removeVelocity()
        end
    end)
end

