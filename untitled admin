local function cmdIsWeldName(n)
    if welds then for _, w in pairs(welds) do if w.name:lower() == n then return true end end end
    if PREBUILT_WELDS then for _, w in ipairs(PREBUILT_WELDS) do if w.name:lower() == n and not (state.weldPrebuiltDeleted and state.weldPrebuiltDeleted[n]) then return true end end end
    return false
end

function settingsCmdKind(n)
    if welds then for _, w in pairs(welds) do if w.name:lower() == n then return "welds" end end end
    if PREBUILT_WELDS then for _, w in ipairs(PREBUILT_WELDS) do if w.name:lower() == n then return "welds" end end end
    if state.weldCyclesSaved then for _, w in pairs(state.weldCyclesSaved) do if w.name and w.name:lower() == n then return "welds" end end end
    if animations then for _, d in pairs(animations) do if d.name and d.name:lower() == n then return "animations" end end end
    if PREBUILT_ANIMS then for _, d in ipairs(PREBUILT_ANIMS) do if d.name and d.name:lower() == n then return "animations" end end end
    return "commands"
end

local function cmdIsCycleName(n)
    if state.weldCyclesSaved then
        for _, w in pairs(state.weldCyclesSaved) do
            if w.name and w.name:lower() == n then return true end
        end
    end
    return false
end

